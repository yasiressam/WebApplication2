@model IEnumerable<WebApplication2.Models.Ngo>

@{
    
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-6">
            <h2>المنظمات غير الحكومية</h2>
            <p class="text-muted">هذه البيانات يضيفها المستخدمون عند التسجيل</p>
        </div>
        <div class="col-6 text-start">
            <a href="@Url.Action("CreateNgo")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> إضافة منظمة غير حكومية جديدة
            </a>
            <a href="@Url.Action("Dashboard")" class="btn btn-secondary">
                <i class="bi bi-arrow-right"></i> عودة
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>اسم المنظمة غير الحكومية</th>
                           @*  <th>تاريخ الإضافة</th> *@
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int i = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@(i++)</td>
                                    <td>@item.Name</td>
                                    @* <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td> *@
                                    <td>
                                        <button class="btn btn-danger btn-sm" onclick="deleteNgo(@item.Id, '@item.Name')">
                                            <i class="bi bi-trash"></i> حذف
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    لا توجد منظمات غير حكومية
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function deleteNgo(id, name) {
            if (confirm(`هل أنت متأكد من حذف المنظمة غير الحكومية "${name}"؟`)) {
                console.log("محاولة حذف منظمة غير حكومية:", id, name);

                var token = $('input[name="__RequestVerificationToken"]').val();
                if (!token) token = $('form input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("DeleteNgo", "ManageableEntities")',
                    type: 'POST',
                    data: {
                        id: id
                    },
                    headers: {
                        'RequestVerificationToken': token
                    },
                    success: function(response) {
                        console.log("الرد من السيرفر:", response);
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert("فشل الحذف: " + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error("حالة الخطأ:", status);
                        console.error("نص الخطأ:", error);
                        console.error("رد السيرفر:", xhr.responseText);
                        alert('خطأ في الاتصال: ' + error);
                    }
                });
            }
        }
    </script>
}