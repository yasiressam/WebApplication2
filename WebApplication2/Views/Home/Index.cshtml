@model IEnumerable<WebApplication2.Models.News>



<style>
    /* ===== السلايدر الرئيسي ===== */
    .featured-slider {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        margin-bottom: 60px;
    }

    .slider-item {
        display: none;
    }

        .slider-item.active {
            display: block;
        }

    .slider-image {
        height: 500px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .slider-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .slider-content {
        padding: 40px;
        background: white;
    }

        .slider-content h3 {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 20px;
            color: #111827;
            line-height: 1.4;
        }

        .slider-content p {
            color: #4b5563;
            font-size: 1.2rem;
            line-height: 1.8;
            margin-bottom: 25px;
        }

    .slider-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #6b7280;
        font-size: 1.1rem;
    }

    .slider-controls {
        position: relative;
        display: flex;
        justify-content: center;
        gap: 12px;
        padding: 20px;
        background: #f9fafb;
        border-top: 1px solid #e5e7eb;
    }

    .slider-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: none;
        background: #d1d5db;
        cursor: pointer;
        transition: all 0.3s;
    }

        .slider-dot.active {
            background: #111827;
            width: 30px;
            border-radius: 20px;
        }

    .slider-arrow {
        position: absolute;
        top: -25px;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: white;
        border: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s;
        font-size: 1.5rem;
    }

        .slider-arrow:hover {
            background: #111827;
            color: white;
            border-color: #111827;
        }

        .slider-arrow.prev {
            left: 20px;
        }

        .slider-arrow.next {
            right: 20px;
        }

    /* ===== قائمة الأخبار الرئيسية ===== */
    .main-news-section {
        margin: 60px 0;
    }

    .section-header {
        margin-bottom: 40px;
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .section-title {
        font-size: 2.2rem;
        font-weight: 800;
        color: #111827;
        margin: 0;
        position: relative;
    }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -17px;
            right: 0;
            width: 100px;
            height: 4px;
            background: #dc2626;
        }

    .view-all-link {
        color: #111827;
        font-size: 1.1rem;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        cursor: pointer;
    }

        .view-all-link:hover {
            color: #dc2626;
            gap: 12px;
        }

    /* ===== قائمة الأخبار العمودية ===== */
    .news-list-vertical {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .news-item-horizontal {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
        border: 1px solid #e5e7eb;
    }

        .news-item-horizontal:hover {
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            border-color: #111827;
        }

    .news-item-link {
        display: flex;
        padding: 25px;
        text-decoration: none;
        color: inherit;
        gap: 30px;
    }

    .news-item-image {
        width: 280px;
        height: 180px;
        border-radius: 12px;
        overflow: hidden;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .news-item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .news-item-horizontal:hover .news-item-image img {
        transform: scale(1.05);
    }

    .news-item-image i {
        font-size: 4rem;
        color: #9ca3af;
    }

    .news-item-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .news-item-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 15px;
        line-height: 1.4;
    }

    .news-item-excerpt {
        color: #4b5563;
        font-size: 1.1rem;
        line-height: 1.7;
        margin-bottom: 20px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .news-item-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
    }

    .news-item-date {
        color: #9ca3af;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .news-item-date i {
            color: #111827;
        }

    .read-more {
        color: #111827;
        font-weight: 600;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
    }

    .news-item-horizontal:hover .read-more {
        color: #dc2626;
        gap: 12px;
    }

    /* ===== تذييل الصفحة ===== */
    .load-more-container {
        text-align: center;
        margin-top: 50px;
    }

    .btn-load-more {
        background: transparent;
        border: 2px solid #111827;
        color: #111827;
        padding: 15px 50px;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: 50px;
        cursor: pointer;
        transition: all 0.3s;
    }

        .btn-load-more:hover {
            background: #111827;
            color: white;
        }

    /* ===== إخفاء الأخبار الإضافية ===== */
    .news-item-horizontal.extra-news {
        display: none;
    }

        .news-item-horizontal.extra-news.show {
            display: block;
        }

    /* ===== رسالة لا توجد أخبار ===== */
    .no-news {
        text-align: center;
        padding: 80px 20px;
        background: white;
        border-radius: 20px;
    }

        .no-news i {
            font-size: 5rem;
            color: #d1d5db;
            margin-bottom: 25px;
        }

        .no-news h3 {
            font-size: 2rem;
            font-weight: 700;
            color: #111827;
            margin-bottom: 15px;
        }

        .no-news p {
            color: #6b7280;
            font-size: 1.2rem;
        }

    /* ===== صفحة جميع الأخبار ===== */
    .all-news-page {
        margin-top: 30px;
    }

    .page-title {
        font-size: 2.2rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 3px solid #dc2626;
    }

    .back-link {
        margin-bottom: 20px;
        display: inline-block;
    }

        .back-link a {
            color: #111827;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 5px;
            font-weight: 600;
        }

            .back-link a:hover {
                color: #dc2626;
            }

    /* ===== تحسينات الموبايل ===== */
    @@media (max-width: 992px) {
        .slider-image {
            height: 400px;
        }

        .slider-content h3 {
            font-size: 1.8rem;
        }

        .news-item-link {
            flex-direction: column;
        }

        .news-item-image {
            width: 100%;
            height: 250px;
        }

        .news-item-title {
            font-size: 1.4rem;
        }
    }

    @@media (max-width: 768px) {
        .slider-image {
            height: 300px;
        }

        .slider-content {
            padding: 25px;
        }

            .slider-content h3 {
                font-size: 1.5rem;
            }

            .slider-content p {
                font-size: 1rem;
            }

        .slider-arrow {
            width: 40px;
            height: 40px;
            font-size: 1.2rem;
        }

        .section-title {
            font-size: 1.8rem;
        }

        .news-item-title {
            font-size: 1.3rem;
        }

        .news-item-excerpt {
            font-size: 1rem;
        }

        .page-title {
            font-size: 1.8rem;
        }
    }
</style>

@{
    var showAll = Context.Request.Query.ContainsKey("all") && Context.Request.Query["all"] == "true";
}

@if (showAll)
{
    <!-- صفحة عرض جميع الأخبار -->
    <div class="all-news-page">
        <div class="back-link">
            <a href="@Url.Action("Index", "Home")">
                <i class="bi bi-arrow-right"></i> العودة للرئيسية
            </a>
        </div>

        <h1 class="page-title">جميع الأخبار</h1>

        @if (Model.Any())
        {
            <div class="news-list-vertical">
                @foreach (var news in Model)
                {
                    <div class="news-item-horizontal">
                        <a href="@Url.Action("NewsDetails", "News", new { id = news.Id })" class="news-item-link">
                            <div class="news-item-image">
                                @if (!string.IsNullOrEmpty(news.ImageUrl))
                                {
                                    <img src="@news.ImageUrl" alt="@news.Title"
                                         onerror="this.onerror=null; this.innerHTML='<i class=\'bi bi-newspaper\'></i>'">
                                }
                                else
                                {
                                    <i class="bi bi-newspaper"></i>
                                }
                            </div>
                            <div class="news-item-content">
                                <h3 class="news-item-title">@news.Title</h3>
                                <p class="news-item-excerpt">
                                    @(news.Content.Length > 150 ? news.Content.Substring(0, 150) + "..." : news.Content)
                                </p>
                                <div class="news-item-footer">
                                    <span class="news-item-date">
                                        <i class="bi bi-calendar3"></i>
                                        @news.CreatedAt.ToString("yyyy/MM/dd")
                                    </span>
                                    <span class="read-more">
                                        اقرأ المزيد
                                        <i class="bi bi-arrow-left"></i>
                                    </span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-news">
                <i class="bi bi-newspaper"></i>
                <h3>لا توجد أخبار</h3>
                <p>سيتم إضافة الأخبار قريباً</p>
            </div>
        }
    </div>
}
else
{
    <!-- الصفحة الرئيسية مع السلايدر -->
    <!-- السلايدر الرئيسي -->
    @if (Model.Any())
    {
        <div class="featured-slider">
            @for (int i = 0; i < Model.Take(5).Count(); i++)
            {
                var news = Model.ElementAt(i);
                <div class="slider-item @(i == 0 ? "active" : "")">
                    <div class="row g-0">
                        <div class="col-md-7">
                            <div class="slider-image">
                                @if (!string.IsNullOrEmpty(news.ImageUrl))
                                {
                                    <img src="@news.ImageUrl" alt="@news.Title"
                                         onerror="this.onerror=null; this.parentElement.innerHTML='<i class=\'bi bi-newspaper\' style=\'font-size:5rem;color:#9ca3af;\'></i>'">
                                }
                                else
                                {
                                    <i class="bi bi-newspaper" style="font-size:5rem; color:#9ca3af;"></i>
                                }
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="slider-content">
                                <h3>@news.Title</h3>
                                <p>@(news.Content.Length > 200 ? news.Content.Substring(0, 200) + "..." : news.Content)</p>
                                <div class="slider-meta">
                                    <span>
                                        <i class="bi bi-calendar me-2"></i>
                                        @news.CreatedAt.ToString("yyyy/MM/dd")
                                    </span>
                                    <a href="@Url.Action("NewsDetails", "News", new { id = news.Id })" class="btn btn-primary btn-lg">
                                        قراءة المزيد
                                        <i class="bi bi-arrow-left ms-2"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- أزرار التحكم -->
            <div class="slider-controls">
                <button class="slider-arrow prev" onclick="prevSlide()">
                    <i class="bi bi-chevron-right"></i>
                </button>
                @for (int i = 0; i < Model.Take(5).Count(); i++)
                {
                    <button class="slider-dot @(i == 0 ? "active" : "")"
                            onclick="goToSlide(@i)"></button>
                }
                <button class="slider-arrow next" onclick="nextSlide()">
                    <i class="bi bi-chevron-left"></i>
                </button>
            </div>
        </div>

        <!-- جميع الأخبار في الأسفل -->
        <div class="main-news-section">
            <div class="section-header">
                <h2 class="section-title">أحدث الأخبار</h2>
                <a href="?all=true" class="view-all-link">
                    عرض الكل
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>

            <div class="news-list-vertical" id="newsList">
                @{
                    var newsList = Model.ToList();
                    int initialCount = 5; // عدد الأخبار التي تظهر في البداية
                }

                @for (int i = 0; i < newsList.Count; i++)
                {
                    var news = newsList[i];
                    <div class="news-item-horizontal @(i >= initialCount ? "extra-news" : "")">
                        <a href="@Url.Action("NewsDetails", "News", new { id = news.Id })" class="news-item-link">
                            <div class="news-item-image">
                                @if (!string.IsNullOrEmpty(news.ImageUrl))
                                {
                                    <img src="@news.ImageUrl" alt="@news.Title"
                                         onerror="this.onerror=null; this.innerHTML='<i class=\'bi bi-newspaper\'></i>'">
                                }
                                else
                                {
                                    <i class="bi bi-newspaper"></i>
                                }
                            </div>
                            <div class="news-item-content">
                                <h3 class="news-item-title">@news.Title</h3>
                                <p class="news-item-excerpt">
                                    @(news.Content.Length > 150 ? news.Content.Substring(0, 150) + "..." : news.Content)
                                </p>
                                <div class="news-item-footer">
                                    <span class="news-item-date">
                                        <i class="bi bi-calendar3"></i>
                                        @news.CreatedAt.ToString("yyyy/MM/dd")
                                    </span>
                                    <span class="read-more">
                                        اقرأ المزيد
                                        <i class="bi bi-arrow-left"></i>
                                    </span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            @if (newsList.Count > 5)
            {
                <div class="load-more-container">
                    <button class="btn-load-more" onclick="loadMoreNews()">
                        تحميل المزيد من الأخبار
                    </button>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-news">
            <i class="bi bi-newspaper"></i>
            <h3>لا توجد أخبار حالياً</h3>
            <p>سيتم إضافة الأخبار قريباً</p>
        </div>
    }
}

<script>
    let currentSlide = 0;
    let slides = document.querySelectorAll('.slider-item');
    let dots = document.querySelectorAll('.slider-dot');
    let slideInterval;

    function showSlide(index) {
        if (!slides.length) return;

        slides.forEach(s => s.classList.remove('active'));
        dots.forEach(d => d.classList.remove('active'));

        slides[index].classList.add('active');
        dots[index].classList.add('active');
        currentSlide = index;
    }

    function nextSlide() {
        if (!slides.length) return;
        clearInterval(slideInterval);
        showSlide((currentSlide + 1) % slides.length);
        startAutoSlide();
    }

    function prevSlide() {
        if (!slides.length) return;
        clearInterval(slideInterval);
        showSlide((currentSlide - 1 + slides.length) % slides.length);
        startAutoSlide();
    }

    function goToSlide(index) {
        if (!slides.length) return;
        clearInterval(slideInterval);
        showSlide(index);
        startAutoSlide();
    }

    function startAutoSlide() {
        if (slides.length > 1) {
            slideInterval = setInterval(nextSlide, 5000);
        }
    }

    function loadMoreNews() {
        var extraNews = document.querySelectorAll('.extra-news');
        var count = 0;

        extraNews.forEach(function(news) {
            if (!news.classList.contains('show') && count < 5) {
                news.classList.add('show');
                count++;
            }
        });

        // إخفاء الزر إذا تم عرض كل الأخبار
        var remainingNews = document.querySelectorAll('.extra-news:not(.show)');
        if (remainingNews.length === 0) {
            document.querySelector('.load-more-container').style.display = 'none';
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        if (slides.length > 0) {
            startAutoSlide();
        }
    });
</script>