@model WebApplication2.Models.SiteSettings

@{
    ViewData["Title"] = "إعدادات الموقع";
    ViewData["Icon"] = "bi bi-gear";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg">
                <div class="card-header bg-gradient-primary text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-gear me-2"></i>إعدادات الموقع
                    </h3>
                    <small class="opacity-75">للمشرف العام فقط - تعديل معلومات الفوتر</small>
                </div>

                <div class="card-body">
                    <!-- رسائل -->
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" asp-action="Index" id="settingsForm">
                        @Html.AntiForgeryToken()

                        <!-- معلومات الاتصال الأساسية -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h4 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="bi bi-telephone me-2"></i>معلومات الاتصال
                                </h4>

                                <div class="mb-3">
                                    <label asp-for="ContactEmail" class="form-label fw-bold">
                                        <i class="bi bi-envelope me-1"></i>البريد الإلكتروني
                                    </label>
                                    <input asp-for="ContactEmail" type="email" class="form-control"
                                           placeholder="info@example.com" required>
                                    <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ContactPhone" class="form-label fw-bold">
                                        <i class="bi bi-phone me-1"></i>رقم الهاتف
                                    </label>
                                    <input asp-for="ContactPhone" class="form-control"
                                           placeholder="+964 XXX XXX XXXX" required>
                                    <span asp-validation-for="ContactPhone" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="SiteAddress" class="form-label fw-bold">
                                        <i class="bi bi-geo-alt me-1"></i>العنوان
                                    </label>
                                    <input asp-for="SiteAddress" class="form-control"
                                           placeholder="العراق - بغداد">
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h4 class="text-success border-bottom pb-2 mb-3">
                                    <i class="bi bi-info-circle me-2"></i>وصف الموقع
                                </h4>

                                <div class="mb-3">
                                    <label asp-for="SiteDescription" class="form-label fw-bold">
                                        <i class="bi bi-text-paragraph me-1"></i>وصف الموقع
                                    </label>
                                    <textarea asp-for="SiteDescription" class="form-control" rows="6"
                                              placeholder="أدخل وصف الموقع الذي سيظهر في الفوتر" required></textarea>
                                    <small class="text-muted">هذا الوصف سيظهر في قسم معلومات الموقع في الفوتر</small>
                                    <span asp-validation-for="SiteDescription" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- وسائل التواصل الاجتماعي (الثلاثة فقط) -->
                        <div class="mb-4">
                            <h4 class="text-info border-bottom pb-2 mb-3">
                                <i class="bi bi-share me-2"></i>وسائل التواصل الاجتماعي
                            </h4>
                            <p class="text-muted mb-3">أدخل روابط وسائل التواصل الاجتماعي (اترك الحقل فارغاً إذا كنت لا تريد إظهاره)</p>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 border-primary">
                                        <div class="card-body">
                                            <label asp-for="FacebookUrl" class="form-label fw-bold">
                                                <i class="bi bi-facebook text-primary me-1"></i>فيسبوك
                                            </label>
                                            <input asp-for="FacebookUrl" type="url" class="form-control"
                                                   placeholder="https://facebook.com/username">
                                            <span asp-validation-for="FacebookUrl" class="text-danger small"></span>
                                            <small class="text-muted mt-2 d-block">
                                                <i class="bi bi-info-circle me-1"></i>
                                                مثال: https://facebook.com/yourpage
                                            </small>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 border-danger">
                                        <div class="card-body">
                                            <label asp-for="InstagramUrl" class="form-label fw-bold">
                                                <i class="bi bi-instagram text-danger me-1"></i>إنستغرام
                                            </label>
                                            <input asp-for="InstagramUrl" type="url" class="form-control"
                                                   placeholder="https://instagram.com/username">
                                            <span asp-validation-for="InstagramUrl" class="text-danger small"></span>
                                            <small class="text-muted mt-2 d-block">
                                                <i class="bi bi-info-circle me-1"></i>
                                                مثال: https://instagram.com/yourpage
                                            </small>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 border-success">
                                        <div class="card-body">
                                            <label asp-for="WhatsAppNumber" class="form-label fw-bold">
                                                <i class="bi bi-whatsapp text-success me-1"></i>واتساب
                                            </label>
                                            <input asp-for="WhatsAppNumber" class="form-control"
                                                   placeholder="+964XXXXXXXXX">
                                            <span asp-validation-for="WhatsAppNumber" class="text-danger small"></span>
                                            <small class="text-muted mt-2 d-block">
                                                <i class="bi bi-info-circle me-1"></i>
                                                مثال: +9647701234567
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- أزرار التحكم -->
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <div>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-right me-1"></i>العودة للرئيسية
                                </a>

                                <a asp-action="Reset" class="btn btn-outline-warning ms-2"
                                   onclick="return confirm('هل أنت متأكد من إعادة تعيين جميع الإعدادات إلى القيم الافتراضية؟')">
                                    <i class="bi bi-arrow-clockwise me-1"></i>إعادة التعيين
                                </a>
                            </div>

                            <div>
                                <button type="reset" class="btn btn-warning me-2">
                                    <i class="bi bi-arrow-clockwise me-1"></i>إعادة تعيين النموذج
                                </button>
                                <button type="submit" class="btn btn-success" id="saveBtn">
                                    <i class="bi bi-save me-1"></i>حفظ التغييرات
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light text-muted">
                    <div class="d-flex justify-content-between align-items-center">
                        <small>
                            <i class="bi bi-info-circle me-1"></i>
                            سيتم تطبيق التغييرات مباشرة على الفوتر في جميع صفحات الموقع
                        </small>
                        <small>
                            <i class="bi bi-clock-history me-1"></i>
                            آخر تحديث: @Model.LastUpdated.ToString("yyyy/MM/dd HH:mm")
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            // تأكيد الحفظ
            $('#settingsForm').submit(function(e) {
                if ($(this).valid()) {
                    $('#saveBtn').prop('disabled', true).html('<i class="bi bi-hourglass-split me-1"></i>جاري الحفظ...');
                    return true;
                }
                return false;
            });

            // إضافة https:// تلقائياً لروابط السوشيال ميديا
            $('#FacebookUrl, #InstagramUrl').blur(function() {
                var val = $(this).val();
                if (val && !val.startsWith('http')) {
                    $(this).val('https://' + val);
                }
            });

            // تنسيق رقم الهاتف
            $('#ContactPhone').on('input', function() {
                var value = $(this).val().replace(/\D/g, '');
                if (value.length > 0) {
                    if (!value.startsWith('964')) {
                        value = '+964' + value;
                    } else if (!value.startsWith('+')) {
                        value = '+' + value;
                    }
                }
                $(this).val(value);
            });

            // تنسيق رقم واتساب
            $('#WhatsAppNumber').on('input', function() {
                var value = $(this).val().replace(/\D/g, '');
                if (value.length > 0) {
                    if (!value.startsWith('964')) {
                        value = '+964' + value;
                    } else if (!value.startsWith('+')) {
                        value = '+' + value;
                    }
                }
                $(this).val(value);
            });
        });
    </script>
}