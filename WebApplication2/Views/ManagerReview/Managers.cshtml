@model IEnumerable<WebApplication2.Controllers.CentralManagedManagerVM>

@{
    Layout = "_Layout";
    ViewData["Title"] = "المسؤولين";

    var managers = Model?.ToList() ?? new List<WebApplication2.Controllers.CentralManagedManagerVM>();
    var totalManagers = managers.Count(x => x.AssignmentRole == "Manager");
    var totalAssistants = managers.Count(x => x.AssignmentRole == "Assistant");
    var currentSearch = ViewBag.Search as string ?? "";
}

<style>
    .central-managers-page {
        direction: rtl;
    }

    .page-shell {
        max-width: 1180px;
        margin: 0 auto;
    }

    .summary-card {
        border: 0;
        border-radius: 8px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.06);
    }

    .summary-value {
        font-size: 1.8rem;
        font-weight: 800;
        color: #1e3c72;
    }

    .table-card {
        border: 0;
        border-radius: 8px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .table thead th {
        background: #f8f9fa;
        color: #1e3c72;
        font-weight: 700;
        border-bottom: 2px solid #e9ecef;
        white-space: nowrap;
    }

    .manager-name {
        font-weight: 800;
        color: #1e3c72;
        display: block;
    }

    .manager-email {
        color: #6c757d;
        font-size: 0.82rem;
    }

    .scope-chip {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.55rem;
        border-radius: 999px;
        background: #e8f0fe;
        color: #1e3c72;
        font-weight: 700;
        font-size: 0.8rem;
    }
</style>

<div class="central-managers-page py-4">
    <div class="page-shell">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <h3 class="mb-1">
                    <i class="bi bi-person-badge me-2"></i>
                    المسؤولين
                </h3>
                <div class="text-muted">المسؤولون والمعاونون ضمن نفس نطاق تكليفك المركزي في المحافظات.</div>
            </div>
            <a class="btn btn-outline-secondary" asp-action="Users">
                <i class="bi bi-arrow-right"></i>
                المستخدمين التابعين لي
            </a>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card summary-card">
                    <div class="card-body">
                        <div class="text-muted small">إجمالي النتائج</div>
                        <div class="summary-value">@managers.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card summary-card">
                    <div class="card-body">
                        <div class="text-muted small">المسؤولين</div>
                        <div class="summary-value">@totalManagers</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card summary-card">
                    <div class="card-body">
                        <div class="text-muted small">المعاونين</div>
                        <div class="summary-value">@totalAssistants</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card summary-card mb-4">
            <div class="card-body">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-md-10">
                        <label class="form-label fw-bold">البحث</label>
                        <input type="text" name="search" value="@currentSearch" class="form-control" placeholder="ابحث بالاسم أو البريد أو الهاتف أو المحافظة أو النطاق">
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i>
                            بحث
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card table-card">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>المسؤول</th>
                            <th>الهاتف</th>
                            <th>الصفة</th>
                            <th>المستوى</th>
                            <th>النطاق</th>
                            <th>المحافظة</th>
                            <th>الحالة</th>
                            <th>تفاصيل</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!managers.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    لا توجد بيانات لعرضها
                                </td>
                            </tr>
                        }
                        else
                        {
                            var index = 1;
                            foreach (var manager in managers)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>
                                        <span class="manager-name">@manager.FullName</span>
                                        <span class="manager-email">@manager.Email</span>
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(manager.PhoneNumber) ? "---" : manager.PhoneNumber)</td>
                                    <td>
                                        <span class="badge @(manager.AssignmentRole == "Assistant" ? "bg-warning text-dark" : "bg-info")">
                                            @manager.AssignmentRoleArabic
                                        </span>
                                    </td>
                                    <td>@manager.ManagementLevelArabic</td>
                                    <td><span class="scope-chip">@(string.IsNullOrWhiteSpace(manager.ManagedUnitName) ? "---" : manager.ManagedUnitName)</span></td>
                                    <td>@manager.Governorate</td>
                                    <td>
                                        @if (manager.IsActive)
                                        {
                                            <span class="badge bg-success">مفعل</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">معطل</span>
                                        }
                                    </td>
                                    <td>
                                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@manager.UserId">
                                            عرض
                                        </a>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
