@model WebApplication2.Models.News

@{
    ViewData["Title"] = "حذف الخبر";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="bi bi-exclamation-triangle me-2"></i> تأكيد حذف الخبر
            </h4>
        </div>

        <div class="card-body">
            <!-- تحذير -->
            <div class="alert alert-danger mb-4">
                <div class="d-flex">
                    <i class="bi bi-exclamation-circle display-6 me-3"></i>
                    <div>
                        <h5 class="alert-heading">تحذير هام!</h5>
                        <p class="mb-0">
                            أنت على وشك حذف الخبر التالي. هذا الإجراء <strong>لا يمكن التراجع عنه</strong>.
                            سيتم حذف الخبر وكل البيانات المرتبطة به بما في ذلك الصورة.
                        </p>
                    </div>
                </div>
            </div>

            <!-- معلومات الخبر -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">معلومات الخبر المراد حذفه</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" class="img-fluid rounded" />
                            }
                            else
                            {
                                <div class="text-center py-4 bg-light rounded">
                                    <i class="bi bi-image text-muted display-6"></i>
                                    <p class="mt-2">لا توجد صورة</p>
                                </div>
                            }
                        </div>
                        <div class="col-md-9">
                            <h5 class="text-primary">@Model.Title</h5>
                            <p class="text-muted">
                                @(Model.Content.Length > 150 ? Model.Content.Substring(0, 150) + "..." : Model.Content)
                            </p>

                            <div class="row mt-3">
                                <div class="col-md-6">
                                    <p>
                                        <strong><i class="bi bi-calendar"></i> تاريخ الإنشاء:</strong><br />
                                        <span class="text-muted">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    <p>
                                        <strong><i class="bi bi-hash"></i> رقم الخبر:</strong><br />
                                        <span class="text-muted">#@Model.Id</span>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- نموذج الحذف -->
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex gap-2 justify-content-center">
                    <button type="submit" class="btn btn-danger btn-lg px-5">
                        <i class="bi bi-trash me-2"></i> نعم، احذف الخبر
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary btn-lg">
                        <i class="bi bi-arrow-left me-2"></i> لا، إلغاء والعودة
                    </a>
                </div>

                <div class="text-center mt-3">
                    <small class="text-muted">
                        <i class="bi bi-lightbulb"></i> يمكنك الضغط على "إلغاء" للرجوع أو "نعم، احذف" للتأكيد
                    </small>
                </div>
            </form>
        </div>
    </div>
</div>