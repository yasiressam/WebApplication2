@model WebApplication2.Models.Request.RequestDetailsViewModel
@using WebApplication2.Models.Request
@{
    Layout = "_Layout";

    var canRespond = ViewBag.CanRespond as bool? ?? false;
    var isSender = ViewBag.IsSender as bool? ?? false;
    var canSeeAll = ViewBag.CanSeeAll as bool? ?? false;
    var canSeeRecipients = ViewBag.CanSeeRecipients as bool? ?? false;
    var isStaffRequestUser = ViewBag.IsStaffRequestUser as bool? ?? false;
}

<style>
    .request-details {
        max-width: 900px;
        margin: 24px auto;
    }

    .details-panel {
        background: #fff;
        border: 1px solid #e6e8ee;
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .details-header {
        padding: 18px 22px;
        border-bottom: 1px solid #edf0f5;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .details-header h2 {
        margin: 0 0 8px;
        font-size: 1.35rem;
        font-weight: 800;
        color: #172033;
    }

    .details-meta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        color: #667085;
        font-size: 0.9rem;
    }

    .details-body {
        padding: 22px;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        background: #eef2f7;
        color: #344054;
        font-weight: 800;
        font-size: 0.9rem;
    }

    .simple-section {
        border: 1px solid #edf0f5;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .simple-section-title {
        font-weight: 800;
        color: #25324a;
        margin-bottom: 10px;
    }

    .request-content {
        line-height: 1.8;
        white-space: pre-line;
        color: #25324a;
    }

    .people-line {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        color: #475467;
    }

    .person-chip {
        background: #f7f8fb;
        border: 1px solid #e6e8ee;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 0.9rem;
    }

    .reply-item {
        border-top: 1px solid #edf0f5;
        padding-top: 14px;
        margin-top: 14px;
    }

    .reply-item:first-child {
        border-top: 0;
        padding-top: 0;
        margin-top: 0;
    }

    .reply-header {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 8px;
        color: #667085;
        font-size: 0.9rem;
    }

    .reply-name {
        color: #172033;
        font-weight: 800;
    }

    .reply-content {
        white-space: pre-line;
        line-height: 1.7;
        color: #25324a;
    }

    .details-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 18px;
    }
    .attachment-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #1d4ed8;
        font-weight: 800;
        text-decoration: none;
    }
</style>

<div class="container">
    <div class="request-details">
        <div class="details-panel">
            <div class="details-header">
                <div>
                    <h2>@Model.Title</h2>
                    <div class="details-meta">
                        <span><i class="bi bi-person"></i> @Model.SenderName</span>
                        <span><i class="bi bi-calendar"></i> @Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
                    </div>
                </div>
                <span class="status-pill">@Model.StatusName</span>
            </div>

            <div class="details-body">
                @if (canSeeRecipients && Model.Recipients.Any())
                {
                    <div class="simple-section">
                        <div class="simple-section-title">المستلمون</div>
                        <div class="people-line">
                            @foreach (var recipient in Model.Recipients)
                            {
                                <span class="person-chip">
                                    @recipient.Name
                                    @if (recipient.HasResponded)
                                    {
                                        <span class="text-success"> - رد</span>
                                    }
                                </span>
                            }
                        </div>
                    </div>
                }

                <div class="simple-section">
                    <div class="simple-section-title">الطلب</div>
                    <div class="request-content">@Model.Content</div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.AttachmentPath))
                {
                    <div class="simple-section">
                        <div class="simple-section-title">المرفق</div>
                        <a class="attachment-link" href="@Model.AttachmentPath" target="_blank" rel="noopener">
                            <i class="bi bi-paperclip"></i>
                            @(Model.AttachmentFileName ?? "تحميل الملف")
                        </a>
                        @if (Model.AttachmentSize.HasValue)
                        {
                            <span class="text-muted small ms-2">@((Model.AttachmentSize.Value / 1024.0).ToString("0.#")) KB</span>
                        }
                    </div>
                }

                <div class="simple-section">
                    <div class="simple-section-title">الردود</div>

                    @if (Model.Replies == null || !Model.Replies.Any())
                    {
                        <div class="text-muted">لا توجد ردود بعد.</div>
                    }
                    else
                    {
                        foreach (var reply in Model.Replies.OrderBy(r => r.RepliedAt))
                        {
                            <div class="reply-item">
                                <div class="reply-header">
                                    <span class="reply-name">@reply.UserName</span>
                                    <span>@reply.RepliedAtFormatted</span>
                                </div>
                                <div class="reply-content">@reply.ReplyContent</div>
                                @if (!string.IsNullOrWhiteSpace(reply.Notes))
                                {
                                    <div class="text-muted small mt-2">ملاحظة: @reply.Notes</div>
                                }
                            </div>
                        }
                    }
                </div>

                @if (isSender && !canRespond)
                {
                    <div class="alert alert-light border">
                        تم إرسال الطلب. ستصلك الردود هنا وعبر الإشعارات.
                    </div>
                }

                <div class="details-actions">
                    @if (canRespond)
                    {
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#respondModal">
                            <i class="bi bi-reply"></i> رد
                        </button>
                    }

                    @if (isStaffRequestUser)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">الرئيسية</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (canRespond)
{
    <div class="modal fade" id="respondModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">إضافة رد</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="Respond" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />

                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">الرد</label>
                            <textarea name="AdminResponse" class="form-control" rows="5" required placeholder="اكتب الرد هنا..."></textarea>
                        </div>

                        @if (isStaffRequestUser)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">الحالة</label>
                                <select name="NewStatus" class="form-select">
                                    <option value="1">قيد المراجعة</option>
                                    <option value="5">بانتظار رد المستخدم</option>
                                    <option value="4">تمت المعالجة</option>
                                    <option value="6">مغلق</option>
                                </select>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" name="NewStatus" value="1" />
                        }

                        <input type="hidden" name="Notes" value="" />
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">إلغاء</button>
                        <button type="submit" class="btn btn-primary">إرسال الرد</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
