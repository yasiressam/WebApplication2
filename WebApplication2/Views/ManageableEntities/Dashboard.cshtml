@{
   
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card custom-card">
                <div class="custom-card-header">
                    <h4 class="mb-0">
                        <i class="bi bi-grid-3x3-gap-fill me-2"></i>
                        لوحة التحكم - إدارة البيانات
                    </h4>
                    <p class="mb-0 mt-2 text-white-50">
                        اختر القسم الذي تريد إدارته من الأقسام التالية
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- صف البطاقات - كل بطاقة تؤدي لصفحة منفصلة -->
    <div class="row g-4">
        <!-- جهات الانتساب -->
        <div class="col-md-4">
            <div class="card custom-card h-100">
                <div class="custom-card-header">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-building fs-1 me-3"></i>
                        <div>
                            <h5 class="mb-1">جهات الانتساب</h5>
                            <span class="badge bg-light text-dark">@ViewBag.AffiliationEntitiesCount</span>
                        </div>
                    </div>
                </div>
                <div class="custom-card-body">
                    <p class="text-muted">إدارة جهات الانتساب - إضافة، تعديل، حذف</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="@Url.Action("AffiliationEntities")" class="custom-btn-primary">
                            <i class="bi bi-arrow-left me-1"></i> الذهاب للإدارة
                        </a>
                        <a href="@Url.Action("CreateAffiliationEntity")" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-plus-circle"></i> إضافة جديد
                        </a>
                    </div>
                </div>
                <div class="custom-card-footer">
                    <small>آخر تحديث: @DateTime.Now.ToString("yyyy/MM/dd")</small>
                </div>
            </div>
        </div>

        <!-- النقابات -->
        <div class="col-md-4">
            <div class="card custom-card h-100">
                <div class="custom-card-header" style="background: linear-gradient(135deg, #28a745, #20c997) !important;">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-people fs-1 me-3"></i>
                        <div>
                            <h5 class="mb-1">النقابات</h5>
                            <span class="badge bg-light text-dark">@ViewBag.UnionsCount</span>
                        </div>
                    </div>
                </div>
                <div class="custom-card-body">
                    <p class="text-muted">إدارة النقابات - إضافة، تعديل، حذف</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="@Url.Action("Unions")" class="custom-btn-primary">
                            <i class="bi bi-arrow-left me-1"></i> الذهاب للإدارة
                        </a>
                        <a href="@Url.Action("CreateUnion")" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-plus-circle"></i> إضافة جديد
                        </a>
                    </div>
                </div>
                <div class="custom-card-footer">
                    <small>آخر تحديث: @DateTime.Now.ToString("yyyy/MM/dd")</small>
                </div>
            </div>
        </div>

        <!-- الاتحادات -->
        <div class="col-md-4">
            <div class="card custom-card h-100">
                <div class="custom-card-header" style="background: linear-gradient(135deg, #17a2b8, #0dcaf0) !important;">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-diagram-3 fs-1 me-3"></i>
                        <div>
                            <h5 class="mb-1">الاتحادات</h5>
                            <span class="badge bg-light text-dark">@ViewBag.FederationsCount</span>
                        </div>
                    </div>
                </div>
                <div class="custom-card-body">
                    <p class="text-muted">إدارة الاتحادات - إضافة، تعديل، حذف</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="@Url.Action("Federations")" class="custom-btn-primary">
                            <i class="bi bi-arrow-left me-1"></i> الذهاب للإدارة
                        </a>
                        <a href="@Url.Action("CreateFederation")" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-plus-circle"></i> إضافة جديد
                        </a>
                    </div>
                </div>
                <div class="custom-card-footer">
                    <small>آخر تحديث: @DateTime.Now.ToString("yyyy/MM/dd")</small>
                </div>
            </div>
        </div>

        <!-- الجمعيات -->
        <div class="col-md-4">
            <div class="card custom-card h-100">
                <div class="custom-card-header" style="background: linear-gradient(135deg, #ffc107, #fd7e14) !important;">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-people-fill fs-1 me-3"></i>
                        <div>
                            <h5 class="mb-1">الجمعيات</h5>
                            <span class="badge bg-light text-dark">@ViewBag.AssociationsCount</span>
                        </div>
                    </div>
                </div>
                <div class="custom-card-body">
                    <p class="text-muted">إدارة الجمعيات - إضافة، تعديل، حذف</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="@Url.Action("Associations")" class="custom-btn-primary">
                            <i class="bi bi-arrow-left me-1"></i> الذهاب للإدارة
                        </a>
                        <a href="@Url.Action("CreateAssociation")" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-plus-circle"></i> إضافة جديد
                        </a>
                    </div>
                </div>
                <div class="custom-card-footer">
                    <small>آخر تحديث: @DateTime.Now.ToString("yyyy/MM/dd")</small>
                </div>
            </div>
        </div>

        <!-- الجمعيات غير الحكومية -->
        <div class="col-md-4">
            <div class="card custom-card h-100">
                <div class="custom-card-header" style="background: linear-gradient(135deg, #dc3545, #c82333) !important;">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-heart fs-1 me-3"></i>
                        <div>
                            <h5 class="mb-1">المنظمات غير الحكومية</h5>
                            <span class="badge bg-light text-dark">@ViewBag.NgosCount</span>
                        </div>
                    </div>
                </div>
                <div class="custom-card-body">
                    <p class="text-muted">إدارة المنظمات غير الحكومية - إضافة، تعديل، حذف</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="@Url.Action("Ngos")" class="custom-btn-primary">
                            <i class="bi bi-arrow-left me-1"></i> الذهاب للإدارة
                        </a>
                        <a href="@Url.Action("CreateNgo")" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-plus-circle"></i> إضافة جديد
                        </a>
                    </div>
                </div>
                <div class="custom-card-footer">
                    <small>آخر تحديث: @DateTime.Now.ToString("yyyy/MM/dd")</small>
                </div>
            </div>
        </div>

        

    <!-- إحصائيات سريعة -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card custom-card">
                <div class="custom-card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-bar-chart-fill me-2"></i>
                        إحصائيات سريعة
                    </h5>
                </div>
                <div class="custom-card-body">
                    <div class="row text-center">
                        <div class="col">
                            <div class="p-3">
                                <h3 class="text-primary mb-0">@ViewBag.AffiliationEntitiesCount</h3>
                                <small class="text-muted">جهات انتساب</small>
                            </div>
                        </div>
                        <div class="col">
                            <div class="p-3">
                                <h3 class="text-success mb-0">@ViewBag.UnionsCount</h3>
                                <small class="text-muted">نقابات</small>
                            </div>
                        </div>
                        <div class="col">
                            <div class="p-3">
                                <h3 class="text-info mb-0">@ViewBag.FederationsCount</h3>
                                <small class="text-muted">اتحادات</small>
                            </div>
                        </div>
                        <div class="col">
                            <div class="p-3">
                                <h3 class="text-warning mb-0">@ViewBag.AssociationsCount</h3>
                                <small class="text-muted">جمعيات</small>
                            </div>
                        </div>
                        <div class="col">
                            <div class="p-3">
                                <h3 class="text-danger mb-0">@ViewBag.NgosCount</h3>
                                <small class="text-muted">منظمات غير حكومية </small>
                            </div>
                        </div>
                        <div class="col">
                            <div class="p-3">
                                <h3 class="text-secondary mb-0">@(ViewBag.AffiliationEntitiesCount + ViewBag.UnionsCount + ViewBag.FederationsCount + ViewBag.AssociationsCount + ViewBag.NgosCount)</h3>
                                <small class="text-muted">المجموع الكلي</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-white-50 {
        color: rgba(255, 255, 255, 0.7) !important;
    }

    .custom-btn-primary {
        background: linear-gradient(135deg, #3498db, #2c3e50) !important;
        border: none !important;
        color: white !important;
        font-weight: 600 !important;
        padding: 0.5rem 1rem !important;
        border-radius: 8px !important;
        transition: all 0.3s !important;
        text-decoration: none !important;
        display: inline-block !important;
    }

        .custom-btn-primary:hover {
            transform: translateY(-2px) !important;
            box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3) !important;
            color: white !important;
        }

    .custom-card {
        border: none !important;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        border-radius: 15px !important;
        overflow: hidden !important;
        background: white !important;
    }

    .custom-card-header {
        background: linear-gradient(135deg, #3498db, #2c3e50) !important;
        color: white !important;
        padding: 1.2rem 1.5rem !important;
        border-bottom: none !important;
    }

    .custom-card-body {
        padding: 1.5rem !important;
        background: white !important;
    }

    .custom-card-footer {
        background: #f8f9fa !important;
        border-top: 1px solid rgba(52, 152, 219, 0.2) !important;
        padding: 1rem 1.5rem !important;
        color: #6c757d !important;
    }

    .badge {
        font-size: 0.9rem !important;
        padding: 0.4rem 0.8rem !important;
        border-radius: 20px !important;
    }
</style>