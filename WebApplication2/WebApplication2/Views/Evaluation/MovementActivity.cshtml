@model WebApplication2.Models.ViewModels.EvaluationFactorViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "تقييم النشاط الحركي";
}

<div class="container mt-3">
    <h3>🏃 تقييم: @Model.FactorDisplayName</h3>
    <hr />

    <div class="alert alert-info">
        الدرجة القصوى لهذا العامل: <strong>@Model.MaxScore</strong>
    </div>

    @if (!Model.Users.Any())
    {
        <div class="alert alert-warning">
            ⚠️ لا يوجد أفراد مصعدين لعرضهم.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>الاسم</th>
                        <th>رقم الهاتف</th>
                        <th>المحافظة</th>
                        <th>الدرجة</th>
                        <th>الإجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Users.Count; i++)
                    {
                        var user = Model.Users[i];
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@user.FullName</td>
                            <td>@user.PhoneNumber</td>
                            <td>@user.Governorate</td>
                            <td>
                                <input type="range" class="form-range"
                                       style="width: 150px; display: inline-block;"
                                       min="1" max="@user.MaxScore"
                                       value="@user.CurrentScore" />
                                <span>@user.CurrentScore</span> / @user.MaxScore
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-primary save-btn"
                                        data-user-id="@user.UserId">
                                    حفظ
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @await Html.PartialAsync("_EvaluationPagination", Model)
    }

    <div class="mt-3">
        <select id="monthSelect" class="form-select d-inline-block w-auto" style="width: 120px;">
            @for (int i = 1; i <= 12; i++)
            {
                <option value="@i" selected="@(Model.Month == i)">@(new DateTime(2024, i, 1).ToString("MMMM"))</option>
            }
        </select>
        <select id="yearSelect" class="form-select d-inline-block w-auto ms-2" style="width: 100px;">
            @for (int i = 2020; i <= DateTime.Now.Year + 1; i++)
            {
                <option value="@i" selected="@(Model.Year == i)">@i</option>
            }
        </select>
        <button id="filterBtn" class="btn btn-primary">عرض</button>
    </div>
</div>

<script>
    // فلتر
    document.getElementById('filterBtn').addEventListener('click', function() {
        var month = document.getElementById('monthSelect').value;
        var year = document.getElementById('yearSelect').value;
        window.location.href = '/Evaluation/MovementActivity?month=' + month + '&year=' + year;
    });

    // حفظ التقييم
    document.querySelectorAll('.save-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var userId = this.dataset.userId;
            var row = this.closest('tr');
            var slider = row.querySelector('input[type="range"]');
            var score = slider.value;
            var month = document.getElementById('monthSelect').value;
            var year = document.getElementById('yearSelect').value;
            var csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            fetch('/Evaluation/SaveMovementActivity', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': csrfToken
                },
                body: 'userId=' + userId + '&score=' + score + '&month=' + month + '&year=' + year
            }).then(function(response) {
                if (response.ok) {
                    alert('تم حفظ التقييم بنجاح');
                } else {
                    alert('حدث خطأ');
                }
            });
        });
    });
</script>
