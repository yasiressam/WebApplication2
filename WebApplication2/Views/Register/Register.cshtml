@model WebApplication2.Models.RegisterViewModel
@{
}

<style>
    .btn-primary-custom {
        background: linear-gradient(135deg, #3498db, #2c3e50) !important;
        border: none !important;
        color: white !important;
        font-weight: 600 !important;
        width: 100%;
        padding: 0.75rem;
        border-radius: 0.375rem;
        transition: opacity 0.15s ease-in-out;
    }

    .btn-primary-custom:hover {
        opacity: 0.9;
        background: linear-gradient(135deg, #3498db, #2c3e50) !important;
    }

    .btn-primary-custom:focus {
        box-shadow: 0 0 0 0.25rem rgba(52, 152, 219, 0.5) !important;
    }

    .btn-primary-custom:disabled {
        opacity: 0.65;
    }

    .custom-link {
        color: #3498db !important;
        text-decoration: none !important;
    }

    .custom-link:hover {
        color: #2c3e50 !important;
        text-decoration: underline !important;
    }

    .custom-title {
        color: #2c3e50 !important;
    }

    .card-header-custom {
        background: linear-gradient(135deg, #3498db, #2c3e50) !important;
        color: white !important;
        border-radius: 15px 15px 0 0 !important;
    }
</style>

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow p-4" style="max-width: 450px; width: 100%;">
        <div class="card-header text-center text-white card-header-custom">
            <h2>📝 @ViewData["Title"]</h2>
        </div>
        <div class="card-body">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger text-center mb-3">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
                </div>
            }

            <form id="registerForm" method="post" asp-action="Index">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-floating mb-3" id="emailField">
                    <input asp-for="Email" class="form-control" autocomplete="email" placeholder="name@example.com" />
                    <label asp-for="Email">البريد الإلكتروني</label>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" placeholder="********" />
                    <label asp-for="Password">كلمة المرور</label>
                    <span asp-validation-for="Password" class="text-danger"></span>
                    <small class="text-muted">يجب أن تحتوي على 6 أحرف على الأقل</small>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" placeholder="********" />
                    <label asp-for="ConfirmPassword">تأكيد كلمة المرور</label>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-primary-custom mb-3">
                    <i class="bi bi-person-plus me-2"></i> إنشاء حساب
                </button>

                <div class="text-center">
                    <p>
                        لديك حساب بالفعل؟
                        <a asp-area="Identity" asp-page="/Account/Login" class="custom-link">تسجيل الدخول</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('registerForm')?.addEventListener('submit', function() {
            var submitBtn = this.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i> جاري إنشاء الحساب...';
        });
    </script>
}
