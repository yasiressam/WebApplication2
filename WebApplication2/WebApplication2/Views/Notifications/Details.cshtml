@model WebApplication2.Models.Notification


<style>
    .notification-detail-card {
        border-radius: 15px;
        border: none;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .notification-detail-header {
        background: linear-gradient(135deg, #1e3c72, #2a5a9c);
        color: white;
        padding: 1.5rem;
    }

    .notification-detail-icon {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
    }

    .notification-meta {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 10px;
    }

    .notification-content {
        padding: 20px;
        font-size: 1.1rem;
        line-height: 1.8;
        background: white;
        border-radius: 10px;
        border: 1px solid #e9ecef;
    }
</style>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card notification-detail-card">
            <div class="notification-detail-header">
                <div class="d-flex align-items-center">
                    <div class="notification-detail-icon me-3">
                        <i class="bi @(Model.Icon ?? "bi-bell")"></i>
                    </div>
                    <div>
                        <h4 class="mb-1">@Model.Title</h4>
                        <small class="opacity-75">
                            <i class="bi bi-clock"></i> @GetRelativeTime(Model.SentAt)
                        </small>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="notification-meta mb-4">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted d-block">تاريخ الإرسال</small>
                            <strong>@Model.SentAt.ToString("yyyy/MM/dd HH:mm")</strong>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted d-block">الحالة</small>
                            @if (Model.IsRead)
                            {
                                <span class="badge bg-success">تمت القراءة @(Model.ReadAt.HasValue ? $"في {Model.ReadAt.Value.ToString("HH:mm")}" : "")</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">غير مقروء</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="notification-content mb-4">
                    @Model.Message
                </div>

                @if (!string.IsNullOrEmpty(Model.ClickUrl))
                {
                    <a href="@Model.ClickUrl" class="btn btn-primary">
                        <i class="bi bi-box-arrow-up-right"></i> الذهاب إلى الرابط
                    </a>
                }

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-right"></i> العودة إلى كل الإشعارات
                </a>
            </div>
        </div>
    </div>
</div>

@functions {
    private string GetRelativeTime(DateTime dateTime)
    {
        var timeSpan = DateTime.Now - dateTime;

        if (timeSpan.TotalSeconds < 60)
            return "الآن";
        if (timeSpan.TotalMinutes < 60)
            return $"منذ {Math.Max(1, (int)timeSpan.TotalMinutes)} دقيقة";
        if (timeSpan.TotalHours < 24)
            return $"منذ {Math.Max(1, (int)timeSpan.TotalHours)} ساعة";
        if (timeSpan.TotalDays < 30)
            return $"منذ {Math.Max(1, (int)timeSpan.TotalDays)} يوم";
        if (timeSpan.TotalDays < 365)
            return $"منذ {Math.Max(1, (int)(timeSpan.TotalDays / 30))} شهر";

        return dateTime.ToString("yyyy/MM/dd");
    }
}