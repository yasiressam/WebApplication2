        function loadMapFromFile() {
            $.ajax({
                url: '/images/iraq-map.svg',
                type: 'GET',
                dataType: 'text',
                success: function(data) {
                    try {
                        var parser = new DOMParser();
                        var svgDoc = parser.parseFromString(data, 'image/svg+xml');
                        var svgElement = svgDoc.querySelector('svg');
                        if (svgElement) {
                            var svgContent = svgElement.innerHTML;
                            $('#iraq-map').html(svgContent);
                            setTimeout(function() {
                                $('#iraq-map .lbl').css({ 'font-size': '18px', 'font-weight': 'bold' });
                            }, 100);
                            initializeMap();
                            updateMapCounts();
                            
                            var mapContainer = document.getElementById('map-container');
                            if (mapContainer) {
                                mapContainer.style.height = '550px';
                                mapContainer.style.maxHeight = '550px';
                                mapContainer.style.overflow = 'auto';
                            }
                        }
                    } catch (e) {
                        console.error('❌ خطأ في معالجة SVG:', e);
                    }
                },
                error: function() {
                    Swal.fire('خطأ', 'فشل تحميل الخريطة', 'error');
                }
            });
        }

        function updateMapCounts() {
            try {
                if (!governoratesData || governoratesData.length === 0) return;
                
                setTimeout(function() {
                    var govMap = {};
                    governoratesData.forEach(gov => { 
                        govMap[gov.name] = gov.individualCount || 0; 
                    });

                    var baghdadAggregate = 0;
                    ['بغداد', 'بغداد عامة', 'بغداد - الكرخ', 'بغداد - الرصافة'].forEach(function(name) {
                        baghdadAggregate += govMap[name] || 0;
                    });

                    if (baghdadAggregate > 0) {
                        govMap['بغداد'] = baghdadAggregate;
                    }
                    
                    $('.cnt').each(function() {
                        var cntElement = $(this);
                        var lblElement = cntElement.prevAll('.lbl').first();
                        var govName = lblElement.text().trim();
                        
                        if (govName && govMap[govName] !== undefined) {
                            cntElement.text(govMap[govName]);
                        }
                    });
                    
                    $('#iraq-map .cnt').css({ 
                        'font-size': '20px', 
                        'font-weight': 'bold', 
                        'fill': '#e74c3c', 
                        'stroke': 'white', 
                        'stroke-width': '1px', 
                        'paint-order': 'stroke' 
                    });
                    
                    console.log('✅ تم تحديث أرقام المحافظات:', govMap);
                }, 1000);
            } catch (e) { 
                console.error('❌ خطأ في تحديث الأرقام:', e); 
            }
        }

        function initializeMap() {
            try {
                document.querySelectorAll('.prov').forEach(path => {
                    path.removeEventListener('click', path._clickHandler);
                    
                    const clickHandler = function(e) {
                        e.stopPropagation();
                        selectGovernorate(parseInt(this.getAttribute('data-id')), this.getAttribute('data-name'));
                    };
                    
                    path._clickHandler = clickHandler;
                    path.addEventListener('click', clickHandler);
                    
                    path.addEventListener('mouseenter', function() { 
                        if (currentSelectedId != this.getAttribute('data-id')) 
                            this.style.fill = '#7bb9ff'; 
                    });
                    path.addEventListener('mouseleave', function() { 
                        if (currentSelectedId != this.getAttribute('data-id')) 
                            this.style.fill = '#a8d1ff'; 
                    });
                });
            } catch (e) { console.error('❌ خطأ:', e); }
        }

        function initializeProvincesGrid() {
            try {
                $('#provincesGrid').empty();
                var sortedGovernorates = [...governoratesData].sort((a, b) => (b.individualCount || 0) - (a.individualCount || 0));
                
                sortedGovernorates.forEach(gov => {
                    $('#provincesGrid').append($('<button class="province-horiz-btn">')
                        .attr('data-id', gov.id)
                        .attr('data-name', gov.name)
                        .html('<span class="horiz-name">' + gov.name + '</span><span class="horiz-count">' + (gov.individualCount || 0) + '</span>'));
                });
                $('.province-horiz-btn').off('click').on('click', function() { selectGovernorate($(this).data('id'), $(this).data('name')); });
            } catch (e) { console.error('❌ خطأ:', e); }
        }

        function updateActiveButtons(selectedId, selectedName) {
            $('.province-horiz-btn').removeClass('active');
            if (selectedName) {
                $('.province-horiz-btn').filter(function() {
                    return $(this).data('name') === selectedName;
                }).addClass('active');
            } else if (selectedId) {
                $(`.province-horiz-btn[data-id="${selectedId}"]`).addClass('active');
            }

            $('.prov').removeClass('prov-sel');
            if (selectedId && selectedId < 1000) $(`.prov[data-id="${selectedId}"]`).addClass('prov-sel');
        }

        function selectGovernorate(id, name) {
            currentSelectedId = id;
            updateActiveButtons(id, name);
            if (id) {
                var govData = governoratesData.find(g => g.name == name) || governoratesData.find(g => g.id == id);
                govData ? showReportPanel(govData) : fetchGovernorateData(id, name);
            } else { $('#reportPanel').hide(); }
