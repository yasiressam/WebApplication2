                const result = await Swal.fire({
                    title: 'تأكيد التصدير',
                    text: 'هل أنت متأكد من تحميل ملف Excel لهذه الإحصائية؟',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'نعم، تحميل',
                    cancelButtonText: 'إلغاء',
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d'
                });

                if (!result.isConfirmed) {
                    return;
                }

                const params = new URLSearchParams();
                params.set('cardType', cardType || '');
                if (value) params.set('value', value);
                window.location.href = '/MapDashboard/ExportCardUsersToExcel?' + params.toString();
            } catch (e) {
                Swal.fire('خطأ', 'حدث خطأ في بدء التصدير: ' + e.message, 'error');
            }
        }

        // ===== إحصائيات المؤهل العلمي (أعداد فقط) =====
        function loadEducationStatistics() {
            $.ajax({
                url: '/MapDashboard/GetEducationStatistics',
                type: 'GET',
                success: function(response) {
                    if (response && response.success) {
                        var educationStats = response.data;
                        var eduGrid = $('#educationStatsGrid');
                        eduGrid.empty();
                        
                        // إضافة بطاقات المؤهلات
                        educationStats.forEach(function(edu) {
                            eduGrid.append(`
                                <div class="stat-card exportable-card" onclick="exportCardToExcel('education', '${escapeJsValue(edu.educationName)}')">
                                    <div class="stat-icon" style="background: linear-gradient(135deg, ${edu.color}, ${edu.color});">
                                        <i class="${edu.icon}"></i>
                                    </div>
                                    <h3>${edu.count.toLocaleString()}</h3>
                                    <p>${edu.educationName}</p>
                                    <small>مؤهل علمي</small>
                                </div>
                            `);
                        });
                    }
                },
                error: function() {
                    console.log('خطأ في تحميل إحصائيات المؤهل العلمي');
                }
            });
        }

        function escapeJsValue(value) {
            return String(value || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/\r?\n/g, ' ');
        }
