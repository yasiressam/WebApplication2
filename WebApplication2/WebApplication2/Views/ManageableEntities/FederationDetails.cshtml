@model WebApplication2.Models.Federation
@{
    ViewData["Title"] = $"الاتحاد: {Model.Name}";
    var divisions = ViewBag.Divisions as IEnumerable<WebApplication2.Models.FederationDivision>;
}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <!-- معلومات الاتحاد -->
            <div class="card shadow-sm mb-4 border-info">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-diagram-3"></i> @Model.Name
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>تاريخ الإضافة:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd")</p>
                            <p><strong>عدد الأقسام:</strong> <span class="badge bg-info">@(divisions?.Count() ?? 0)</span></p>
                            <p><strong>تمت الإضافة بواسطة:</strong> @(Model.CreatedBy ?? "---")</p>
                        </div>
                        <div class="col-md-6 text-start">
                            <a href="@Url.Action("Federations")" class="btn btn-secondary">
                                <i class="bi bi-arrow-right"></i> عودة للاتحادات
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- الجدول الرئيسي -->
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-table"></i> الهيكل التنظيمي (قسم ← شعبة ← وحدة)
                    </h5>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <div class="table-responsive">
                        <table class="table table-hover table-bordered align-middle" id="hierarchyTable">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 5%">#</th>
                                    <th style="width: 31%">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span><i class="bi bi-folder2-open"></i> القسم</span>
                                            <button class="btn btn-sm btn-success" onclick="showAddDivisionModal()">
                                                <i class="bi bi-plus-circle"></i> إضافة
                                            </button>
                                        </div>
                                    </th>
                                    <th style="width: 32%">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span><i class="bi bi-layers"></i> الشعبة</span>
                                            <button class="btn btn-sm btn-info" onclick="showAddSectionWithSelection()">
                                                <i class="bi bi-plus-circle"></i> إضافة
                                            </button>
                                        </div>
                                    </th>
                                    <th style="width: 32%">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span><i class="bi bi-tag-fill"></i> الوحدة</span>
                                            <button class="btn btn-sm btn-warning" onclick="showAddGroupWithSelection()">
                                                <i class="bi bi-plus-circle"></i> إضافة
                                            </button>
                                        </div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="hierarchyTableBody">
                                @if (divisions != null && divisions.Any())
                                {
                                    int i = 1;
                                    foreach (var division in divisions)
                                    {
                                        var sections = division.Sections?.ToList() ?? new List<FederationSection>();
                                        if (sections.Any())
                                        {
                                            foreach (var sec in sections)
                                            {
                                                var groups = sec.Groups?.ToList() ?? new List<FederationGroup>();
                                                if (groups.Any())
                                                {
                                                    foreach (var grp in groups)
                                                    {
                                                        <tr data-division-id="@division.Id" data-division-name="@division.Name"
                                                            data-section-id="@sec.Id" data-section-name="@sec.Name"
                                                            data-group-id="@grp.Id" data-group-name="@grp.Name">
                                                            <td class="text-center">@(i++)</td>
                                                            <td>
                                                                <div class="d-flex justify-content-between align-items-center">
                                                                    <span class="fw-bold text-success">
                                                                        <i class="bi bi-folder2-open"></i> @division.Name
                                                                    </span>
                                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteDivision(@division.Id, '@division.Name')">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                            <td>
                                                                <div class="d-flex justify-content-between align-items-center">
                                                                    <span class="text-info">
                                                                        <i class="bi bi-layers"></i> @sec.Name
                                                                    </span>
                                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteSection(@sec.Id, '@sec.Name')">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                            <td>
                                                                <div class="d-flex justify-content-between align-items-center">
                                                                    <span class="text-warning">
                                                                        <i class="bi bi-tag-fill"></i> @grp.Name
                                                                    </span>
                                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteGroup(@grp.Id, '@grp.Name')">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                                else
                                                {
                                                    <tr data-division-id="@division.Id" data-division-name="@division.Name"
                                                        data-section-id="@sec.Id" data-section-name="@sec.Name">
                                                        <td class="text-center">@(i++)</td>
                                                        <td>
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <span class="fw-bold text-success">
                                                                    <i class="bi bi-folder2-open"></i> @division.Name
                                                                </span>
                                                                <button class="btn btn-sm btn-outline-danger" onclick="deleteDivision(@division.Id, '@division.Name')">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <span class="text-info">
                                                                    <i class="bi bi-layers"></i> @sec.Name
                                                                </span>
                                                                <button class="btn btn-sm btn-outline-danger" onclick="deleteSection(@sec.Id, '@sec.Name')">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </div>
                                                            <button class="btn btn-sm btn-outline-warning mt-1 w-100" onclick="showAddGroupModal(@sec.Id, '@sec.Name')">
                                                                <i class="bi bi-plus-circle"></i> إضافة وحدة
                                                            </button>
                                                        </td>
                                                        <td class="text-muted text-center">
                                                            <i class="bi bi-dash-circle"></i> لا توجد وحدات
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        }
                                        else
                                        {
                                            <tr data-division-id="@division.Id" data-division-name="@division.Name">
                                                <td class="text-center">@(i++)</td>
                                                <td>
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span class="fw-bold text-success">
                                                            <i class="bi bi-folder2-open"></i> @division.Name
                                                        </span>
                                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteDivision(@division.Id, '@division.Name')">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </div>
                                                    <button class="btn btn-sm btn-outline-info mt-1 w-100" onclick="showAddSectionModal(@division.Id, '@division.Name')">
                                                        <i class="bi bi-plus-circle"></i> إضافة شعبة
                                                    </button>
                                                </td>
                                                <td class="text-muted text-center">
                                                    <i class="bi bi-dash-circle"></i> لا توجد شعب
                                                </td>
                                                <td class="text-muted text-center">
                                                    <i class="bi bi-dash-circle"></i> لا توجد وحدات
                                                </td>
                                            </tr>
                                        }
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-5">
                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                            لا توجد أقسام
                                            <div class="mt-2">
                                                <button class="btn btn-sm btn-success" onclick="showAddDivisionModal()">
                                                    <i class="bi bi-plus-circle"></i> أضف أول قسم
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- مودال إضافة قسم -->
<div class="modal fade" id="addDivisionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-folder2-open"></i> إضافة قسم جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="newDivisionName" class="form-control" placeholder="أدخل اسم القسم" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-success" onclick="addDivision()">إضافة</button>
            </div>
        </div>
    </div>
</div>

<!-- مودال إضافة شعبة (مع اختيار القسم) -->
<div class="modal fade" id="addSectionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="bi bi-layers"></i> إضافة شعبة جديدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">اختر القسم</label>
                    <select id="selectDivision" class="form-select">
                        <option value="">-- اختر القسم --</option>
                        @if (divisions != null)
                        {
                            foreach (var division in divisions)
                            {
                                <option value="@division.Id">@division.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">اسم الشعبة</label>
                    <input type="text" id="newSectionName" class="form-control" placeholder="أدخل اسم الشعبة" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-info" onclick="addSectionWithSelection()">إضافة</button>
            </div>
        </div>
    </div>
</div>

<!-- مودال إضافة وحدة (مع اختيار الشعبة) -->
<div class="modal fade" id="addGroupModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title"><i class="bi bi-tag-fill"></i> إضافة وحدة جديدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">اختر الشعبة</label>
                    <select id="selectSection" class="form-select">
                        <option value="">-- اختر الشعبة --</option>
                        @if (divisions != null)
                        {
                            foreach (var division in divisions)
                            {
                                var sections = division.Sections?.ToList() ?? new List<FederationSection>();
                                foreach (var sec in sections)
                                {
                                    <option value="@sec.Id">@division.Name - @sec.Name</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">اسم الوحدة</label>
                    <input type="text" id="newGroupName" class="form-control" placeholder="أدخل اسم الوحدة" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-warning" onclick="addGroupWithSelection()">إضافة</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let token = $('input[name="__RequestVerificationToken"]').val();
        if (!token) token = $('form input[name="__RequestVerificationToken"]').val();
        let federationId = @Model.Id;

        function refreshTable() { location.reload(); }

        // ========== إضافة قسم ==========
        function showAddDivisionModal() {
            $('#newDivisionName').val('');
            $('#addDivisionModal').modal('show');
        }

        function addDivision() {
            let name = $('#newDivisionName').val().trim();
            if (!name) { alert('الرجاء إدخال اسم القسم'); return; }
            $.ajax({
                url: '@Url.Action("AddFederationDivisionAjax", "ManageableEntities")',
                type: 'POST',
                data: { name: name, federationId: federationId },
                headers: { 'RequestVerificationToken': token },
                success: function(response) {
                    if (response.success) {
                        $('#addDivisionModal').modal('hide');
                        refreshTable();
                    } else { alert(response.message); }
                },
                error: function() { alert('حدث خطأ في إضافة القسم'); }
            });
        }

        // ========== حذف قسم ==========
        function deleteDivision(id, name) {
            if (confirm(`⚠️ هل أنت متأكد من حذف القسم "${name}"؟\n\nملاحظة: سيتم حذف جميع الشعب والوحدات المرتبطة به.`)) {
                $.ajax({
                    url: '@Url.Action("DeleteFederationDivision", "ManageableEntities")',
                    type: 'POST',
                    data: { id: id },
                    headers: { 'RequestVerificationToken': token },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            refreshTable();
                        } else { alert("❌ " + response.message); }
                    },
                    error: function() { alert("❌ حدث خطأ"); }
                });
            }
        }

        // ========== إضافة شعبة ==========
        function showAddSectionWithSelection() {
            $('#selectDivision').val('');
            $('#newSectionName').val('');
            $('#addSectionModal').modal('show');
        }

        function showAddSectionModal(divisionId, divisionName) {
            $('#selectDivision').val(divisionId);
            $('#newSectionName').val('');
            $('#addSectionModal').modal('show');
        }

        function addSectionWithSelection() {
            let divisionId = $('#selectDivision').val();
            let name = $('#newSectionName').val().trim();
            if (!divisionId) { alert('الرجاء اختيار القسم'); return; }
            if (!name) { alert('الرجاء إدخال اسم الشعبة'); return; }
            $.ajax({
                url: '@Url.Action("AddFederationSectionAjax", "ManageableEntities")',
                type: 'POST',
                data: { name: name, divisionId: divisionId },
                headers: { 'RequestVerificationToken': token },
                success: function(response) {
                    if (response.success) {
                        $('#addSectionModal').modal('hide');
                        refreshTable();
                    } else { alert(response.message); }
                },
                error: function() { alert('حدث خطأ في إضافة الشعبة'); }
            });
        }

        // ========== حذف شعبة ==========
        function deleteSection(id, name) {
            if (confirm(`⚠️ هل أنت متأكد من حذف الشعبة "${name}"؟\n\nملاحظة: سيتم حذف جميع الوحدات المرتبطة بها.`)) {
                $.ajax({
                    url: '@Url.Action("DeleteFederationSection", "ManageableEntities")',
                    type: 'POST',
                    data: { id: id },
                    headers: { 'RequestVerificationToken': token },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            refreshTable();
                        } else { alert("❌ " + response.message); }
                    },
                    error: function() { alert("❌ حدث خطأ"); }
                });
            }
        }

        // ========== إضافة تجمع ==========
        function showAddGroupWithSelection() {
            $('#selectSection').val('');
            $('#newGroupName').val('');
            $('#addGroupModal').modal('show');
        }

        function showAddGroupModal(sectionId, sectionName) {
            $('#selectSection').val(sectionId);
            $('#newGroupName').val('');
            $('#addGroupModal').modal('show');
        }

        function addGroupWithSelection() {
            let sectionId = $('#selectSection').val();
            let name = $('#newGroupName').val().trim();
            if (!sectionId) { alert('الرجاء اختيار الشعبة'); return; }
            if (!name) { alert('الرجاء إدخال اسم الوحدة'); return; }
            $.ajax({
                url: '@Url.Action("AddFederationGroupAjax", "ManageableEntities")',
                type: 'POST',
                data: { name: name, sectionId: sectionId },
                headers: { 'RequestVerificationToken': token },
                success: function(response) {
                    if (response.success) {
                        $('#addGroupModal').modal('hide');
                        refreshTable();
                    } else { alert(response.message); }
                },
                error: function() { alert('حدث خطأ في إضافة الوحدة'); }
            });
        }

        // ========== حذف تجمع ==========
        function deleteGroup(id, name) {
            if (confirm(`⚠️ هل أنت متأكد من حذف الوحدة "${name}"؟`)) {
                $.ajax({
                    url: '@Url.Action("DeleteFederationGroup", "ManageableEntities")',
                    type: 'POST',
                    data: { id: id },
                    headers: { 'RequestVerificationToken': token },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            refreshTable();
                        } else { alert("❌ " + response.message); }
                    },
                    error: function() { alert("❌ حدث خطأ"); }
                });
            }
        }
    </script>
}
