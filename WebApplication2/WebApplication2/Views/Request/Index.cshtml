@model IEnumerable<WebApplication2.Models.Request.RequestListItemViewModel>
@using WebApplication2.Models.Request
@{
    Layout = "_Layout";
    var isStaffRequestUser = ViewBag.IsStaffRequestUser as bool? ?? false;
    var currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    var totalRequests = ViewBag.TotalRequests is int tr ? tr : Model.Count();
}

<style>
    .requests-page {
        max-width: 980px;
        margin: 24px auto;
    }

    .requests-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .requests-filter {
        background: #fff;
        border: 1px solid #e6e8ee;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 14px;
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.04);
    }

    .requests-filter .form-control {
        border-radius: 8px;
        border-color: #d8dde8;
        padding: 11px 13px;
    }

    .requests-header h2 {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 800;
        color: #172033;
    }

    .request-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 14px;
        align-items: center;
        background: #fff;
        border: 1px solid #e6e8ee;
        border-radius: 8px;
        padding: 15px 16px;
        margin-bottom: 10px;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .request-row:hover {
        border-color: #2a5a9c;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
        color: inherit;
    }

    .request-title {
        font-weight: 800;
        color: #172033;
        margin-bottom: 6px;
    }

    .request-meta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        color: #667085;
        font-size: 0.9rem;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 110px;
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 0.85rem;
        background: #eef2f7;
        color: #344054;
    }

    .unread-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #dc3545;
        display: inline-block;
        margin-inline-start: 6px;
    }

    .empty-state {
        background: #fff;
        border: 1px dashed #cfd6e4;
        border-radius: 8px;
        padding: 40px 20px;
        text-align: center;
        color: #667085;
    }

    .no-filter-results {
        display: none;
        background: #fff;
        border: 1px dashed #cfd6e4;
        border-radius: 8px;
        padding: 24px 16px;
        text-align: center;
        color: #667085;
    }

    @@media (max-width: 640px) {
        .request-row {
            grid-template-columns: 1fr;
        }

        .status-pill {
            width: fit-content;
        }
    }
</style>

<div class="container">
    <div class="requests-page">
        <div class="requests-header">
            <div>
                <h2><i class="bi bi-inbox"></i> الطلبات</h2>
                <div class="text-muted small">كل طلباتك في مكان واحد.</div>
            </div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> طلب جديد
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                لا توجد طلبات حالياً.
                <div class="mt-3">
                    <a asp-action="Create" class="btn btn-primary">إنشاء طلب</a>
                </div>
            </div>
        }
        else
        {
            <div class="requests-filter">
                <input id="requestSearch" class="form-control" type="search" placeholder="ابحث في الطلبات بالعنوان، الاسم، أو الحالة..." autocomplete="off" />
            </div>
            <div class="no-filter-results" id="requestNoResults">
                لا توجد طلبات مطابقة للبحث.
            </div>

            foreach (var request in Model)
            {
                <a class="request-row"
                   asp-action="Details"
                   asp-route-id="@request.Id"
                   data-search="@($"{request.Title} {request.SenderName} {request.RecipientsNames} {request.StatusName} {request.CreatedAtFormatted}".ToLowerInvariant())">
                    <div>
                        <div class="request-title">
                            @request.Title
                            @if (!request.IsRead)
                            {
                                <span class="unread-dot" title="غير مقروء"></span>
                            }
                        </div>
                        <div class="request-meta">
                            <span><i class="bi bi-person"></i> من: @request.SenderName</span>
                            @if (isStaffRequestUser)
                            {
                                <span><i class="bi bi-people"></i> إلى: @request.RecipientsNames</span>
                            }
                            <span><i class="bi bi-calendar"></i> @request.CreatedAtFormatted</span>
                        </div>
                    </div>
                    <span class="status-pill">@request.StatusName</span>
                </a>
            }

            if (totalPages > 1)
            {
                <div class="d-flex flex-column align-items-center mt-3">
                    <div class="text-muted small mb-2">
                        عرض @Model.Count() من أصل @totalRequests طلب
                    </div>
                    <nav aria-label="تنقل صفحات الطلبات">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" aria-label="السابق">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>

                            @for (var i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                                </li>
                            }

                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" aria-label="التالي">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('requestSearch');
            const rows = Array.from(document.querySelectorAll('.request-row'));
            const noResults = document.getElementById('requestNoResults');

            if (!searchInput) return;

            function filterRequests() {
                const term = searchInput.value.trim().toLowerCase();
                let visibleCount = 0;

                rows.forEach(row => {
                    const match = !term || row.dataset.search.includes(term);
                    row.style.display = match ? '' : 'none';
                    if (match) visibleCount++;
                });

                noResults.style.display = visibleCount === 0 ? 'block' : 'none';
            }

            searchInput.addEventListener('input', filterRequests);
            filterRequests();
        });
    </script>
}
