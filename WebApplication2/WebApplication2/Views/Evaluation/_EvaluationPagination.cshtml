@model WebApplication2.Models.ViewModels.EvaluationFactorViewModel

@if (Model.TotalPages > 1)
{
    <div class="d-flex flex-column align-items-center mt-3">
        <div class="text-muted small mb-2">
            عرض @Model.Users.Count من أصل @Model.TotalUsers فرد
        </div>
        <nav aria-label="تنقل صفحات التقييم">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="@Model.FactorName"
                       asp-route-month="@Model.Month"
                       asp-route-year="@Model.Year"
                       asp-route-page="@(Model.CurrentPage - 1)">السابق</a>
                </li>

                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="@Model.FactorName"
                           asp-route-month="@Model.Month"
                           asp-route-year="@Model.Year"
                           asp-route-page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="@Model.FactorName"
                       asp-route-month="@Model.Month"
                       asp-route-year="@Model.Year"
                       asp-route-page="@(Model.CurrentPage + 1)">التالي</a>
                </li>
            </ul>
        </nav>
    </div>
}
