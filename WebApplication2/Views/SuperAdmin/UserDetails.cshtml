@model WebApplication2.Models.SuperAdminUserDetailsVM
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@functions {
    private string DisplayRoleName(string role)
    {
        return role?.Trim() switch
        {
            "SuperAdmin" => "السوبر أدمن",
            "Admin" => "المسؤول",
            "DistrictAdmin" => "مدير محافظة",
            "Manager" => "المسؤول",
            "AssistantManager" => "المعاون",
            "MapViewer" => "مشاهد الخريطة",
            "NewsEditor" => "محرر الأخبار",
            "User" => "مستخدم",
            "Member" => "عضو",
            "فرد" => "فرد",
            "" or null => "---",
            _ => role.Trim()
        };
    }

    private string DisplayRolesArabic(string? roles)
    {
        if (string.IsNullOrWhiteSpace(roles))
            return "---";

        return string.Join("، ", roles
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(DisplayRoleName)
            .Where(role => !string.IsNullOrWhiteSpace(role) && role != "---")
            .Distinct());
    }

    private string DisplayCleanValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "---";

        var trimmed = value.Trim();
        return trimmed == "-- اختر الدرجة الوظيفية --" || trimmed == "اختر الدرجة الوظيفية"
            ? "---"
            : trimmed;
    }

    private bool HasUniversityDetails()
    {
        return string.Equals(Model?.Education?.Trim(), "طالب جامعي", StringComparison.OrdinalIgnoreCase)
            || !string.IsNullOrWhiteSpace(Model?.UniversityType)
            || !string.IsNullOrWhiteSpace(Model?.InstitutionType)
            || !string.IsNullOrWhiteSpace(Model?.InstitutionName)
            || !string.IsNullOrWhiteSpace(Model?.FacultyDepartment)
            || !string.IsNullOrWhiteSpace(Model?.StudyType)
            || !string.IsNullOrWhiteSpace(Model?.StudyStage);
    }
}

