@model WebApplication2.Models.Request.RequestCreateViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    Layout = "_Layout";

    var targetUsers = ViewBag.TargetUsers as List<WebApplication2.Models.Request.RequestRecipientOptionViewModel> ?? new();
    var requestTitles = ViewBag.RequestTitles as List<SelectListItem> ?? new();
}

<style>
    .request-shell {
        max-width: 860px;
        margin: 24px auto;
    }

    .request-panel {
        background: #fff;
        border: 1px solid #e5e7ef;
        border-radius: 8px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.07);
        overflow: hidden;
    }

    .request-panel-header {
        padding: 18px 22px;
        border-bottom: 1px solid #edf0f5;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        background: #fbfcff;
    }

    .request-panel-header h3 {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 800;
        color: #172033;
    }

    .request-panel-body {
        padding: 22px;
    }

    .form-label {
        font-weight: 800;
        color: #25324a;
        margin-bottom: 8px;
    }

    .form-control,
    .form-select {
        border-radius: 8px !important;
        border: 1px solid #d8dde8 !important;
        padding: 11px 13px !important;
    }

    textarea.form-control {
        min-height: 160px;
    }

    .recipient-category-tabs {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
        margin-bottom: 12px;
    }

    .recipient-category-btn {
        border: 1px solid #d8dde8;
        background: #fff;
        color: #344054;
        border-radius: 8px;
        padding: 9px 10px;
        font-weight: 800;
    }

    .recipient-category-btn.active {
        background: #2a5a9c;
        border-color: #2a5a9c;
        color: #fff;
    }

    .recipient-tools {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 10px;
        align-items: center;
        margin-bottom: 12px;
    }

    .selected-count {
        color: #2a5a9c;
        background: #eef5ff;
        border: 1px solid #d7e7ff;
        border-radius: 999px;
        padding: 7px 12px;
        font-weight: 800;
        white-space: nowrap;
    }

    .recipient-list {
        border: 1px solid #e1e6f0;
        border-radius: 8px;
        overflow: hidden;
        max-height: 320px;
        overflow-y: auto;
        background: #fff;
    }

    .recipient-item {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        border-bottom: 1px solid #eef1f6;
        cursor: pointer;
    }

    .recipient-item:last-child {
        border-bottom: 0;
    }

    .recipient-item:hover,
    .recipient-item:has(input:checked) {
        background: #eef5ff;
    }

    .recipient-check {
        width: 18px;
        height: 18px;
        accent-color: #2a5a9c;
    }

    .recipient-name {
        font-weight: 800;
        color: #172033;
        line-height: 1.4;
    }

    .role-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 86px;
        padding: 5px 9px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 800;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .role-superadmin {
        background: #fde7ea;
        color: #9f1239;
        border-color: #f8b8c1;
    }

    .role-admin {
        background: #fff4d6;
        color: #92400e;
        border-color: #f5d48b;
    }

    .role-manager {
        background: #e7f7ef;
        color: #087443;
        border-color: #b9e7cf;
    }

    .role-member {
        background: #edf2f7;
        color: #344054;
        border-color: #d7dde7;
    }

    .hint-line,
    .recipient-empty-state {
        color: #667085;
        font-size: 0.9rem;
        margin-top: 8px;
    }

    .recipient-empty-state {
        border: 1px dashed #d8dde8;
        border-radius: 8px;
        padding: 16px;
        text-align: center;
        margin: 0 0 12px;
        background: #fbfcff;
    }

    .request-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
        margin-top: 22px;
    }

    .no-results {
        display: none;
        padding: 18px;
        color: #667085;
        text-align: center;
    }

    @@media (max-width: 640px) {
        .recipient-category-tabs,
        .recipient-tools,
        .recipient-item {
            grid-template-columns: 1fr;
        }

        .role-pill,
        .selected-count {
            width: fit-content;
        }
    }
</style>

<div class="container">
    <div class="request-shell">
        <div class="request-panel">
            <div class="request-panel-header">
                <h3><i class="bi bi-send"></i> طلب جديد</h3>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-right"></i> رجوع
                </a>
            </div>

            <div class="request-panel-body">
                @if (!targetUsers.Any())
                {
                    <div class="alert alert-warning mb-0">
                        لا يوجد مستلمون متاحون لك حالياً حسب دورك ومحافظتك.
                    </div>
                }
                else
                {
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Type" value="0" />
                        <input type="hidden" name="Priority" value="0" />

                        <div class="mb-4">
                            <label asp-for="RecipientIds" class="form-label">إلى من؟</label>

                            <div class="recipient-category-tabs" id="recipientCategoryTabs">
                                <button type="button" class="recipient-category-btn" data-category="member">الأفراد</button>
                                <button type="button" class="recipient-category-btn" data-category="manager">المسؤولون</button>
                                <button type="button" class="recipient-category-btn" data-category="admin">الأدمن</button>
                                <button type="button" class="recipient-category-btn" data-category="superadmin">السوبر أدمن</button>
                            </div>

                            <div class="recipient-empty-state" id="recipientCategoryHint">
                                اختر فئة واحدة أو أكثر لعرض الأسماء المتاحة.
                            </div>

                            <div class="recipient-tools">
                                <button type="button" class="btn btn-outline-primary" id="selectVisibleRecipients" disabled>
                                    <i class="bi bi-check2-square"></i> تحديد الكل
                                </button>
                                <input id="recipientSearch" class="form-control" type="search" placeholder="ابحث عن اسم أو دور..." autocomplete="off" />
                                <span class="selected-count" id="selectedCount">0 مستلم</span>
                            </div>

                            <div class="recipient-list" id="recipientList">
                                @for (var i = 0; i < targetUsers.Count; i++)
                                {
                                    var item = targetUsers[i];
                                    var roleClass = item.Category == "superadmin"
                                        ? "role-superadmin"
                                        : item.Category == "admin"
                                            ? "role-admin"
                                            : item.Category == "manager"
                                                ? "role-manager"
                                                : "role-member";
                                    var checkboxId = $"recipient_{i}";
                                    var isChecked = Model.RecipientIds?.Contains(item.Id) == true;

                                    <label class="recipient-item"
                                           for="@checkboxId"
                                           data-category="@item.Category"
                                           data-search="@($"{item.Name} {item.RoleText}".ToLowerInvariant())">
                                        <input id="@checkboxId"
                                               class="recipient-check"
                                               type="checkbox"
                                               name="RecipientIds"
                                               value="@item.Id"
                                               checked="@isChecked" />
                                        <span class="recipient-name">@item.Name</span>
                                        <span class="role-pill @roleClass">@item.RoleText</span>
                                    </label>
                                }

                                <div class="no-results" id="recipientNoResults">
                                    لا توجد نتائج مطابقة.
                                </div>
                            </div>

                            <span asp-validation-for="RecipientIds" class="text-danger"></span>
                            <div class="hint-line">اختر فئة واحدة أو أكثر، ثم حدد مستلماً أو استخدم تحديد الكل للأسماء المعروضة.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label">العنوان</label>
                            <select asp-for="Title" class="form-select" asp-items="requestTitles">
                                <option value="">اختر عنوان الطلب</option>
                            </select>
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Content" class="form-label">التفاصيل</label>
                            <textarea asp-for="Content" class="form-control" rows="6" placeholder="اكتب الطلب بشكل مختصر وواضح..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="AttachmentFile" class="form-label">إرفاق ملف</label>
                            <input asp-for="AttachmentFile" class="form-control" type="file" />
                            <span asp-validation-for="AttachmentFile" class="text-danger"></span>
                            <div class="hint-line">يمكنك إرفاق ملف واحد بحجم لا يتجاوز 10MB.</div>
                        </div>

                        <div class="request-actions">
                            <a asp-action="Index" class="btn btn-light">إلغاء</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i> إرسال
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('recipientSearch');
            const selectedCountSpan = document.getElementById('selectedCount');
            const noResults = document.getElementById('recipientNoResults');
            const categoryHint = document.getElementById('recipientCategoryHint');
            const selectVisibleButton = document.getElementById('selectVisibleRecipients');
            const categoryButtons = Array.from(document.querySelectorAll('.recipient-category-btn'));
            const checkboxes = Array.from(document.querySelectorAll('input[name="RecipientIds"]'));
            const rows = Array.from(document.querySelectorAll('.recipient-item'));
            const activeCategories = new Set();

            function updateSelectedCount() {
                const count = checkboxes.filter(input => input.checked).length;
                selectedCountSpan.textContent = count + ' ' + (count === 1 ? 'مستلم' : 'مستلمين');
            }

            function isRowVisible(row, term) {
                const categoryMatch = activeCategories.size > 0 && activeCategories.has(row.dataset.category);
                const searchMatch = !term || row.dataset.search.includes(term);
                return categoryMatch && searchMatch;
            }

            function filterRecipients() {
                const term = (searchInput.value || '').trim().toLowerCase();
                let visibleCount = 0;

                rows.forEach(row => {
                    const visible = isRowVisible(row, term);
                    row.style.display = visible ? '' : 'none';
                    if (visible) visibleCount++;
                });

                categoryHint.style.display = activeCategories.size > 0 ? 'none' : 'block';
                noResults.style.display = activeCategories.size > 0 && visibleCount === 0 ? 'block' : 'none';
                selectVisibleButton.disabled = activeCategories.size === 0 || visibleCount === 0;
            }

            categoryButtons.forEach(button => {
                button.addEventListener('click', () => {
                    const category = button.dataset.category || '';
                    if (activeCategories.has(category)) {
                        activeCategories.delete(category);
                    } else {
                        activeCategories.add(category);
                    }

                    button.classList.toggle('active', activeCategories.has(category));
                    filterRecipients();
                });
            });

            selectVisibleButton?.addEventListener('click', () => {
                const term = (searchInput.value || '').trim().toLowerCase();
                rows.forEach(row => {
                    if (!isRowVisible(row, term)) return;
                    const input = row.querySelector('input[name="RecipientIds"]');
                    if (input) input.checked = true;
                });
                updateSelectedCount();
            });

            checkboxes.forEach(input => input.addEventListener('change', updateSelectedCount));
            searchInput?.addEventListener('input', filterRecipients);

            const checkedRow = rows.find(row => row.querySelector('input[name="RecipientIds"]')?.checked);
            if (checkedRow) {
                rows.forEach(row => {
                    const hasCheckedInput = row.querySelector('input[name="RecipientIds"]')?.checked;
                    if (hasCheckedInput && row.dataset.category) {
                        activeCategories.add(row.dataset.category);
                    }
                });

                categoryButtons.forEach(item => item.classList.toggle('active', activeCategories.has(item.dataset.category || '')));
            }

            updateSelectedCount();
            filterRecipients();
        });
    </script>
}
