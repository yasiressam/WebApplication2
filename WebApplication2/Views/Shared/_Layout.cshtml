<!DOCTYPE html>
@using Microsoft.EntityFrameworkCore
@using WebApplication2.Data
@inject ApplicationDbContext DbContext
@{
    var siteImageUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/images/background1.jpg";
    var siteUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var pageTitle = $"{ViewData["Title"]} - التنظيم السياسي";
    string? onboardingPromptTitle = null;
    string? onboardingPromptMessage = null;
    string? onboardingPromptUrl = null;
    var shouldShowProfileGuidance = false;

    if (User.Identity?.IsAuthenticated == true &&
        !User.IsInRole("SystemManager") &&
        !User.IsInRole("SuperAdmin") &&
        !User.IsInRole("Admin") &&
        !User.IsInRole("DistrictAdmin") &&
        !User.IsInRole("Manager") &&
        !User.IsInRole("AssistantManager"))
    {
        var currentPath = Context.Request.Path.Value ?? string.Empty;
        var suppressedPaths = new[]
        {
            "/Register/BasicInfo",
            "/Register/AdditionalInfo",
            "/Register/ProfileDetails"
        };

        if (!suppressedPaths.Any(path => currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase)))
        {
            var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrWhiteSpace(currentUserId))
            {
                var profile = await DbContext.Identifies
                    .AsNoTracking()
                    .FirstOrDefaultAsync(i => i.UserId == currentUserId);

                bool hasRequiredWorkLocation = false;
                bool isBasicInfoComplete = false;

                if (profile != null)
                {
                    if (!string.IsNullOrWhiteSpace(profile.WorkGovernorate))
                    {
                        hasRequiredWorkLocation = true;
                    }
                    else
                    {
                        var workLocation = await DbContext.WorkLocations
                            .AsNoTracking()
                            .FirstOrDefaultAsync(w => w.IdentifyId == profile.Id);

                        hasRequiredWorkLocation = workLocation != null &&
                            !string.IsNullOrWhiteSpace(workLocation.Governorate) &&
                            (workLocation.Governorate != "بغداد" || !string.IsNullOrWhiteSpace(workLocation.District));
                    }

                    isBasicInfoComplete =
                        !string.IsNullOrWhiteSpace(profile.FullName) &&
                        !string.IsNullOrWhiteSpace(profile.MotherName) &&
                        profile.Date != DateTime.MinValue &&
                        !string.IsNullOrWhiteSpace(profile.Gender) &&
                        !string.IsNullOrWhiteSpace(profile.PhoneNumber) &&
                        !string.IsNullOrWhiteSpace(profile.IdentityCardN) &&
                        profile.IdentityCardN.Length == 12 &&
                        hasRequiredWorkLocation;
                }

                if (profile == null || !isBasicInfoComplete)
                {
                    onboardingPromptTitle = "أكمل بياناتك الأساسية";
                    onboardingPromptMessage = "اضغط على قائمة الحساب ثم اختر الملف الشخصي لإكمال الاستمارة الأساسية.";
                    onboardingPromptUrl = Url.Action("BasicInfo", "Register");
                    shouldShowProfileGuidance = true;
                }
                else if (!profile.IsPromoted && profile.IsBasicInfoApproved && profile.RequestedPromotion != true)
                {
                    onboardingPromptTitle = "أكمل استمارة الترقية";
                    onboardingPromptMessage = "من قائمة الحساب ادخل إلى الملف الشخصي ثم أكمل الاستمارة الثانية للترقية إلى فرد.";
                    onboardingPromptUrl = Url.Action("AdditionalInfo", "Register");
                    shouldShowProfileGuidance = true;
                }
            }
        }
    }
}
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        @ViewData["Title"] -  التنظيم السياسي
    </title>
    <link rel="icon" type="image/jpeg" href="~/images/background1.jpg" asp-append-version="true" />
    <link rel="shortcut icon" type="image/jpeg" href="~/images/background1.jpg" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/background1.jpg" asp-append-version="true" />
    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#3498db" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="التنظيم السياسي" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ar_IQ" />
    <meta property="og:site_name" content="التنظيم السياسي" />
    <meta property="og:title" content="@pageTitle" />
    <meta property="og:url" content="@siteUrl" />
    <meta property="og:image" content="@siteImageUrl" />
