@model WebApplication2.Models.ViewModels.AttendanceViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "تسجيل الحضور";
}

<style>
    .event-card {
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid #dee2e6;
        margin-bottom: 15px;
    }
    .event-card:hover {
        transform: translateX(-5px);
        background-color: #f8f9fa;
        border-color: #007bff;
    }
    .event-card.selected {
        background-color: #e8f0fe;
        border-color: #007bff;
        border-width: 2px;
    }
    .attended-row {
        background-color: #d4edda !important;
    }
    .status-badge {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
    }
</style>

<div class="container mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📝 تسجيل الحضور</h3>
        <div>
            <select id="monthSelect" class="form-select d-inline-block w-auto" style="width: 120px;">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i" selected="@(Model.Month == i)">@(new DateTime(2024, i, 1).ToString("MMMM"))</option>
                }
            </select>
            <select id="yearSelect" class="form-select d-inline-block w-auto ms-2" style="width: 100px;">
                @for (int i = 2020; i <= DateTime.Now.Year + 1; i++)
                {
                    <option value="@i" selected="@(Model.Year == i)">@i</option>
                }
            </select>
            <button id="filterBtn" class="btn btn-primary ms-2">🔍 عرض</button>
        </div>
    </div>

    <!-- قائمة الأحداث -->
    <div class="card mb-3">
        <div class="card-header bg-primary text-white">
            <i class="fas fa-calendar-alt"></i> الأحداث المتاحة
        </div>
        <div class="card-body">
            <div class="row" id="eventsList">
                @foreach (var eventItem in Model.Events)
                {
                    <div class="col-md-4">
                        <div class="card event-card" onclick="selectEvent(@eventItem.Id, '@eventItem.Title', '@eventItem.EventType')">
                            <div class="card-body">
                                <h6 class="card-title">@eventItem.Title</h6>
                                <small class="text-muted">@eventItem.EventType</small><br />
                                <small>📅 @eventItem.StartDate.ToString("yyyy-MM-dd HH:mm")</small><br />
                                <small>📍 @eventItem.Location</small>
                                <div class="mt-2">
                                    @if (eventItem.IsUrgent)
                                    {
                                        <span class="badge bg-danger">عاجل</span>
                                    }
                                    @if (eventItem.IsMandatory)
                                    {
                                        <span class="badge bg-warning text-dark">إلزامي</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- معلومات الحدث المختار -->
    <div id="selectedEventInfo" style="display: none;" class="mb-3">
        <div class="alert alert-info">
            <strong>📌 الحدث المختار:</strong> <span id="selectedEventTitle"></span>
            <button class="btn btn-sm btn-success float-start" onclick="startAttendance()">▶ بدء تسجيل الحضور</button>
        </div>
    </div>

    <!-- جدول تسجيل الحضور -->
    <div id="attendanceSection" style="display: none;">
        <div class="card">
            <div class="card-header bg-success text-white">
                <i class="fas fa-check-circle"></i> تسجيل الحضور
            </div>
            <div class="card-body">
                <input type="text" id="searchAttendance" class="form-control mb-2" placeholder="🔍 بحث بالاسم أو رقم الهاتف...">
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 5%">#</th>
                                <th style="width: 40%">الاسم</th>
                                <th style="width: 20%">رقم الهاتف</th>
                                <th style="width: 15%">حضور</th>
                            </tr>
                        </thead>
                        <tbody id="attendanceTableBody"></tbody>
                    </table>
                </div>
                <button class="btn btn-primary mt-2" onclick="saveAttendance()">💾 حفظ الحضور</button>
            </div>
        </div>
    </div>

    @if (!Model.Events.Any())
    {
        <div class="alert alert-warning text-center">
            ⚠️ لا توجد أحداث متاحة حالياً.
        </div>
    }
</div>

<script>
    let currentEventId = 0;
    let currentEventTitle = '';
    let currentEventType = '';
    let attendanceChanges = {};

    function selectEvent(id, title, type) {
        // إزالة التحديد السابق
        document.querySelectorAll('.event-card').forEach(card => {
            card.classList.remove('selected');
        });
        // تحديد الحدث الحالي
        const selectedCard = event.currentTarget;
        selectedCard.classList.add('selected');
        
        currentEventId = id;
        currentEventTitle = title;
        currentEventType = type;
        document.getElementById('selectedEventTitle').innerHTML = `${title} (${type})`;
        document.getElementById('selectedEventInfo').style.display = 'block';
        document.getElementById('attendanceSection').style.display = 'none';
    }

    async function startAttendance() {
        if (currentEventId === 0) {
            alert('⚠️ الرجاء اختيار حدث أولاً');
            return;
        }

        document.getElementById('attendanceSection').style.display = 'block';
        document.getElementById('attendanceTableBody').innerHTML = '<tr><td colspan="4" class="text-center">جاري التحميل...</td</tr';

        const month = document.getElementById('monthSelect').value;
        const year = document.getElementById('yearSelect').value;

        try {
            const response = await fetch(`/Evaluation/GetEventTargetUsers?eventId=${currentEventId}&month=${month}&year=${year}`);
            const data = await response.json();
            
            if (data.success && data.users && data.users.length > 0) {
                renderAttendanceTable(data.users);
            } else {
                document.getElementById('attendanceTableBody').innerHTML = '<tr><td colspan="4" class="text-center text-muted">⚠️ لا يوجد مستخدمين مستهدفين لهذا الحدث</td</tr';
            }
        } catch (error) {
            console.error(error);
            document.getElementById('attendanceTableBody').innerHTML = '<tr><td colspan="4" class="text-center text-danger">❌ حدث خطأ في تحميل البيانات</td</tr';
        }
    }

    function renderAttendanceTable(users) {
        const tbody = document.getElementById('attendanceTableBody');
        tbody.innerHTML = '';
        attendanceChanges = {};
        
        users.forEach((user, index) => {
            const row = tbody.insertRow();
            row.dataset.userId = user.userId;
            row.dataset.name = user.fullName?.toLowerCase() || '';
            row.dataset.phone = user.phoneNumber || '';
            
            row.insertCell(0).innerHTML = index + 1;
            row.insertCell(1).innerHTML = user.fullName || '---';
            row.insertCell(2).innerHTML = user.phoneNumber || '---';
            
            const cell = row.insertCell(3);
            const cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.className = 'form-check-input';
            cb.checked = user.attended;
            cb.onchange = function() { 
                attendanceChanges[user.userId] = this.checked;
                if (this.checked) {
                    row.classList.add('attended-row');
                } else {
                    row.classList.remove('attended-row');
                }
            };
            cell.appendChild(cb);
            
            if (user.attended) {
                row.classList.add('attended-row');
            }
        });
        
        // تفعيل البحث
        const searchInput = document.getElementById('searchAttendance');
        if (searchInput) {
            searchInput.onkeyup = function() {
                const value = this.value.toLowerCase();
                Array.from(tbody.rows).forEach(row => {
                    const name = row.dataset.name || '';
                    const phone = row.dataset.phone || '';
                    row.style.display = name.includes(value) || phone.includes(value) ? '' : 'none';
                });
            };
        }
    }

    async function saveAttendance() {
        if (Object.keys(attendanceChanges).length === 0) {
            alert('⚠️ لا توجد تغييرات لحفظها');
            return;
        }

        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const month = document.getElementById('monthSelect').value;
        const year = document.getElementById('yearSelect').value;
        let successCount = 0;
        
        for (const [userId, attended] of Object.entries(attendanceChanges)) {
            try {
                const response = await fetch('/Evaluation/SaveAttendance', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': csrfToken
                    },
                    body: JSON.stringify({ 
                        eventId: currentEventId, 
                        userId, 
                        attended,
                        month: parseInt(month),
                        year: parseInt(year)
                    })
                });
                const result = await response.json();
                if (result.success) {
                    successCount++;
                }
            } catch (error) {
                console.error('خطأ في حفظ الحضور:', error);
            }
        }
        
        alert(`✅ تم حفظ ${successCount} تغيير بنجاح`);
        attendanceChanges = {};
        await startAttendance(); // تحديث الجدول
    }

    document.getElementById('filterBtn').addEventListener('click', function() {
        window.location.href = `/Evaluation/Attendance?month=${document.getElementById('monthSelect').value}&year=${document.getElementById('yearSelect').value}`;
    });
</script>