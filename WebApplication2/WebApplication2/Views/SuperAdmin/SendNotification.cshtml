@{
    ViewData["Title"] = "إرسال إشعار";
    ViewData["Icon"] = "bi bi-send";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-bell"></i> إرسال إشعار جديد</h5>
                </div>
                <div class="card-body">
                    <div id="resultMessage" class="alert" style="display: none;"></div>

                    <form id="notificationForm">
                        <div class="mb-3">
                            <label class="form-label fw-bold">العنوان</label>
                            <input type="text" id="title" class="form-control" value="إشعار تجريبي" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">الرسالة</label>
                            <textarea id="message" class="form-control" rows="3" required>هذا إشعار تجريبي من لوحة التحكم</textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">المستلم</label>
                            <select id="targetUserId" class="form-select">
                                <option value="">جميع المستخدمين</option>
                                @foreach (var user in ViewBag.Users)
                                {
                                    <option value="@user.Id">@user.Email</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">الأيقونة</label>
                            <select id="icon" class="form-select">
                                <option value="bi-bell">🔔 جرس</option>
                                <option value="bi-info-circle">ℹ️ معلومات</option>
                                <option value="bi-check-circle">✅ نجاح</option>
                                <option value="bi-exclamation-triangle">⚠️ تحذير</option>
                                <option value="bi-star">⭐ نجمة</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">رابط النقر (اختياري)</label>
                            <input type="text" id="clickUrl" class="form-control" placeholder="/Home/Index" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg" id="sendBtn">
                                <i class="bi bi-send"></i> إرسال الإشعار
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- ✅ فقط jQuery للإرسال -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script>
        $(document).ready(function() {
            console.log("✅ صفحة الإرسال - جاهزة");

            $('#notificationForm').submit(function(e) {
                e.preventDefault();

                var sendBtn = $('#sendBtn');
                var originalText = sendBtn.html();
                sendBtn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> جاري الإرسال...');

                var data = {
                    title: $('#title').val(),
                    message: $('#message').val(),
                    targetUserId: $('#targetUserId').val() || null,
                    icon: $('#icon').val(),
                    clickUrl: $('#clickUrl').val() || null
                };

                $.ajax({
                    url: '/api/notifications/send-test',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    headers: {
                        'RequestVerificationToken': getCsrfToken()
                    },
                    success: function(response) {
                        showMessage('success', '✅ ' + response.message);
                        $('#notificationForm')[0].reset();
                    },
                    error: function(xhr) {
                        var errorMsg = xhr.responseJSON?.message || 'حدث خطأ أثناء الإرسال';
                        showMessage('danger', '❌ ' + errorMsg);
                    },
                    complete: function() {
                        sendBtn.prop('disabled', false).html(originalText);
                    }
                });
            });

            function showMessage(type, text) {
                var msg = $('#resultMessage');
                msg.removeClass('alert-success alert-danger')
                   .addClass('alert-' + type)
                   .html(text)
                   .show();
                setTimeout(() => msg.fadeOut(), 5000);
            }
        });

        function getCsrfToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }
    </script>
}