@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using WebApplication2.Data
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject ApplicationDbContext _context
@inject IConfiguration Configuration
@using System.Security.Claims

@{
    var isNewsEditor = User.IsInRole("NewsEditor");
    var isMapViewer = User.IsInRole("MapViewer");
    var hidePromotionRequestsForCentralManager = false;
    var showCentralManagersPage = false;

    if (SignInManager.IsSignedIn(User) &&
        User.IsInRole(clsRoles.Manager) &&
        !User.IsInRole(clsRoles.AssistantManager))
    {
        var menuUserId = UserManager.GetUserId(User);
        if (!string.IsNullOrWhiteSpace(menuUserId))
        {
            hidePromotionRequestsForCentralManager = await _context.ManagementAssignments
                .AnyAsync(a =>
                    a.UserId == menuUserId &&
                    a.AssignmentRole == "Manager" &&
                    (string.IsNullOrWhiteSpace(a.Governorate) ||
                     a.Governorate == "مركزي" ||
                     a.Governorate == "كل المحافظات" ||
                     (a.Governorate == "بغداد" &&
                      (string.IsNullOrWhiteSpace(a.BaghdadScope) || a.BaghdadScope == "مركزي"))));

            showCentralManagersPage = await _context.ManagementAssignments
                .AnyAsync(a =>
                    a.UserId == menuUserId &&
                    a.AssignmentRole == "Manager" &&
                    (string.IsNullOrWhiteSpace(a.Governorate) ||
                     a.Governorate == "مركزي" ||
                     a.Governorate == "كل المحافظات"));
        }
    }

    string ToLocalIraqPhoneForDisplay(string value)
    {
        var digits = new string((value ?? string.Empty).Where(char.IsDigit).ToArray());
        if (digits.StartsWith("9647", StringComparison.Ordinal))
            return "0" + digits[3..];

        return value;
    }
}

