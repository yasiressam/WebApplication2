@model LoginViewModel

<style>
    :root {
        --primary-blue: #3498db;
        --primary-dark: #2c3e50;
        --primary-gradient: linear-gradient(135deg, #3498db, #2c3e50);
        --success: #2ecc71;
        --warning: #f39c12;
        --danger: #e74c3c;
        --info: #3498db;
        --text-dark: #2c3e50;
        --text-muted: #6c757d;
        --border-color: rgba(52, 152, 219, 0.2);
        --shadow-color: rgba(0, 0, 0, 0.15);
    }

    .card {
        border-radius: 20px !important;
        overflow: hidden;
        box-shadow: 0 15px 35px var(--shadow-color) !important;
    }

    .card-header {
        background: var(--primary-gradient) !important;
        color: white !important;
        padding: 2rem !important;
        border-bottom: none !important;
    }

        .card-header h3 {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
        }

        .card-header p {
            opacity: 0.9;
            margin: 0;
            font-size: 0.9rem;
        }

    .card-body {
        padding: 2.5rem !important;
    }

    /* تنسيق الحقول */
    .form-label {
        font-weight: 600;
        color: var(--primary-dark);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

        .form-label i {
            color: var(--primary-blue);
        }

    .form-control {
        border-radius: 12px !important;
        padding: 0.8rem 1rem !important;
        border: 2px solid #e9ecef !important;
        transition: all 0.3s !important;
        font-size: 1rem;
    }

        .form-control:focus {
            border-color: var(--primary-blue) !important;
            box-shadow: 0 0 0 4px rgba(52, 152, 219, 0.1) !important;
            outline: none !important;
        }

    /* تنسيق زر تسجيل الدخول */
    .btn-primary {
        background: var(--primary-gradient) !important;
        border: none !important;
        color: white !important;
        padding: 0.8rem 1.5rem !important;
        border-radius: 50px !important;
        font-weight: 600 !important;
        transition: all 0.3s !important;
        box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3) !important;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(52, 152, 219, 0.4) !important;
        }

    /* تنسيق زر إنشاء حساب جديد */
    .btn-outline-success {
        background: transparent !important;
        border: 2px solid var(--primary-gradient) !important;
        color: var(--primary-dark) !important;
        padding: 0.8rem 1.5rem !important;
        border-radius: 50px !important;
        font-weight: 600 !important;
        transition: all 0.3s !important;
    }

        .btn-outline-success:hover {
            background: var(--primary-gradient) !important;
            border-color: transparent !important;
            color: white !important;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3) !important;
        }

    /* تنسيق التنبيهات */
    .alert-success {
        background: linear-gradient(135deg, rgba(46, 204, 113, 0.1), rgba(46, 204, 113, 0.05));
        border-right: 4px solid var(--success);
        border-radius: 12px;
        color: var(--text-dark);
        padding: 1.2rem !important;
    }

        .alert-success h5 {
            color: var(--success);
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

    .alert-danger {
        background: linear-gradient(135deg, rgba(231, 76, 60, 0.1), rgba(231, 76, 60, 0.05));
        border-right: 4px solid var(--danger);
        border-radius: 12px;
        color: var(--text-dark);
        padding: 1rem !important;
    }

    .alert-info {
        background: linear-gradient(135deg, rgba(52, 152, 219, 0.1), rgba(52, 152, 219, 0.05));
        border-right: 4px solid var(--info);
        border-radius: 12px;
        color: var(--text-dark);
        padding: 1.2rem !important;
    }

        .alert-info h6 {
            color: var(--info);
            font-weight: 700;
            margin-bottom: 0.8rem;
        }

        .alert-info ol {
            margin-bottom: 0;
            padding-right: 1.2rem;
        }

        .alert-info li {
            margin-bottom: 0.3rem;
            color: var(--text-muted);
        }

    /* تنسيق روابط إضافية */
    .border-top {
        border-top: 2px solid var(--border-color) !important;
        margin-top: 1.5rem !important;
        padding-top: 1.5rem !important;
    }

    .text-muted {
        color: var(--text-muted) !important;
    }

    a.text-decoration-none {
        color: var(--primary-blue) !important;
        transition: color 0.3s;
    }

        a.text-decoration-none:hover {
            color: var(--primary-dark) !important;
        }

    /* تنسيق مربع تذكرني */
    .form-check-input:checked {
        background-color: var(--primary-blue);
        border-color: var(--primary-blue);
    }

    .form-check-input:focus {
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 0.25rem rgba(52, 152, 219, 0.25);
    }

    .form-check-label {
        color: var(--text-dark);
        font-weight: 500;
    }

    /* تنسيق رسائل التحقق */
    .text-danger {
        color: var(--danger) !important;
        font-size: 0.8rem;
        margin-top: 0.3rem;
        display: block;
    }

    /* تحسينات الموبايل */
    @@media (max-width: 768px) {
        .container {
            padding-left: 15px;
            padding-right: 15px;
        }

        .card-header h3 {
            font-size: 1.5rem;
        }

        .card-body {
            padding: 1.5rem !important;
        }

        .form-control {
            font-size: 0.9rem;
        }

        .btn-primary, .btn-outline-success {
            font-size: 0.9rem;
            padding: 0.7rem 1.2rem !important;
        }
    }

    @@media (max-width: 576px) {
        .card-header h3 {
            font-size: 1.3rem;
        }

        .card-header p {
            font-size: 0.8rem;
        }

        .form-label {
            font-size: 0.9rem;
        }
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow border-0">
                <!-- رأس البطاقة -->
                <div class="card-header text-center">
                    <h3 class="mb-0">🔐 تسجيل الدخول</h3>
                    <p class="mb-0 small">أدخل بيانات حسابك للدخول</p>
                </div>

                <!-- محتوى البطاقة -->
                <div class="card-body">
                    <!-- رسائل الترحيب أو الأخطاء -->
                    @if (ViewBag.ShowWelcomeMessage == true)
                    {
                        <div class="alert alert-success mb-4">
                            <h5><i class="bi bi-check-circle"></i> تهانينا!</h5>
                            <p class="mb-0">تم تأكيد حسابك بنجاح. يمكنك الآن تسجيل الدخول.</p>
                        </div>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success mb-3">
                            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger mb-3">
                            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
                        </div>
                    }

                    <!-- نموذج تسجيل الدخول -->
                    <form asp-action="Login" method="post" asp-route-returnurl="@ViewData["ReturnUrl"]">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">
                                <i class="bi bi-person me-1"></i> البريد الإلكتروني أو رقم الواتساب
                            </label>
                            <input asp-for="Email" class="form-control" placeholder="example@email.com أو 07XXXXXXXXX" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">
                                <i class="bi bi-lock me-1"></i> كلمة المرور
                            </label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="********" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">تذكرني</label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-box-arrow-in-right me-2"></i> تسجيل الدخول
                            </button>
                        </div>
                    </form>

                    <!-- روابط إضافية -->
                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="text-muted mb-2">ليس لديك حساب؟</p>
                        <a href="@Url.Action("Index", "Register")" class="btn btn-outline-success">
                            <i class="bi bi-person-plus me-1"></i> إنشاء حساب جديد
                        </a>
                    </div>

                    <div class="text-center mt-3">
                        <a href="#" class="text-decoration-none small">نسيت كلمة المرور؟</a>
                    </div>
                </div>
            </div>

            <!-- معلومات عن الخطوات -->
            <div class="mt-4">
                <div class="alert alert-info">
                    <h6 class="alert-heading"><i class="bi bi-info-circle"></i> كيفية تسجيل الدخول:</h6>
                    <ol class="mb-0">
                        <li>أدخل البريد الإلكتروني أو رقم الواتساب وكلمة المرور الخاصة بك</li>
                        <li>اضغط على زر "تسجيل الدخول"</li>
                        <li>إذا نسيت كلمة المرور استخدم رابط الاستعادة</li>
                        <li>بعد الدخول يمكنك تعديل بياناتك الشخصية</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
