                    <div class="col-md-3">
                        <label class="form-label small text-muted">رقم العضوية</label>
                        <input type="text" class="form-control" asp-for="Memberships.AssociationIdNumber" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted">تاريخ النفاذ</label>
