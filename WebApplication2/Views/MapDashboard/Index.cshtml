@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    
    <script>
        // ===== متغيرات عامة =====
        var currentSelectedId = null;
        var governoratesData = @Html.Raw(Json.Serialize(Model.Governorates));
        
        var isAdminOnly = @Json.Serialize(isAdminOnly);
        var adminGovName = @Json.Serialize(adminGovernorateName);
        var isDistrictAdmin = @Json.Serialize(isDistrictAdmin);
        var adminDistrictName = @Json.Serialize(adminDistrictName);
        var isManagerScopedView = @Json.Serialize(isManagerScopedView);

        // ===== جلب إحصائيات المسؤولين العامة =====
        function loadManagerStatistics() {
            $.ajax({
                url: '/MapDashboard/GetManagerStatistics',
                type: 'GET',
                success: function(response) {
                    if (response && response.success) {
                        $('#totalEntityManagers').text(response.data.entityManagers || 0);
                        $('#totalDivisionManagers').text(response.data.divisionManagers || 0);
                        $('#totalSectionManagers').text(response.data.sectionManagers || 0);
                        $('#totalGroupManagers').text(response.data.groupManagers || 0);
                        $('#totalEntityAssistants').text(response.data.entityAssistants || 0);
                        $('#totalDivisionAssistants').text(response.data.divisionAssistants || 0);
                        $('#totalSectionAssistants').text(response.data.sectionAssistants || 0);
                        $('#totalGroupAssistants').text(response.data.groupAssistants || 0);
                    }
                },
