@model WebApplication2.Models.Audit.AuditTrailCategoryViewModel
@using WebApplication2.Models.Audit
@{
    ViewData["Title"] = Model.Title;
    ViewData["Icon"] = Model.Icon;
    Layout = "_Layout";
}

<style>
    .audit-page {
        display: grid;
        gap: 16px;
    }

    .audit-hero {
        background: #fff;
        border-radius: 24px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
        padding: 24px;
    }

    .audit-hero p {
        margin: 10px 0 0;
        color: #475569;
        line-height: 1.9;
    }

    .audit-list {
        display: grid;
        gap: 14px;
    }

    .audit-item {
        background: #fff;
        border-radius: 20px;
        border: 1px solid rgba(226, 232, 240, 0.95);
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
        padding: 18px 20px;
    }

    .audit-item-top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 8px;
    }

    .audit-item-title {
        font-weight: 800;
        color: #0f172a;
    }

    .audit-item-time {
        color: #64748b;
        font-size: 0.92rem;
        font-weight: 700;
    }

    .audit-item-meta {
        color: #475569;
        line-height: 1.9;
        font-size: 0.95rem;
    }

    .audit-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .audit-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        background: #e2e8f0;
        color: #1e293b;
        padding: 12px 16px;
        border-radius: 14px;
        font-weight: 700;
    }

    .audit-empty {
        text-align: center;
        background: #fff;
        border-radius: 20px;
        padding: 30px 20px;
        color: #64748b;
        border: 1px dashed rgba(148, 163, 184, 0.45);
    }
</style>

<div class="audit-page">
    <section class="audit-hero">
        <div class="audit-actions">
            <a asp-action="AuditTrail" class="audit-back">
                <i class="bi bi-arrow-right-circle"></i>
                <span>العودة إلى صفحة السجل</span>
            </a>
        </div>
        <p>@Model.Subtitle</p>
    </section>

    @if (Model.Entries.Any())
    {
        <div class="audit-list">
            @foreach (var entry in Model.Entries)
            {
                var title = AuditTrailDisplayFormatter.GetEventTitle(entry);
                var operationLabel = AuditTrailDisplayFormatter.GetOperationLabel(entry);
                var messageLabel = AuditTrailDisplayFormatter.TranslateMessage(entry.Message);
                <article class="audit-item">
                    <div class="audit-item-top">
                        <div class="audit-item-title">@title</div>
                        <div class="audit-item-time">@entry.TimestampUtc.ToLocalTime().ToString("yyyy/MM/dd hh:mm tt")</div>
                    </div>
                    <div class="audit-item-meta">
                        <span>العملية أو الصفحة: @operationLabel</span><br />
                        <span>الرسالة: @messageLabel</span><br />
                        <span>المستخدم: @(entry.UserEmail ?? entry.UserName ?? "غير معروف")</span><br />
                        <span>IP: @(entry.IpAddress ?? "-")</span>
                        @if (!string.IsNullOrWhiteSpace(entry.Details))
                        {
                            <br />
                            <span>التفاصيل: @entry.Details</span>
                        }
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="audit-empty">
            لا توجد سجلات في هذا القسم حتى الآن.
        </div>
    }
</div>
