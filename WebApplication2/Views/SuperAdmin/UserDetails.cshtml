@model WebApplication2.Models.SuperAdminUserDetailsVM
@{
    ViewData["Title"] = "تفاصيل المستخدم";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-user-circle"></i>
                تفاصيل المستخدم
            </h4>
        </div>
        <div class="card-body">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle"></i>
                    @TempData["ErrorMessage"]
                </div>
            }

            <div class="row">
                <!-- معلومات الحساب -->
                <div class="col-md-6">
                    <h5 class="border-bottom pb-2 mb-3">
                        <i class="fas fa-user-shield"></i> معلومات الحساب
                    </h5>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">البريد الإلكتروني:</div>
                        <div class="col-sm-8">
                            @Model.Email
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success ms-2">مفعل</span>
                            }
                            else
                            {
                                <span class="badge bg-danger ms-2">معطل</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">رقم الهاتف:</div>
                        <div class="col-sm-8">@Model.PhoneNumber</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">الأدوار:</div>
                        <div class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.Roles))
                            {
                                if (Model.Roles.Contains("SuperAdmin"))
                                {
                                    <span class="badge bg-danger">سوبر أدمن</span>
                                }
                                if (Model.Roles.Contains("Admin"))
                                {
                                    <span class="badge bg-success">أدمن</span>
                                }
                                if (Model.Roles.Contains("User"))
                                {
                                    <span class="badge bg-secondary">مستخدم</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">لا يوجد أدوار</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">معرف المستخدم:</div>
                        <div class="col-sm-8">
                            <small class="text-muted">@Model.UserId</small>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ManagedGovernorate))
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-bold">المحافظة المدارة:</div>
                            <div class="col-sm-8">
                                <span class="badge bg-warning text-dark">
                                    <i class="fas fa-crown"></i> @Model.ManagedGovernorate
                                </span>
                            </div>
                        </div>
                    }
                </div>

                <!-- المعلومات الشخصية -->
                <div class="col-md-6">
                    <h5 class="border-bottom pb-2 mb-3">
                        <i class="fas fa-id-card"></i> المعلومات الشخصية
                    </h5>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">الاسم الكامل:</div>
                        <div class="col-sm-8">@Model.FullName</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">اسم العائلة:</div>
                        <div class="col-sm-8">@Model.LastName</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">اسم الأم:</div>
                        <div class="col-sm-8">@Model.MotherName</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">الجنس:</div>
                        <div class="col-sm-8">
                            @if (Model.Gender == "ذكر")
                            {
                                <span class="badge bg-info">ذكر</span>
                            }
                            else if (Model.Gender == "أنثى")
                            {
                                <span class="badge bg-pink">أنثى</span>
                            }
                            else
                            {
                                <span class="text-muted">@Model.Gender</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">اللقب:</div>
                        <div class="col-sm-8">@Model.MozakeName</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">المؤهل العلمي:</div>
                        <div class="col-sm-8">@Model.Education</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">التخصص:</div>
                        <div class="col-sm-8">@Model.Specialization</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">رقم البطاقة:</div>
                        <div class="col-sm-8">@Model.IdentityCardN</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">تاريخ البطاقة:</div>
                        <div class="col-sm-8">@Model.IdentityDate.ToString("yyyy/MM/dd")</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">تاريخ الميلاد:</div>
                        <div class="col-sm-8">@Model.DateOfBirth.ToString("yyyy/MM/dd")</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">رقم البطاقة التموينية:</div>
                        <div class="col-sm-8">@Model.RationN</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">مركز التوزيع:</div>
                        <div class="col-sm-8">@Model.RationCenter</div>
                    </div>
                </div>
            </div>

            <!-- معلومات العنوان -->
            <div class="mt-4">
                <h5 class="border-bottom pb-2 mb-3">
                    <i class="fas fa-map-marker-alt"></i> معلومات العنوان
                </h5>

                @if (Model.Address != null)
                {
                    <div class="row">
                        <div class="col-md-4">
                            <div class="row mb-2">
                                <div class="col-sm-5 fw-bold">المحافظة:</div>
                                <div class="col-sm-7">@Model.Address.Governorate</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="row mb-2">
                                <div class="col-sm-5 fw-bold">القضاء/المنطقة:</div>
                                <div class="col-sm-7">@Model.Address.District</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="row mb-2">
                                <div class="col-sm-5 fw-bold">الناحية:</div>
                                <div class="col-sm-7">@Model.Address.SubDistrict</div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="row mb-2">
                                <div class="col-sm-5 fw-bold">المحلة/الزقاق:</div>
                                <div class="col-sm-7">@Model.Address.Alley</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="row mb-2">
                                <div class="col-sm-5 fw-bold">الشارع:</div>
                                <div class="col-sm-7">@Model.Address.Street</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="row mb-2">
                                <div class="col-sm-5 fw-bold">المنزل:</div>
                                <div class="col-sm-7">@Model.Address.House</div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Address.NearestPoint))
                    {
                        <div class="row">
                            <div class="col-12">
                                <div class="row mb-2">
                                    <div class="col-sm-2 fw-bold">أقرب نقطة دالة:</div>
                                    <div class="col-sm-10">@Model.Address.NearestPoint</div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        لا يوجد عنوان مسجل لهذا المستخدم
                    </div>
                }
            </div>
        </div>
        <div class="card-footer">
            <a href="@Url.Action("Users", "SuperAdmin")" class="btn btn-secondary">
                <i class="fas fa-arrow-right"></i> العودة للقائمة
            </a>
        </div>
    </div>
</div>

<style>
    .border-bottom {
        border-bottom: 2px solid #dee2e6 !important;
    }

    .bg-pink {
        background-color: #ffc0cb;
        color: #000;
    }
</style>