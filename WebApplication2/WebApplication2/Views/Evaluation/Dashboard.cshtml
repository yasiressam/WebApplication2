@model List<WebApplication2.Models.UserEvaluationSummary>

@{
    Layout = "_Layout";
    ViewData["Title"] = "لوحة التقييمات الشاملة";
}

<style>
    .table th, .table td {
        font-size: 0.85rem;
        padding: 8px;
        vertical-align: middle;
        white-space: nowrap;
    }
    .grade-badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-block;
        min-width: 70px;
        text-align: center;
    }
    .grade-Excellent { background: #28a745; color: white; }
    .grade-VeryGood { background: #17a2b8; color: white; }
    .grade-Good { background: #007bff; color: white; }
    .grade-Acceptable { background: #ffc107; color: #212529; }
    .grade-Weak { background: #dc3545; color: white; }
    .score-cell {
        font-weight: 600;
        text-align: center;
    }
    .total-cell {
        background-color: #e8f0fe;
        font-weight: 700;
    }
    .table-responsive {
        overflow-x: auto;
    }
</style>

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📊 لوحة التقييمات الشاملة</h3>
        <div>
            <select id="monthSelect" class="form-select d-inline-block w-auto" style="width: 120px;">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i" selected="@(ViewBag.Month == i)">@(new DateTime(2024, i, 1).ToString("MMMM"))</option>
                }
            </select>
            <select id="yearSelect" class="form-select d-inline-block w-auto ms-2" style="width: 100px;">
                @for (int i = 2020; i <= DateTime.Now.Year + 1; i++)
                {
                    <option value="@i" selected="@(ViewBag.Year == i)">@i</option>
                }
            </select>
            <button id="filterBtn" class="btn btn-primary ms-2">🔍 عرض</button>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered mb-0">
                    <thead class="table-light">
                        <tr style="text-align: center;">
                            <th rowspan="2">#</th>
                            <th rowspan="2">الاسم</th>
                            <th rowspan="2">رقم الهاتف</th>
                            <th rowspan="2">المحافظة</th>
                            <th colspan="6" class="text-center">العوامل اليدوية</th>
                            <th colspan="2" class="text-center">الحضور</th>
                            <th rowspan="2">المجموع</th>
                            <th rowspan="2">التقدير</th>
                        </tr>
                        <tr style="text-align: center;">
                            <th>تواصل</th>
                            <th>إعلامي</th>
                            <th>حركي</th>
                            <th>استقطاب</th>
                            <th>تواصل اجتماعي</th>
                            <th>رأي مسؤول</th>
                            <th>منتدى سياسي</th>
                            <th>اجتماعات دورية</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var user = Model[i];
                            var gradeClass = user.Percentage >= 90 ? "Excellent" :
                                            user.Percentage >= 80 ? "VeryGood" :
                                            user.Percentage >= 70 ? "Good" :
                                            user.Percentage >= 60 ? "Acceptable" : "Weak";
                            <tr>
                                <td class="text-center">@(i + 1)</td>
                                <td>@user.FullName</td>
                                <td>@user.PhoneNumber</td>
                                <td>@user.Governorate</td>
                                <td class="score-cell">@user.CommunicationScore / 12</td>
                                <td class="score-cell">@user.MediaActivityScore / 12</td>
                                <td class="score-cell">@user.MovementActivityScore / 12</td>
                                <td class="score-cell">@user.PolarizationScore / 12</td>
                                <td class="score-cell">@user.SocialMediaScore / 12</td>
                                <td class="score-cell">@user.SupervisorOpinionScore / 16</td>
                                <td class="score-cell">@user.PoliticalForumScore.ToString("F0") / 12</td>
                                <td class="score-cell">@user.PeriodicMeetingsScore.ToString("F0") / 12</td>
                                <td class="total-cell text-center">@user.TotalScore / 100</td>
                                <td class="text-center"><span class="grade-badge grade-@gradeClass">@user.Grade</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center mt-3">
            📭 لا يوجد أفراد مصعدين في النظام.
        </div>
    }
</div>

<script>
    document.getElementById('filterBtn').addEventListener('click', function() {
        const month = document.getElementById('monthSelect').value;
        const year = document.getElementById('yearSelect').value;
        window.location.href = `/Evaluation/Dashboard?month=${month}&year=${year}`;
    });
</script>