@{
    ViewData["Title"] = "خطأ";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0"><i class="bi bi-exclamation-triangle"></i> حدث خطأ</h3>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-x-circle display-1 text-danger"></i>
                    </div>

                    <h4 class="text-danger mb-3">@ViewBag.ErrorMessage</h4>

                    <p class="text-muted mb-4">
                        حدث خطأ أثناء معالجة طلبك. يرجى المحاولة مرة أخرى.
                    </p>

                    <div class="alert alert-info text-start">
                        <h6><i class="bi bi-lightbulb"></i> نصائح:</h6>
                        <ul class="mb-0">
                            <li>تأكد من صحة رابط التأكيد</li>
                            <li>حاول إعادة إرسال رابط التأكيد</li>
                            <li>تحقق من عدم انتهاء صلاحية الرابط (24 ساعة)</li>
                            <li>اتصل بالدعم الفني إذا استمرت المشكلة</li>
                        </ul>
                    </div>

                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-primary me-2">
                            <i class="bi bi-arrow-left"></i> العودة للتسجيل
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-house"></i> الصفحة الرئيسية
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>