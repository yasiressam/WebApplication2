@model IEnumerable<WebApplication2.Models.AffiliationEntity>

@{
    ViewData["Title"] = "جهات الانتساب";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-6">
            <h2><i class="bi bi-building"></i> جهات الانتساب</h2>
        </div>
        <div class="col-6 text-start">
            <a href="@Url.Action("CreateAffiliationEntity")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> إضافة جديدة
            </a>
            <a href="@Url.Action("Dashboard")" class="btn btn-secondary">
                <i class="bi bi-arrow-right"></i> عودة للوحة
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 5%">#</th>
                            <th style="width: 40%">جهة الانتساب</th>
                            <th style="width: 15%">عدد الأقسام</th>
                            <th style="width: 20%">تاريخ الإضافة</th>
                            <th style="width: 20%">الإجراءات</th>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int i = 1;
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-center">@(i++)</td>
                                        <td>
                                            <!-- ✅ تم التعديل: من Divisions إلى AffiliationEntityDetails -->
                                            <a href="@Url.Action("AffiliationEntityDetails", new { id = item.Id })"
                                                   class="text-decoration-none fw-bold text-primary">
                                                <i class="bi bi-folder-fill"></i> @item.Name
                                            </a>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-info rounded-pill">@item.Divisions?.Count()</span>
                                        </td>
                                        <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            <!-- ✅ تم التعديل: من Divisions إلى AffiliationEntityDetails -->
                                            <a href="@Url.Action("AffiliationEntityDetails", new { id = item.Id })"
                                                   class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-diagram-3"></i> إدارة
                                            </a>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    onclick="deleteAffiliation(@item.Id, '@item.Name')">
                                                <i class="bi bi-trash"></i> حذف
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-5">
                                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                        لا توجد جهات انتساب
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            function deleteAffiliation(id, name) {
                if (confirm(`⚠️ هل أنت متأكد من حذف جهة الانتساب "${name}"؟\n\nملاحظة: سيتم حذف جميع الأقسام والشعب والوحدات المرتبطة بها.`)) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    if (!token) token = $('form input[name="__RequestVerificationToken"]').val();

                    $.ajax({
                        url: '@Url.Action("DeleteAffiliationEntity", "ManageableEntities")',
                        type: 'POST',
                        data: { id: id },
                        headers: { 'RequestVerificationToken': token },
                        success: function(response) {
                            if (response.success) {
                                alert(response.message);
                                location.reload();
                            } else {
                                alert("❌ " + response.message);
                            }
                        },
                        error: function(xhr) {
                            alert("❌ حدث خطأ: " + (xhr.responseJSON?.message || xhr.statusText));
                        }
                    });
                }
            }
        </script>
    }
