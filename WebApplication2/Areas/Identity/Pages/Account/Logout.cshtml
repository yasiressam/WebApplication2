@page
@model LogoutModel



                <div class="card-body text-center py-5">
                    @{
                        if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <i class="bi bi-person-check display-1 text-primary mb-4"></i>
                            <h3 class="mb-4">هل تريد تسجيل الخروج؟</h3>
                            <p class="text-muted mb-4">ستتم إعادتك إلى الصفحة الرئيسية بعد تسجيل الخروج</p>

                            <form class="form-inline d-inline-block" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                                <button type="submit" class="btn btn-danger btn-lg px-5">
                                    <i class="bi bi-box-arrow-right me-2"></i> نعم، سجل خروج
                                </button>
                            </form>

                            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-lg px-5 ms-2">
                                <i class="bi bi-x-circle me-2"></i> إلغاء
                            </a>
                        }
                        else
                        {
                            <i class="bi bi-check-circle display-1 text-success mb-4"></i>
                            <h3 class="mb-4">تم تسجيل الخروج بنجاح</h3>
                            <p class="text-muted mb-4">تم تسجيل خروجك من التطبيق بنجاح</p>

                            <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-house-door me-2"></i> العودة للصفحة الرئيسية
                            </a>
                        }
                    }
                </div>

                <div class="card-footer bg-light text-center">
                    <small class="text-muted">
                        <i class="bi bi-shield-check me-1"></i>
                        جلستك آمنة - تم حماية عملية تسجيل الخروج
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn {
        transition: all 0.3s;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
</style>