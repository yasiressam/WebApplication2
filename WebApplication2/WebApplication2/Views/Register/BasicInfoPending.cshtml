@{
    
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .pending-card {
        background: white;
        border-radius: 15px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        text-align: center;
        max-width: 600px;
        margin: 50px auto;
    }

    .pending-icon {
        font-size: 5rem;
        color: #f39c12;
        margin-bottom: 20px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }

        100% {
            transform: scale(1);
        }
    }

    .pending-title {
        color: #2c3e50;
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .pending-message {
        color: #666;
        font-size: 1.1rem;
        margin-bottom: 30px;
        line-height: 1.8;
    }

    .info-box {
        background: #f8f9fa;
        border-right: 4px solid #3498db;
        padding: 20px;
        border-radius: 10px;
        text-align: right;
        margin-bottom: 30px;
    }

        .info-box h6 {
            color: #2c3e50;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .info-box ul {
            list-style: none;
            padding-right: 0;
        }

        .info-box li {
            margin-bottom: 10px;
            color: #555;
        }

            .info-box li i {
                color: #27ae60;
                margin-left: 10px;
            }

    .estimated-time {
        background: #fff3cd;
        border: 1px solid #ffeeba;
        border-radius: 10px;
        padding: 15px;
        margin: 30px 0;
    }

        .estimated-time i {
            color: #856404;
            font-size: 1.5rem;
            margin-left: 10px;
        }

    .btn-home {
        background: linear-gradient(135deg, #3498db, #2c3e50);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 25px;
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0 5px;
        transition: all 0.3s;
    }

        .btn-home:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3);
        }

    .btn-outline-home {
        background: white;
        color: #2c3e50;
        border: 2px solid #2c3e50;
        padding: 12px 30px;
        border-radius: 25px;
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0 5px;
        transition: all 0.3s;
    }

        .btn-outline-home:hover {
            background: #2c3e50;
            color: white;
        }
</style>

<div class="container" dir="rtl">
    <div class="pending-card">
        <div class="pending-icon">
            <i class="bi bi-clock-history"></i>
        </div>

        <h1 class="pending-title">⏳ قيد المراجعة</h1>

        <div class="pending-message">
            <p>شكراً لك! تم استلام معلوماتك الأساسية بنجاح.</p>
            <p>سيقوم فريق الإدارة بمراجعة بياناتك خلال 24-48 ساعة.</p>
        </div>

        <div class="info-box">
            <h6><i class="bi bi-info-circle"></i> ماذا سيحدث بعد ذلك؟</h6>
            <ul>
                <li>
                    <i class="bi bi-check-circle"></i>
                    <strong>الموافقة:</strong> إذا تمت الموافقة على معلوماتك، ستتلقى إشعاراً ويمكنك إكمال البيانات الإضافية.
                </li>
                <li>
                    <i class="bi bi-x-circle"></i>
                    <strong>الرفض:</strong> إذا كانت هناك أخطاء في البيانات، سيتم إشعارك بسبب الرفض ويمكنك تعديلها.
                </li>
            </ul>
        </div>

        <div class="estimated-time">
            <i class="bi bi-bell"></i>
            <strong>ملاحظة:</strong> سيتم إرسال إشعار إلى بريدك الإلكتروني فور انتهاء المراجعة.
        </div>

        <div class="mt-4">
            <a asp-action="Index" asp-controller="Home" class="btn-home">
                <i class="bi bi-house"></i> العودة للرئيسية
            </a>
            @* <a asp-action="BasicInfo" class="btn-outline-home">
                <i class="bi bi-pencil"></i> تعديل البيانات
            </a> *@
        </div>
    </div>
</div>

<!-- ✅ إضافة سكريبت التحقق التلقائي -->
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            console.log("✅ صفحة انتظار المراجعة - بدء التحقق التلقائي");

            // التحقق كل 30 ثانية إذا تمت الموافقة
            var checkInterval = setInterval(function() {
                $.ajax({
                    url: '/Register/CheckApprovalStatus',
                    type: 'GET',
                    success: function(data) {
                        console.log("📊 حالة الموافقة:", data);
                        if (data && data.approved === true) {
                            console.log("✅ تمت الموافقة! جارٍ التوجيه إلى الصفحة الإضافية");
                            clearInterval(checkInterval);
                            window.location.href = '/Register/AdditionalInfo';
                        }
                    },
                    error: function(xhr, status, error) {
                        console.log("❌ خطأ في التحقق:", error);
                    }
                });
            }, 30000); // 30 ثانية

            // إيقاف التحقق عند مغادرة الصفحة
            $(window).on('beforeunload', function() {
                clearInterval(checkInterval);
            });
        });
    </script>
}