        // ========== تعديل الأدوار ==========
        document.querySelectorAll('.edit-roles-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const userId = this.dataset.userId;
                const userEmail = this.dataset.userEmail;
                const userGovernorate = this.dataset.userGovernorate || '';
                const userDistrict = this.dataset.userDistrict || '';

                document.getElementById('modalUserInfo').innerHTML = '<i class="fas fa-user"></i> <strong>' + userEmail + '</strong>';
                document.getElementById('modalUserId').value = userId;
                document.getElementById('currentUserGovernorate').value = userGovernorate;
                document.getElementById('currentUserDistrict').value = userDistrict;

                Swal.fire({ title: 'جاري التحميل...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

                fetch('/SuperAdmin/GetUserRoles?userId=' + userId)
                    .then(res => res.json())
                    .then(data => {
                        Swal.close();
                        if (data.success) {
                            document.querySelectorAll('input[name="roleOption"]').forEach(radio => radio.checked = false);
                            let isAdmin = false;
                            let isMapViewer = false;
                            if (data.data && data.data.CurrentRoles) {
                                data.data.CurrentRoles.forEach(role => {
                                    let radioId = '';
                                    switch(role) {
                                        case 'User': radioId = 'roleUser'; break;
                                        case 'فرد': radioId = 'roleMember'; break;
                                        case 'Admin': radioId = 'roleAdmin'; isAdmin = true; break;
                                        case 'DistrictAdmin': radioId = 'roleAdmin'; isAdmin = true; break;
                                        case 'SuperAdmin': radioId = 'roleSuperAdmin'; break;
                                        case 'NewsEditor': radioId = 'roleNewsEditor'; break;
                                        case 'MapViewer': radioId = 'roleMapViewer'; isMapViewer = true; break;
                                    }
                                    if (radioId) document.getElementById(radioId).checked = true;
                                });
                            }
                            
                            // تعيين المحافظة والقضاء الحاليين
                            if (userGovernorate) {
                                document.getElementById('adminGovernorate').value =
                                    userGovernorate === 'بغداد' && userDistrict
                                        ? 'بغداد - ' + userDistrict
                                        : userGovernorate === 'بغداد'
                                        ? 'بغداد مركزي'
                                        : userGovernorate;
                            }
                            
                            toggleAdminFields();
                            document.getElementById('adminWarning').style.display = (isAdmin || isMapViewer) ? 'block' : 'none';
                            new bootstrap.Modal(document.getElementById('rolesModal')).show();
                        } else {
                            Swal.fire('خطأ', data.message || 'فشل في تحميل الأدوار', 'error');
                        }
                    })
                    .catch(error => {
                        Swal.close();
                        Swal.fire('خطأ', 'حدث خطأ في الاتصال بالخادم', 'error');
                    });
            });
        });

