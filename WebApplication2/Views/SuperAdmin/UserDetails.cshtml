<!-- نافذة تكبير الصورة -->
<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-dark border-0">

            <div class="modal-header border-0">
                <h5 class="text-white">الصورة الشخصية</h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center p-2">
                <img src="@Model.CoverImage"
                     class="img-fluid rounded shadow"
                     style="max-height:85vh;">
            </div>

        </div>
    </div>
</div>
@section Scripts {
    <script>
        async function printOfficialForm() {
            buildOfficialPrintPages();
            await waitForOfficialPrintImages();
            printOfficialPagesInCleanWindow();
        }

        function printOfficialPagesInCleanWindow() {
            const pagesHtml = Array.from(document.querySelectorAll('#officialPrintForm .print-page'))
                .map(page => page.outerHTML)
                .join('');

            if (!pagesHtml) {
                return;
            }

            const printWindow = window.open('', '_blank', 'width=900,height=1200');
            if (!printWindow) {
                document.body.classList.add('print-mode');
                window.print();
                setTimeout(() => document.body.classList.remove('print-mode'), 300);
                return;
            }

            printWindow.document.open();
            printWindow.document.write(`<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8">
    <title>طباعة الاستمارة</title>
    <style>
        @@page { size: A4; margin: 0; }
        html, body {
            width: 210mm;
            margin: 0;
            padding: 0;
            background: #fff;
            direction: rtl;
            font-family: "Segoe UI", Tahoma, sans-serif;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .print-page {
            width: 210mm;
            height: 297mm;
            margin: 0;
            padding: 0;
            position: relative;
            overflow: hidden;
            background: #fff;
            page-break-after: always;
            break-after: page;
        }
        .print-page:last-child {
            page-break-after: auto;
            break-after: auto;
        }
        .print-page-bg {
            display: block;
            position: absolute;
            inset: 0;
            width: 210mm;
            height: 297mm;
            max-width: none;
            max-height: none;
            object-fit: fill;
            z-index: 0;
        }
        .print-page-content {
            position: absolute;
            top: 43mm;
            right: 11mm;
            bottom: 22mm;
            left: 11mm;
            z-index: 1;
            overflow: hidden;
        }
        .print-profile-card {
            position: absolute;
            top: 43mm;
            left: 11mm;
            right: 11mm;
            min-height: 28mm;
            z-index: 2;
            border: 1px solid rgba(17, 24, 39, 0.25);
            border-radius: 7px;
            background: rgba(255,255,255,0.68);
            padding: 4mm;
            display: grid;
            grid-template-columns: 24mm 1fr;
            gap: 6mm;
            align-items: center;
            direction: ltr;
            color: #111827;
        }
        .print-profile-copy {
            direction: rtl;
            text-align: center;
        }
        .print-profile-title {
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 3mm;
            line-height: 1.3;
        }
        .print-profile-photo {
            display: block;
            width: 24mm;
            height: 24mm;
            margin: 0;
            border: 1px solid rgba(17, 24, 39, 0.22);
            border-radius: 5px;
            object-fit: cover;
            background: #fff;
        }
        .print-profile-name {
            font-size: 17px;
            font-weight: 700;
            line-height: 1.35;
            word-break: break-word;
        }
        .print-page.has-photo .print-page-content {
            top: 76mm;
        }
        .print-page.has-signatures .print-page-content {
            padding-bottom: 34mm;
        }
        .print-sections {
            display: grid;
            gap: 5px;
        }
        .print-section {
            border: 1px solid #dbe5ee;
            border-radius: 6px;
            overflow: hidden;
            background: rgba(255,255,255,0.58);
            break-inside: avoid;
            page-break-inside: avoid;
        }
        .print-section-title {
            padding: 6px 11px;
            font-weight: 700;
            font-size: 15.5px;
            color: #0f172a;
            background: rgba(240,253,250,0.62);
            border-bottom: 1px solid #dde7f0;
            border-right: 4px solid #0f766e;
        }
        .print-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 5px;
            padding: 6px;
        }
        .print-field {
            background: rgba(248,250,252,0.52);
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            padding: 4px 6px;
            min-height: 42px;
            break-inside: avoid;
            page-break-inside: avoid;
        }
        .print-field.full {
            grid-column: 1 / -1;
        }
        .print-label {
            display: block;
            color: #546274;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 2px;
        }
        .print-value {
            display: block;
            color: #111827;
            font-size: 16px;
            font-weight: 700;
            line-height: 1.3;
            word-break: break-word;
        }
        .print-signatures {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-top: 0;
            position: absolute;
            right: 0;
            left: 0;
            bottom: 0;
        }
        .signature-box {
            text-align: center;
            background: rgba(255,255,255,0.82);
            border: 1px dashed #94a3b8;
            border-radius: 6px;
            min-height: 76px;
            padding: 10px;
            font-size: 12px;
            color: #475569;
        }
    <\/style>
<\/head>
<body>${pagesHtml}<\/body>
<\/html>`);
            printWindow.document.close();

            const images = Array.from(printWindow.document.querySelectorAll('.print-page-bg'));
            Promise.all(images.map(img => img.complete
                ? Promise.resolve()
                : new Promise(resolve => {
                    img.onload = resolve;
                    img.onerror = resolve;
                })))
                .then(() => {
                    printWindow.focus();
                    printWindow.print();
                    setTimeout(() => printWindow.close(), 500);
                });
        }

        function waitForOfficialPrintImages() {
            const images = Array.from(document.querySelectorAll('#officialPrintForm .print-page-bg'));
            const pending = images
                .filter(img => !img.complete)
                .map(img => new Promise(resolve => {
                    img.onload = resolve;
                    img.onerror = resolve;
                }));

            return Promise.all(pending).then(() => new Promise(resolve => requestAnimationFrame(() => resolve())));
        }

        function buildOfficialPrintPages() {
            const form = document.getElementById('officialPrintForm');
            const templateSheet = form?.querySelector('.print-sheet');
            const templateContent = templateSheet?.querySelector('.print-content');
            const header = templateContent?.querySelector('.print-header');
            const sections = Array.from(templateContent?.querySelectorAll('.print-sections > .print-section') || []);
            const signatures = templateContent?.querySelector('.print-signatures');

            if (!form || !templateSheet || !templateContent || !sections.length) {
                return;
            }

            form.querySelectorAll('.print-page').forEach(page => page.remove());
            form.classList.add('paginating');

            const pageRules = [
                {
                    includePhoto: true,
                    titles: ['معلومات الحساب', 'المعلومات الشخصية', 'المستندات الرسمية']
                },
                {
                    titles: ['محافظة العمل التنظيمي', 'عنوان السكن', 'العمل والتوظيف']
                },
                {
                    titles: ['المسؤوليات الإدارية', 'معلومات الانتساب', 'العضويات'],
                    includeSignatures: true
                }
            ];

            const usedSections = new Set();

            pageRules.forEach(rule => {
                const matchingSections = sections.filter(section => {
                    const title = section.querySelector('.print-section-title')?.textContent?.trim();
                    return title && rule.titles.includes(title);
                });

                if (!rule.includeHeader && !rule.includeSignatures && !matchingSections.length) {
                    return;
                }

                const page = createOfficialPrintPage(form, rule.includePhoto === true);
                const content = page.querySelector('.print-page-content');

                if (rule.includeHeader && header) {
                    content.appendChild(header.cloneNode(true));
                }

                matchingSections.forEach(section => {
                    usedSections.add(section);
                    content.appendChild(section.cloneNode(true));
                });

                if (rule.includeSignatures && signatures) {
                    page.classList.add('has-signatures');
                    content.appendChild(signatures.cloneNode(true));
                }
            });

            const remainingSections = sections.filter(section => {
                const title = section.querySelector('.print-section-title')?.textContent?.trim();
                return !usedSections.has(section) && title !== 'حالة الترقية';
            });
            if (remainingSections.length) {
                const page = createOfficialPrintPage(form, false);
                const content = page.querySelector('.print-page-content');
                remainingSections.forEach(section => content.appendChild(section.cloneNode(true)));
            }

            form.classList.remove('paginating');
        }

        function createOfficialPrintPage(form, includePhoto) {
            const page = document.createElement('div');
            page.className = 'print-page';

            const background = document.createElement('img');
            background.className = 'print-page-bg';
            background.src = '/images/official-form-background.jpg';
            background.alt = '';
            page.appendChild(background);

            const coverImage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model?.CoverImage ?? ""));
            if (includePhoto && coverImage) {
                page.classList.add('has-photo');
                const card = document.createElement('div');
                card.className = 'print-profile-card';

                const copy = document.createElement('div');
                copy.className = 'print-profile-copy';

                const title = document.createElement('div');
                title.className = 'print-profile-title';
                title.textContent = 'استمارة معلومات المستخدم';

                const photo = document.createElement('img');
                photo.className = 'print-profile-photo';
                photo.src = coverImage;
                photo.alt = 'الصورة الشخصية';

                const name = document.createElement('div');
                name.className = 'print-profile-name';
                name.textContent = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((Model?.FullName ?? "غير مكتمل") + (!string.IsNullOrWhiteSpace(Model?.LastName) ? $" {Model.LastName}" : "")));

                card.appendChild(photo);
                copy.appendChild(title);
                copy.appendChild(name);
                card.appendChild(copy);
                page.appendChild(card);
            }

            const content = document.createElement('div');
            content.className = 'print-page-content';
            page.appendChild(content);

            form.appendChild(page);
            return page;
        }

        function goBack() {
            window.history.back();
        }

        function removeAssignment(assignmentId, userName) {
            if (confirm(`هل أنت متأكد من إلغاء هذا التكليف للمستخدم ${userName}؟`)) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                
                fetch('/ManagementAssignments/RemoveAssignment', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ assignmentId: assignmentId })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('❌ فشل إلغاء التكليف: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('❌ حدث خطأ في إلغاء التكليف');
                });
            }
        }

    </script>
}
