@{
    
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card custom-card">
                <div class="custom-card-header">
                    <h4 class="mb-0">
                        <i class="bi bi-people-fill me-2"></i>
                        إضافة جمعية جديدة
                    </h4>
                    <p class="mb-0 mt-2 text-white-50">
                        أدخل اسم الجمعية فقط (باقي التفاصيل يضيفها المستخدم لاحقاً)
                    </p>
                </div>
                <div class="custom-card-body">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <div asp-validation-summary="ModelOnly"></div>
                            </div>
                        }

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">اسم الجمعية <span class="text-danger">*</span></label>
                            <input type="text" name="name" class="form-control"
                                   placeholder="مثال: جمعية خيرية، جمعية ثقافية..." required />
                            <small class="text-muted">اسماً فقط بدون تفاصيل إضافية</small>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> حفظ
                            </button>
                            <a href="@Url.Action("Associations")" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> إلغاء
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-card {
        border: none !important;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        border-radius: 15px !important;
        overflow: hidden !important;
    }

    .custom-card-header {
        background: linear-gradient(135deg, #ffc107, #fd7e14) !important;
        color: white !important;
        padding: 1.2rem 1.5rem !important;
        border-bottom: none !important;
    }

    .custom-card-body {
        padding: 2rem !important;
        background: white !important;
    }

    .text-white-50 {
        color: rgba(255, 255, 255, 0.8) !important;
    }

    .form-control {
        border-radius: 8px !important;
        border: 1px solid #ced4da !important;
        padding: 0.6rem 1rem !important;
        transition: all 0.2s !important;
    }

        .form-control:focus {
            border-color: #ffc107 !important;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25) !important;
            outline: none !important;
        }

    .form-label {
        color: #2c3e50 !important;
        font-weight: 600 !important;
        margin-bottom: 0.4rem !important;
    }

    .btn {
        padding: 0.6rem 1.5rem !important;
        font-weight: 600 !important;
        border-radius: 8px !important;
    }

    .btn-primary {
        background: linear-gradient(135deg, #ffc107, #fd7e14) !important;
        border: none !important;
        color: #2c3e50 !important;
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, #e0a800, #e96b0e) !important;
            transform: translateY(-2px) !important;
            box-shadow: 0 5px 15px rgba(255, 193, 7, 0.3) !important;
            color: #2c3e50 !important;
        }
</style>