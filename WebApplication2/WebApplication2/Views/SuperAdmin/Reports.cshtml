@model WebApplication2.Models.SuperAdminReportsViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "التقارير";
    ViewData["Icon"] = "bi bi-bar-chart-fill";
}

<style>
    .reports-page {
        direction: rtl;
    }

    .reports-toolbar,
    .report-options-panel {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 14px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.05);
        margin-bottom: 14px;
    }

    .report-card-option {
        min-height: 118px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
        padding: 13px;
        cursor: pointer;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
        position: relative;
        text-align: right;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .report-card-option:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
    }

    .report-card-option.selected {
        border-color: #1e3c72;
        background: #f8fbff;
        box-shadow: 0 8px 20px rgba(30, 60, 114, 0.14);
    }

    .report-card-option.selected::after {
        content: "✓";
        position: absolute;
        top: 10px;
        left: 10px;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #198754;
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 0.85rem;
        line-height: 1;
    }

    .report-icon {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 7px;
        color: #fff;
        font-size: 1.05rem;
        margin-bottom: 9px;
        flex: 0 0 auto;
    }

    .report-title {
        font-size: 0.95rem;
        font-weight: 800;
        color: #1f2937;
        line-height: 1.35;
        width: 100%;
        overflow-wrap: anywhere;
    }

    .report-description {
        color: #6b7280;
        font-size: 0.78rem;
        line-height: 1.45;
        margin-top: 4px;
        width: 100%;
        overflow-wrap: anywhere;
    }

    .option-group {
        border: 1px solid #e6ebf2;
        border-radius: 8px;
        padding: 12px;
        background: #fbfcfe;
    }

    .option-group:first-child {
        margin-top: 0;
    }

    .option-group-header {
        background: #fff;
        border: 1px solid #edf0f4;
        border-radius: 8px;
        padding: 10px 12px;
        margin-bottom: 12px;
    }

    .option-group-title {
        color: #1e3c72;
        font-weight: 800;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .option-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 10px;
    }

    .option-chip {
        border: 1px solid #dbe1ea;
        border-radius: 7px;
        padding: 9px 11px;
        background: #fff;
        font-size: 0.86rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        min-height: 40px;
        transition: border-color 0.2s ease, background 0.2s ease;
        overflow-wrap: anywhere;
    }

    .option-chip:hover {
        border-color: #1e3c72;
        background: #f8fbff;
    }

    .option-chip.option-all {
        background: #eef5ff;
        border-color: #b9d2f5;
        color: #1e3c72;
        font-weight: 800;
    }

    .option-chip input {
        margin: 0;
    }

    .date-filter-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 10px;
    }

    .date-filter-field {
        background: #fff;
        border: 1px solid #e6ebf2;
        border-radius: 8px;
        padding: 10px;
    }

    .date-filter-field label {
        color: #4b5563;
        font-size: 0.8rem;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .export-button {
        min-width: 180px;
    }

    .report-filters-modal .modal-dialog {
        max-width: 720px;
    }

    .report-filters-modal .modal-content {
        border: 0;
        border-radius: 8px;
    }

    .report-filters-modal .modal-body {
        max-height: min(68vh, 620px);
        overflow-y: auto;
    }

    @@media (max-width: 576px) {
        .report-card-option {
            min-height: 108px;
        }

        .option-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@Html.AntiForgeryToken()

<div class="reports-page">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["WarningMessage"] != null)
    {
        <div class="alert alert-warning">@TempData["WarningMessage"]</div>
    }

    <div class="reports-toolbar d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <div class="fw-bold text-dark">تفاصيل الاستمارة</div>
            <small class="text-muted">اختر نوع التقرير، ثم اختر القيم المطلوبة داخله أو اختر الكل.</small>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <button type="button" class="btn btn-outline-secondary btn-sm" id="clearReports">
                <i class="bi bi-x-circle"></i> مسح
            </button>
            <form asp-action="ExportReportsToExcel" method="post" id="reportsExportForm" class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="selectedFilters" id="selectedFiltersInput" />
                <button type="submit" class="btn btn-success export-button" id="exportReportsBtn" disabled>
                    <i class="bi bi-file-earmark-excel"></i>
                    تصدير
                    <span class="badge bg-light text-success ms-1" id="exportCount">0</span>
                </button>
            </form>
        </div>
    </div>

    <div class="row g-2 mb-3">
        @foreach (var card in Model.Cards)
        {
            <div class="col-xl-3 col-lg-4 col-md-4 col-sm-6">
                <button type="button"
                        class="report-card-option w-100"
                        data-key="@card.Key"
                        data-title="@card.Title"
                        aria-pressed="false">
                    <span class="report-icon bg-@card.Color"><i class="bi @card.Icon"></i></span>
                    <span class="d-block report-title">@card.Title</span>
                    <span class="d-block report-description">@card.Description</span>
                </button>
            </div>
        }
    </div>

    <div class="modal fade report-filters-modal" id="reportOptionsModal" tabindex="-1" aria-labelledby="reportOptionsModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="reportOptionsModalTitle">خيارات التقرير</h5>
                    <button type="button" class="btn-close m-0" data-bs-dismiss="modal" aria-label="إغلاق"></button>
                </div>
                <div class="modal-body" id="reportOptionsPanel"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const cards = Array.from(document.querySelectorAll('.report-card-option'));
            const panel = document.getElementById('reportOptionsPanel');
            const modalElement = document.getElementById('reportOptionsModal');
            const modalTitle = document.getElementById('reportOptionsModalTitle');
            const optionsModal = modalElement ? new bootstrap.Modal(modalElement) : null;
            const exportButton = document.getElementById('exportReportsBtn');
            const exportCount = document.getElementById('exportCount');
            const selectedInput = document.getElementById('selectedFiltersInput');
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const filters = new Map();
            let pendingRequest = null;

            function serializeFilters() {
                return Array.from(filters.entries()).map(([key, item]) => ({
                    key,
                    values: Array.from(item.values)
                }));
            }

            function syncHiddenInput() {
                selectedInput.value = JSON.stringify(serializeFilters());
            }

            async function updateExportState() {
                const payload = serializeFilters();
                syncHiddenInput();
                exportButton.disabled = payload.length === 0;

                if (payload.length === 0) {
                    exportCount.textContent = '0';
                    return;
                }

                if (pendingRequest) {
                    pendingRequest.abort();
                }

                pendingRequest = new AbortController();
                exportCount.textContent = '...';

                try {
                    const response = await fetch('@Url.Action("GetReportsExportCount", "SuperAdmin")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({ filters: payload }),
                        signal: pendingRequest.signal
                    });

                    const data = await response.json();
                    const count = data && data.success ? data.count : 0;
                    exportCount.textContent = count;
                    exportButton.disabled = count === 0;
                } catch (error) {
                    if (error.name !== 'AbortError') {
                        exportCount.textContent = '0';
                        exportButton.disabled = true;
                    }
                }
            }

            function updateCardState(key) {
                const card = cards.find(x => x.dataset.key === key);
                const selected = filters.has(key);
                card?.classList.toggle('selected', selected);
                card?.setAttribute('aria-pressed', selected ? 'true' : 'false');
            }

            function renderOptions(key, title, options) {
                if (!options.length) {
                    panel.innerHTML = `<div class="text-muted">لا توجد خيارات متوفرة لـ ${title}.</div>`;
                    return;
                }

                const current = filters.get(key)?.values || new Set();
                const allSelected = current.has('__all');
                const chips = options.map(option => {
                    const value = String(option.value || '');
                    const label = String(option.label || value);
                    const checked = allSelected || current.has(value);
                    return `
                        <label class="option-chip">
                            <input type="checkbox" class="report-option" data-key="${key}" value="${escapeHtml(value)}" ${checked ? 'checked' : ''} ${allSelected ? 'disabled' : ''}>
                            <span>${escapeHtml(label)}</span>
                        </label>`;
                }).join('');

                panel.innerHTML = `
                    <div class="option-group" data-group="${key}">
                        <div class="option-group-header d-flex flex-wrap align-items-center justify-content-between gap-2">
                            <div class="option-group-title"><i class="bi bi-filter-circle-fill"></i><span>${escapeHtml(title)}</span></div>
                            <label class="option-chip option-all m-0">
                                <input type="checkbox" class="report-option-all" data-key="${key}" ${allSelected ? 'checked' : ''}>
                                <span>الكل</span>
                            </label>
                        </div>
                        <div class="option-grid">${chips}</div>
                    </div>`;
            }

            function isDateFilter(key) {
                return key === 'birthDate' || key === 'affiliationDate';
            }

            function getDatePart(current, part) {
                const prefix = `${part}:`;
                const value = Array.from(current).find(item => item.startsWith(prefix));
                return value ? value.slice(prefix.length) : '';
            }

            function renderDateOptions(key, title) {
                const current = filters.get(key)?.values || new Set();
                const allSelected = current.has('__all');
                const exactDate = getDatePart(current, 'date');
                const selectedYear = getDatePart(current, 'year');
                const selectedMonth = getDatePart(current, 'month');
                const selectedDay = getDatePart(current, 'day');

                const monthOptions = Array.from({ length: 12 }, (_, index) => {
                    const value = String(index + 1).padStart(2, '0');
                    return `<option value="${value}" ${selectedMonth === value ? 'selected' : ''}>${value}</option>`;
                }).join('');

                const dayOptions = Array.from({ length: 31 }, (_, index) => {
                    const value = String(index + 1).padStart(2, '0');
                    return `<option value="${value}" ${selectedDay === value ? 'selected' : ''}>${value}</option>`;
                }).join('');

                panel.innerHTML = `
                    <div class="option-group" data-group="${key}">
                        <div class="option-group-header d-flex flex-wrap align-items-center justify-content-between gap-2">
                            <div class="option-group-title"><i class="bi bi-calendar-week-fill"></i><span>${escapeHtml(title)}</span></div>
                            <label class="option-chip option-all m-0">
                                <input type="checkbox" class="report-date-all" data-key="${key}" ${allSelected ? 'checked' : ''}>
                                <span>الكل</span>
                            </label>
                        </div>
                        <div class="date-filter-grid">
                            <div class="date-filter-field">
                                <label class="d-block">تاريخ كامل</label>
                                <input type="date" class="form-control report-date-exact" data-key="${key}" value="${escapeHtml(exactDate)}" ${allSelected ? 'disabled' : ''}>
                            </div>
                            <div class="date-filter-field">
                                <label class="d-block">السنة</label>
                                <input type="number" class="form-control report-date-part" data-key="${key}" data-part="year" min="1900" max="2100" placeholder="مثال: 1990" value="${escapeHtml(selectedYear)}" ${allSelected ? 'disabled' : ''}>
                            </div>
                            <div class="date-filter-field">
                                <label class="d-block">الشهر</label>
                                <select class="form-select report-date-part" data-key="${key}" data-part="month" ${allSelected ? 'disabled' : ''}>
                                    <option value="">أي شهر</option>
                                    ${monthOptions}
                                </select>
                            </div>
                            <div class="date-filter-field">
                                <label class="d-block">اليوم</label>
                                <select class="form-select report-date-part" data-key="${key}" data-part="day" ${allSelected ? 'disabled' : ''}>
                                    <option value="">أي يوم</option>
                                    ${dayOptions}
                                </select>
                            </div>
                        </div>
                    </div>`;
            }

            async function loadOptions(card) {
                const key = card.dataset.key;
                const title = card.dataset.title;
                modalTitle.textContent = title || 'خيارات التقرير';

                if (isDateFilter(key)) {
                    renderDateOptions(key, title);
                    return;
                }

                panel.innerHTML = `<div class="text-muted">جاري تحميل خيارات ${escapeHtml(title)}...</div>`;

                const response = await fetch(`@Url.Action("GetReportFilterOptions", "SuperAdmin")?key=${encodeURIComponent(key)}`);
                const data = await response.json();
                renderOptions(key, title, data && data.success ? data.data : []);
            }

            cards.forEach(card => {
                card.addEventListener('click', async () => {
                    panel.innerHTML = '';
                    optionsModal?.show();
                    await loadOptions(card);
                });
            });

            function applyDateFilter(target) {
                const key = target.dataset.key;
                if (!key || !isDateFilter(key)) return false;

                if (!filters.has(key)) {
                    filters.set(key, { values: new Set() });
                }

                const current = filters.get(key).values;

                if (target.classList.contains('report-date-all')) {
                    current.clear();
                    if (target.checked) {
                        current.add('__all');
                    }
                    panel.querySelectorAll(`.report-date-exact[data-key="${key}"], .report-date-part[data-key="${key}"]`).forEach(input => {
                        input.disabled = target.checked;
                        if (target.checked) input.value = '';
                    });
                }

                if (target.classList.contains('report-date-exact')) {
                    current.clear();
                    if (target.value) {
                        current.add(`date:${target.value}`);
                    }
                    panel.querySelectorAll(`.report-date-part[data-key="${key}"]`).forEach(input => {
                        input.value = '';
                    });
                    const allInput = panel.querySelector(`.report-date-all[data-key="${key}"]`);
                    if (allInput) allInput.checked = false;
                }

                if (target.classList.contains('report-date-part')) {
                    current.delete('__all');
                    Array.from(current)
                        .filter(item => item.startsWith('date:') || item.startsWith(`${target.dataset.part}:`))
                        .forEach(item => current.delete(item));

                    if (target.value) {
                        current.add(`${target.dataset.part}:${target.value}`);
                    }

                    const exactInput = panel.querySelector(`.report-date-exact[data-key="${key}"]`);
                    if (exactInput) exactInput.value = '';

                    const allInput = panel.querySelector(`.report-date-all[data-key="${key}"]`);
                    if (allInput) allInput.checked = false;
                }

                if (current.size === 0) {
                    filters.delete(key);
                }

                updateCardState(key);
                updateExportState();
                return true;
            }

            panel.addEventListener('change', event => {
                const target = event.target;
                const key = target.dataset.key;
                if (!key) return;

                if (applyDateFilter(target)) return;

                if (!filters.has(key)) {
                    filters.set(key, { values: new Set() });
                }

                const current = filters.get(key).values;

                if (target.classList.contains('report-option-all')) {
                    current.clear();
                    if (target.checked) {
                        current.add('__all');
                    }
                    panel.querySelectorAll(`.report-option[data-key="${key}"]`).forEach(input => {
                        input.checked = target.checked;
                        input.disabled = target.checked;
                    });
                }

                if (target.classList.contains('report-option')) {
                    current.delete('__all');
                    if (target.checked) {
                        current.add(target.value);
                    } else {
                        current.delete(target.value);
                    }
                    const allInput = panel.querySelector(`.report-option-all[data-key="${key}"]`);
                    if (allInput) allInput.checked = false;
                }

                if (current.size === 0) {
                    filters.delete(key);
                }

                updateCardState(key);
                updateExportState();
            });

            panel.addEventListener('input', event => {
                applyDateFilter(event.target);
            });

            document.getElementById('clearReports')?.addEventListener('click', () => {
                filters.clear();
                cards.forEach(card => {
                    card.classList.remove('selected');
                    card.setAttribute('aria-pressed', 'false');
                });
                panel.innerHTML = '';
                optionsModal?.hide();
                updateExportState();
            });

            function escapeHtml(value) {
                return String(value)
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#039;');
            }
        })();
    </script>
}
