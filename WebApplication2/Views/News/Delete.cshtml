@model WebApplication2.Models.News
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    

    // جلب اسم الكاتب إذا كان معرف الكاتب موجوداً
    string authorName = "غير معروف";
    if (!string.IsNullOrEmpty(Model.AuthorId))
    {
        var author = await UserManager.FindByIdAsync(Model.AuthorId);
        if (author != null)
        {
            authorName = author.UserName ?? author.Email;
        }
    }
}

<style>
    /* تحسينات التصميم - نفس ألوان الصفحات السابقة */
    .card {
        border-radius: 20px !important;
        overflow: hidden;
        transition: transform 0.3s ease;
        border: none !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(30, 60, 114, 0.15) !important;
        }

    .card-header {
        background: linear-gradient(135deg, #1e3c72, #2a5a9c) !important;
        padding: 1.5rem 2rem !important;
        border: none !important;
    }

        .card-header h4 {
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            color: white;
        }

        .card-header i {
            font-size: 2rem;
            background: rgba(255,255,255,0.2);
            padding: 10px;
            border-radius: 12px;
            color: white;
        }

    .card-body {
        padding: 2rem !important;
        background: #ffffff;
    }

    /* تحسين تحذير الحذف */
    .alert-danger {
        background: linear-gradient(135deg, #fee2e2, #fecaca) !important;
        border: none !important;
        border-radius: 20px !important;
        padding: 1.5rem !important;
        border-right: 6px solid #1e3c72 !important;
    }

        .alert-danger i {
            color: #1e3c72;
            font-size: 3rem;
        }

        .alert-danger h5 {
            color: #1e3c72;
            font-weight: 700;
        }

        .alert-danger p {
            color: #2c3e50;
        }

    /* تحسين بطاقة معلومات الخبر */
    .card.mb-4 {
        border: 1px solid #e2e8f0 !important;
        border-radius: 20px !important;
        overflow: hidden;
    }

    .card-header.bg-light {
        background: linear-gradient(135deg, #f8fafc, #f1f5f9) !important;
        border-bottom: 2px solid #e2e8f0 !important;
    }

        .card-header.bg-light h5 {
            color: #1e3c72;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .card-header.bg-light h5::before {
                content: '📰';
                font-size: 1.2rem;
            }

    /* تحسين الصورة */
    .col-md-3 img {
        border-radius: 16px !important;
        width: 100%;
        height: 150px;
        object-fit: cover;
        border: 3px solid #ffffff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: transform 0.3s;
    }

        .col-md-3 img:hover {
            transform: scale(1.05);
        }

    .bg-light.rounded {
        background: linear-gradient(135deg, #f8fafc, #f1f5f9) !important;
        border: 2px dashed #cbd5e1;
        padding: 2rem !important;
    }

        .bg-light.rounded i {
            color: #94a3b8;
        }

    /* تحسين عنوان الخبر */
    .text-primary {
        color: #1e3c72 !important;
        font-size: 1.4rem !important;
        font-weight: 700;
        margin-bottom: 0.8rem;
    }

    .text-muted {
        color: #64748b !important;
        line-height: 1.6;
        font-size: 1rem;
        background: #f8fafc;
        padding: 1rem;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
    }

    /* تحسين صف المعلومات */
    .row.mt-3 {
        margin-top: 1.5rem !important;
    }

        .row.mt-3 p {
            background: #f8fafc;
            padding: 1rem;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            margin-bottom: 0;
        }

        .row.mt-3 strong {
            color: #1e3c72;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
            margin-bottom: 0.5rem;
        }

            .row.mt-3 strong i {
                font-size: 1.1rem;
                color: #1e3c72;
                background: #ffffff;
                padding: 6px;
                border-radius: 8px;
            }

    /* بادج الكاتب */
    .author-badge {
        background: linear-gradient(135deg, #1e3c72, #2a5a9c);
        color: white;
        padding: 0.3rem 1rem;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 0.5rem;
    }

    /* تحسين أزرار الحذف */
    .d-flex.gap-2.justify-content-center {
        gap: 1rem !important;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .btn {
        border-radius: 50px !important;
        padding: 1rem 2.5rem !important;
        font-weight: 700 !important;
        transition: all 0.3s !important;
        border: none !important;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 1.1rem;
        min-width: 220px;
        justify-content: center;
    }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2) !important;
        }

    .btn-danger {
        background: linear-gradient(135deg, #dc2626, #b91c1c) !important;
    }

    .btn-secondary {
        background: linear-gradient(135deg, #1e3c72, #2a5a9c) !important;
    }

    /* تحسين النص السفلي */
    .text-center.mt-3 small {
        color: #64748b;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f8fafc;
        padding: 0.5rem 1.5rem;
        border-radius: 50px;
        border: 1px solid #e2e8f0;
    }

        .text-center.mt-3 small i {
            color: #1e3c72;
        }

    /* تحسينات الموبايل */
    @@media (max-width: 768px) {
        .card-header h4 {
            font-size: 1.4rem;
        }

        .card-body {
            padding: 1.5rem !important;
        }

        .d-flex.gap-2.justify-content-center {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            padding: 0.8rem !important;
            font-size: 1rem;
        }

        .row {
            flex-direction: column;
        }

        .col-md-3, .col-md-6, .col-md-9 {
            width: 100%;
            margin-bottom: 1rem;
        }

        .alert-danger .d-flex {
            flex-direction: column;
            text-align: center;
        }

        .alert-danger i {
            margin: 0 0 1rem 0 !important;
        }
    }
</style>

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="bi bi-exclamation-triangle me-2"></i> تأكيد حذف الخبر
            </h4>
        </div>

        <div class="card-body">
            <!-- تحذير -->
            <div class="alert alert-danger mb-4">
                <div class="d-flex">
                    <i class="bi bi-exclamation-circle display-6 me-3"></i>
                    <div>
                        <h5 class="alert-heading">تحذير هام!</h5>
                        <p class="mb-0">
                            أنت على وشك حذف الخبر التالي. هذا الإجراء <strong>لا يمكن التراجع عنه</strong>.
                            سيتم حذف الخبر وكل البيانات المرتبطة به بما في ذلك الصورة.
                        </p>
                    </div>
                </div>
            </div>

            <!-- معلومات الخبر -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">معلومات الخبر المراد حذفه</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" class="img-fluid rounded" />
                            }
                            else
                            {
                                <div class="text-center py-4 bg-light rounded">
                                    <i class="bi bi-image text-muted display-6"></i>
                                    <p class="mt-2">لا توجد صورة</p>
                                </div>
                            }
                        </div>
                        <div class="col-md-9">
                            <h5 class="text-primary">@Model.Title</h5>
                            <p class="text-muted">
                                @(Model.Content.Length > 150 ? Model.Content.Substring(0, 150) + "..." : Model.Content)
                            </p>

                            <div class="row mt-3">
                                <div class="col-md-6">
                                    <p>
                                        <strong><i class="bi bi-calendar"></i> تاريخ الإنشاء:</strong><br />
                                        <span class="text-muted">
                                            <i class="bi bi-calendar3 ms-1"></i> @Model.CreatedAt.ToString("yyyy/MM/dd")
                                            <i class="bi bi-clock ms-2"></i> @Model.CreatedAt.ToString("HH:mm")
                                        </span>
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    <p>
                                        <strong><i class="bi bi-hash"></i> رقم الخبر:</strong><br />
                                        <span class="text-muted">#@Model.Id</span>
                                    </p>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.AuthorId))
                                {
                                    <div class="col-md-12 mt-2">
                                        <p>
                                            <strong><i class="bi bi-person"></i> الكاتب:</strong><br />
                                            <span class="author-badge">
                                                <i class="bi bi-pencil-fill"></i>
                                                @authorName
                                            </span>
                                        </p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- نموذج الحذف -->
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex gap-2 justify-content-center">
                    <button type="submit" class="btn btn-danger btn-lg px-5">
                        <i class="bi bi-trash me-2"></i> نعم، احذف الخبر
                    </button>
                    <a asp-action="Index" asp-route-id="@Model.Id" class="btn btn-secondary btn-lg">
                        <i class="bi bi-arrow-left me-2"></i> لا، إلغاء والعودة
                    </a>
                </div>

                <div class="text-center mt-3">
                    <small class="text-muted">
                        <i class="bi bi-lightbulb"></i> يمكنك الضغط على "إلغاء" للرجوع أو "نعم، احذف" للتأكيد
                    </small>
                </div>
            </form>
        </div>
    </div>
</div>