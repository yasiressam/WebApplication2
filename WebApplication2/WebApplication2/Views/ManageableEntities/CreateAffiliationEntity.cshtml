@{
    ViewData["Title"] = "إضافة جهة انتساب";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-building-add"></i> إضافة جهة انتساب جديدة</h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <form asp-action="CreateAffiliationEntity" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-bold">جهة الانتساب</label>
                            <input type="text" name="name" class="form-control form-control-lg"
                                   placeholder="مثال: وزارة التربية" required autofocus />
                            <small class="form-text text-muted">أدخل اسم جهة الانتساب الجديدة</small>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("AffiliationEntities")" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> إلغاء
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> إنشاء
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>