<div id="cropModal" class="cropper-modal-overlay">
    <div class="cropper-container-custom">
        <div class="cropper-instruction">
            <i class="bi bi-arrows-move"></i>
            اسحب وحدد الجزء المطلوب، ويمكنك التكبير بعجلة الماوس
        </div>
        <div class="cropper-image-stage">
            <img id="cropImage" src="" alt="قص الصورة">
        </div>
        <div class="cropper-buttons">
            <button type="button" class="btn-crop-save" onclick="saveCroppedImage()">
                <i class="bi bi-check-circle"></i>
                حفظ الصورة
            </button>
            <button type="button" class="btn-crop-cancel" onclick="closeCropModal()">
                <i class="bi bi-x-circle"></i>
                إلغاء
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let cropper = null;
        let currentImageFile = null;

        // toggle sections
        function toggleSection(element) {
            const body = element.nextElementSibling;
            const icon = element.querySelector('.toggle-icon');
            
            if (body.classList.contains('collapsed')) {
                body.classList.remove('collapsed');
                icon.classList.remove('collapsed');
                icon.classList.replace('bi-chevron-down', 'bi-chevron-up');
            } else {
                body.classList.add('collapsed');
                icon.classList.add('collapsed');
                icon.classList.replace('bi-chevron-up', 'bi-chevron-down');
            }
        }

        function openCropModal() {
            document.getElementById('CoverImageFile')?.click();
        }

        function renderProfileImage(imageSrc) {
            const container = document.getElementById('imagePreview');
            if (!container) return;

            container.innerHTML = '<img src="' + imageSrc + '" class="profile-image-preview" id="profileImage" alt="الصورة الشخصية">';
        }

        document.getElementById('CoverImageFile')?.addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (!file) return;

            const allowedExtensions = ['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp'];
            const fileExtension = (file.name.split('.').pop() || '').toLowerCase();
            if (!allowedExtensions.includes(fileExtension)) {
                alert('صيغة الملف غير مدعومة. الصيغ المسموحة: jpg, png, gif, webp');
                this.value = '';
                return;
            }

            const maxSize = 5 * 1024 * 1024;
            if (file.size > maxSize) {
                alert('حجم الصورة كبير جداً. الحد الأقصى 5MB');
                this.value = '';
                return;
            }

            currentImageFile = file;
            const reader = new FileReader();
            reader.onload = function (event) {
                const cropImage = document.getElementById('cropImage');
                const modal = document.getElementById('cropModal');
                if (!cropImage || !modal) return;

                cropImage.src = event.target.result;
                modal.classList.add('active');

                setTimeout(() => {
                    if (cropper) {
                        cropper.destroy();
                    }

                    cropper = new Cropper(cropImage, {
                        aspectRatio: 1,
                        viewMode: 1,
                        dragMode: 'move',
                        cropBoxMovable: true,
                        cropBoxResizable: true,
                        zoomable: true,
                        zoomOnWheel: true,
                        autoCropArea: 1,
                        background: true,
                        guides: true,
                        responsive: true,
                        restore: false,
                        center: true
                    });
                }, 100);
            };

            reader.readAsDataURL(file);
        });

        function saveCroppedImage() {
            if (!cropper || !currentImageFile) return;

            const canvas = cropper.getCroppedCanvas({
                width: 500,
                height: 500,
                imageSmoothingEnabled: true,
                imageSmoothingQuality: 'high'
            });

            if (!canvas) {
                alert('حدث خطأ أثناء معالجة الصورة');
                return;
            }

            canvas.toBlob(function (blob) {
                if (!blob) {
                    alert('تعذر حفظ الصورة بعد القص');
                    return;
                }

                const croppedFile = new File([blob], currentImageFile.name, {
                    type: currentImageFile.type,
                    lastModified: Date.now()
                });

                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(croppedFile);

                const fileInput = document.getElementById('CoverImageFile');
                if (fileInput) {
                    fileInput.files = dataTransfer.files;
                }

                const reader = new FileReader();
                reader.onload = function (event) {
                    renderProfileImage(event.target.result);
                };
                reader.readAsDataURL(blob);

                closeCropModal();
            }, currentImageFile.type, 1);
        }

        function closeCropModal() {
            document.getElementById('cropModal')?.classList.remove('active');

            if (cropper) {
                cropper.destroy();
                cropper = null;
            }
        }

        // نفس منطق BasicInfo للتحصيل الدراسي وحقول الطالب الجامعي
        const educationSelect = document.getElementById('EducationLevel');
        if (educationSelect) {
            function toggleStudentFields() {
                const universityFields = document.getElementById('UniversityFields');
                const specializationField = document.getElementById('PersonalInfo_Specialization');
                const universityTypeField = document.getElementById('PersonalInfo_UniversityType');
                const institutionTypeField = document.getElementById('PersonalInfo_InstitutionType');
                const institutionNameField = document.getElementById('PersonalInfo_InstitutionName');
                const facultyDepartmentField = document.getElementById('PersonalInfo_FacultyDepartment');
                const studyTypeField = document.getElementById('PersonalInfo_StudyType');
                const studyStageField = document.getElementById('PersonalInfo_StudyStage');
                const educationLevel = educationSelect.value;

                if (specializationField) {
                    if (educationLevel === 'آمي' || educationLevel === 'ابتدائي' || educationLevel === 'متوسط') {
                        specializationField.value = educationLevel;
                        specializationField.setAttribute('readonly', 'readonly');
                    } else {
                        if (specializationField.value === 'آمي' || specializationField.value === 'ابتدائي' || specializationField.value === 'متوسط') {
                            specializationField.value = '';
                        }

                        specializationField.removeAttribute('readonly');
                    }
                }

                if (!universityFields) return;

                if (educationLevel === 'طالب جامعي') {
                    universityFields.style.display = 'flex';
                    universityFields.style.flexWrap = 'wrap';
                    universityTypeField?.setAttribute('required', 'required');
                    institutionTypeField?.setAttribute('required', 'required');
                    institutionNameField?.setAttribute('required', 'required');
                    facultyDepartmentField?.setAttribute('required', 'required');
                    studyTypeField?.setAttribute('required', 'required');
                    studyStageField?.setAttribute('required', 'required');
                } else {
                    universityFields.style.display = 'none';
                    universityTypeField?.removeAttribute('required');
                    institutionTypeField?.removeAttribute('required');
                    institutionNameField?.removeAttribute('required');
                    facultyDepartmentField?.removeAttribute('required');
                    studyTypeField?.removeAttribute('required');
                    studyStageField?.removeAttribute('required');
                }
            }

            educationSelect.addEventListener('change', toggleStudentFields);
            toggleStudentFields();
        }

        // نفس منطق BasicInfo للحالة الوظيفية
        const employmentSelect = document.getElementById('EmploymentStatus');
        if (employmentSelect) {
            function updateEmploymentValidationRules() {
                const employmentStatus = employmentSelect.value;
                const ministryField = document.getElementById('Employment_Ministry');
                const departmentField = document.getElementById('Employment_Department');
                const positionField = document.getElementById('Employment_Position');
                const jobTitleField = document.getElementById('Employment_JobTitle');
                const jobGradeField = document.getElementById('Employment_JobGrade');

                if (employmentStatus === 'موظف') {
                    ministryField?.setAttribute('required', 'required');
                    departmentField?.setAttribute('required', 'required');
                    positionField?.setAttribute('required', 'required');
                    jobTitleField?.setAttribute('required', 'required');
                    jobGradeField?.setAttribute('required', 'required');
                } else {
                    ministryField?.removeAttribute('required');
                    departmentField?.removeAttribute('required');
                    positionField?.removeAttribute('required');
                    jobTitleField?.removeAttribute('required');
                    jobGradeField?.removeAttribute('required');
                }
            }

            function toggleEmploymentFields() {
                const ministryDiv = document.getElementById('MinistryDiv');
                const departmentDiv = document.getElementById('DepartmentDiv');
                const positionDiv = document.getElementById('PositionDiv');
                const jobTitleDiv = document.getElementById('JobTitleDiv');
                const jobGradeDiv = document.getElementById('JobGradeDiv');
                const workField = document.getElementById('Employment_Work');
                const employmentStatus = employmentSelect.value;

                if (workField) {
                    if (employmentStatus === 'موظف' || employmentStatus === 'متقاعد' || employmentStatus === 'طالب') {
                        workField.value = employmentStatus;
                        workField.setAttribute('readonly', 'readonly');
                    } else {
                        if (workField.value === 'موظف' || workField.value === 'متقاعد' || workField.value === 'طالب') {
                            workField.value = '';
                        }

                        workField.removeAttribute('readonly');
                    }
                }
                
                if (employmentStatus === 'موظف') {
                    if (ministryDiv) ministryDiv.style.display = 'block';
                    if (departmentDiv) departmentDiv.style.display = 'block';
                    if (positionDiv) positionDiv.style.display = 'block';
                    if (jobTitleDiv) jobTitleDiv.style.display = 'block';
                    if (jobGradeDiv) jobGradeDiv.style.display = 'block';
                } else {
                    if (ministryDiv) ministryDiv.style.display = 'none';
                    if (departmentDiv) departmentDiv.style.display = 'none';
                    if (positionDiv) positionDiv.style.display = 'none';
                    if (jobTitleDiv) jobTitleDiv.style.display = 'none';
                    if (jobGradeDiv) jobGradeDiv.style.display = 'none';
                }

                updateEmploymentValidationRules();
            }

            employmentSelect.addEventListener('change', toggleEmploymentFields);
            toggleEmploymentFields();
        }

               // ========== دوال تحميل مستويات الاتحاد (محسنة) ==========

        function loadFederationDivisions(federationName, savedDivision = null, savedSection = null, savedGroup = null) {
            $('#FederationDivisionName').prop('disabled', true).html('<option value="">جاري التحميل...</option>');
            $('#FederationSectionName').prop('disabled', true).html('<option value="">-- اختر الشعبة --</option>');
            $('#FederationGroupName').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
    
            $.ajax({
                url: '@Url.Action("GetFederationDivisionsByFederationName", "PublicData")',
                type: 'GET',
                data: { federationName: federationName },
                success: function(response) {
                    let options = '<option value="">-- اختر القسم --</option>';
                    if (response.data && response.data.length > 0) {
                        response.data.forEach(function(div) {
                            let selected = (savedDivision === div.name) ? 'selected' : '';
                            options += `<option value="${div.name}" ${selected}>${div.name}</option>`;
                        });
                        $('#FederationDivisionName').prop('disabled', false);
                    } else {
                        options += '<option value="" disabled>لا توجد أقسام</option>';
                    }
                    $('#FederationDivisionName').html(options);
            
                    // إذا كان هناك قسم محفوظ، قم بتحميل الشعب
                    if (savedDivision && savedDivision !== '') {
                        loadFederationSections(savedDivision, savedSection, savedGroup);
                    }
                },
                error: function() {
                    $('#FederationDivisionName').html('<option value="">حدث خطأ</option>');
                }
            });
        }

        function loadFederationSections(divisionName, savedSection = null, savedGroup = null) {
            $('#FederationSectionName').prop('disabled', true).html('<option value="">جاري التحميل...</option>');
            $('#FederationGroupName').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
    
            if (!divisionName) {
                $('#FederationSectionName').prop('disabled', true).html('<option value="">-- اختر الشعبة --</option>');
                return;
            }
    
            var federationName = $('#FederationMasterName').val();
    
            $.ajax({
                url: '@Url.Action("GetFederationSectionsByDivisionName", "PublicData")',
                type: 'GET',
                data: {
                    federationName: federationName,
                    divisionName: divisionName
                },
                success: function(response) {
                    if (response.success && response.data && response.data.length > 0) {
                        let options = '<option value="">-- اختر الشعبة --</option>';
                        response.data.forEach(function(sec) {
                            let selected = (savedSection === sec.name) ? 'selected' : '';
                            options += `<option value="${sec.name}" ${selected}>${sec.name}</option>`;
                        });
                        $('#FederationSectionName').html(options).prop('disabled', false);
                
                        // إذا كانت هناك شعبة محفوظة، قم بتحميل التجمعات
                        if (savedSection && savedSection !== '') {
                            loadFederationGroups(savedSection, savedGroup);
                        }
                    } else {
                        $('#FederationSectionName').html('<option value="">لا توجد شعب</option>').prop('disabled', true);
                        $('#FederationGroupName').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                    }
                },
                error: function() {
                    $('#FederationSectionName').html('<option value="">حدث خطأ</option>').prop('disabled', true);
                }
            });
        }

                                   function loadFederationGroups(sectionName, savedGroup = null) {
            const groupSelect = $('#FederationGroupName');
            groupSelect.prop('disabled', true).html('<option value="">جاري التحميل...</option>');
    
            if (!sectionName) {
                groupSelect.prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                return;
            }
    
            var federationName = $('#FederationMasterName').val();
            var divisionName = $('#FederationDivisionName').val();
    
            console.log('🔍 إرسال طلب لتجمعات الاتحاد:', { federationName, divisionName, sectionName });
    
            $.ajax({
                url: '@Url.Action("GetFederationGroupsBySectionName", "PublicData")',
                type: 'GET',
                data: {
                    federationName: federationName,
                    divisionName: divisionName,
                    sectionName: sectionName
                },
                success: function(response) {
                    console.log('📡 استجابة تجمعات الاتحاد:', response);
                    console.log('📡 response.data:', response.data);
                    console.log('📡 response.data.length:', response.data ? response.data.length : 'null');
            
                    let options = '';
            
                    if (response.data && Array.isArray(response.data) && response.data.length > 0) {
                        options = '<option value="">-- اختر الوحدة --</option>';
                        for (let i = 0; i < response.data.length; i++) {
                            let selected = (savedGroup === response.data[i].name) ? 'selected' : '';
                            options += `<option value="${response.data[i].name}" ${selected}>${response.data[i].name}</option>`;
                        }
                        groupSelect.prop('disabled', false);
                        console.log('✅ تم تحميل ' + response.data.length + ' تجمعات');
                    } else {
                        // ✅ رسالة واضحة
                        options = '<option value="" disabled selected> لا توجد وحدات </option>';
                        groupSelect.prop('disabled', true);
                        console.log('⚠️ لا توجد تجمعات لهذه الشعبة في الاتحاد');
                    }
                    groupSelect.html(options);
                },
                error: function(xhr, status, error) {
                    console.error('❌ خطأ في تحميل تجمعات الاتحاد:', error);
                    console.error('❌ Status:', status);
                    console.error('❌ Response:', xhr.responseText);
                    groupSelect.html('<option value="">حدث خطأ في التحميل</option>');
                }
            });
        }
        
        function updateFederationFullName() {
            var masterName = $('#FederationMasterName').val();
            var divisionName = $('#FederationDivisionName').val();
            var sectionName = $('#FederationSectionName').val();
            var groupName = $('#FederationGroupName').val();
            
            var fullName = '';
            if (masterName) fullName = masterName;
            if (divisionName) fullName += ' - ' + divisionName;
            if (sectionName) fullName += ' - ' + sectionName;
            if (groupName) fullName += ' - ' + groupName;
            
            $('#FederationFullName').val(fullName);
        }

        function toggleWorkDistrictField() {
            const workGovernorateSelect = document.getElementById('WorkGovernorateSelect');
            if (!workGovernorateSelect) return;
        }

                // ========== دوال الـ Cascading Dropdown للانتساب (باستخدام PublicDataController) ==========
        function loadDivisions(entityName, savedDivision = null) {
            const divisionSelect = $('#Affiliation_Division');
            divisionSelect.prop('disabled', true).html('<option value="">جاري التحميل...</option>');
    
            $.ajax({
                url: '@Url.Action("GetDivisionsByEntityName", "PublicData")',
                type: 'GET',
                data: { entityName: entityName },
                success: function(response) {
                    let options = '<option value="">-- اختر القسم --</option>';
                    if (response.data && response.data.length > 0) {
                        response.data.forEach(function(div) {
                            let selected = (savedDivision === div.name) ? 'selected' : '';
                            options += `<option value="${div.name}" ${selected}>${div.name}</option>`;
                        });
                        divisionSelect.prop('disabled', false);
                    } else {
                        options += '<option value="" disabled>لا توجد أقسام</option>';
                    }
                    divisionSelect.html(options);
            
                    $('#Affiliation_Section').prop('disabled', true).html('<option value="">-- اختر الشعبة --</option>');
                    $('#Affiliation_Group').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                },
                error: function() {
                    divisionSelect.html('<option value="">حدث خطأ</option>');
                }
            });
        }

        function loadSections(divisionName, savedSection = null) {
            const sectionSelect = $('#Affiliation_Section');
            sectionSelect.prop('disabled', true).html('<option value="">جاري التحميل...</option>');
    
            var entityName = $('#Affiliation_AffiliationEntity').val();
    
            $.ajax({
                url: '@Url.Action("GetSectionsByDivisionName", "PublicData")',
                type: 'GET',
                data: {
                    entityName: entityName,
                    divisionName: divisionName
                },
                success: function(response) {
                    let options = '<option value="">-- اختر الشعبة --</option>';
                    if (response.data && response.data.length > 0) {
                        response.data.forEach(function(sec) {
                            let selected = (savedSection === sec.name) ? 'selected' : '';
                            options += `<option value="${sec.name}" ${selected}>${sec.name}</option>`;
                        });
                        sectionSelect.prop('disabled', false);
                    } else {
                        options += '<option value="" disabled>لا توجد شعب</option>';
                    }
                    sectionSelect.html(options);
            
                    $('#Affiliation_Group').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                },
                error: function() {
                    sectionSelect.html('<option value="">حدث خطأ</option>');
                }
            });
        }
                      function loadGroups(sectionName, savedGroup = null) {
            const groupSelect = $('#Affiliation_Group');
            groupSelect.prop('disabled', true).html('<option value="">جاري التحميل...</option>');
    
            var entityName = $('#Affiliation_AffiliationEntity').val();
            var divisionName = $('#Affiliation_Division').val();
    
            console.log('🔍 إرسال طلب للتجمعات:', { entityName, divisionName, sectionName });
    
            $.ajax({
                url: '@Url.Action("GetGroupsBySectionName", "PublicData")',
                type: 'GET',
                data: {
                    entityName: entityName,
                    divisionName: divisionName,
                    sectionName: sectionName
                },
                success: function(response) {
                    console.log('📡 الاستجابة من الخادم:', response);
                    console.log('📡 response.data:', response.data);
                    console.log('📡 typeof response.data:', typeof response.data);
                    console.log('📡 response.data.length:', response.data ? response.data.length : 'null');
            
                    let options = '';
            
                    // التحقق من وجود بيانات
                    if (response.data && Array.isArray(response.data) && response.data.length > 0) {
                        options = '<option value="">-- اختر الوحدة --</option>';
                        for (let i = 0; i < response.data.length; i++) {
                            let selected = (savedGroup === response.data[i].name) ? 'selected' : '';
                            options += `<option value="${response.data[i].name}" ${selected}>${response.data[i].name}</option>`;
                        }
                        groupSelect.prop('disabled', false);
                        console.log('✅ تم تحميل ' + response.data.length + ' تجمعات');
                    } else {
                        // ✅ رسالة واضحة
                        options = '<option value="" disabled selected> لا توجد وحدات </option>';
                        groupSelect.prop('disabled', true);
                        console.log('⚠️ لا توجد تجمعات');
                    }
                    groupSelect.html(options);
                },
                error: function(xhr, status, error) {
                    console.error('❌ خطأ في Ajax:', error);
                    console.error('❌ Status:', status);
                    console.error('❌ Response:', xhr.responseText);
                    groupSelect.html('<option value="">حدث خطأ في التحميل</option>');
                }
            });
        }
               
        
        // ========== ربط الأحداث ==========
        $(document).ready(function() {
            $('#WorkGovernorateSelect').change(toggleWorkDistrictField);
            toggleWorkDistrictField();

            // أحداث الاتحاد
            $('#FederationMasterName').change(function() {
                var federationName = $(this).val();
                if (federationName) {
                    loadFederationDivisions(federationName);
                } else {
                    $('#FederationDivisionName').prop('disabled', true).html('<option value="">-- اختر القسم --</option>');
                    $('#FederationSectionName').prop('disabled', true).html('<option value="">-- اختر الشعبة --</option>');
                    $('#FederationGroupName').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                }
                updateFederationFullName();
            });
            
            $('#FederationDivisionName').change(function() {
                var divisionName = $(this).val();
                if (divisionName) {
                    loadFederationSections(divisionName);
                } else {
                    $('#FederationSectionName').prop('disabled', true).html('<option value="">-- اختر الشعبة --</option>');
                    $('#FederationGroupName').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                }
                updateFederationFullName();
            });
            
            $('#FederationSectionName').change(function() {
                var sectionName = $(this).val();
                if (sectionName) {
                    loadFederationGroups(sectionName);
                } else {
                    $('#FederationGroupName').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                }
                updateFederationFullName();
            });
            
            $('#FederationGroupName').change(function() {
                updateFederationFullName();
            });
            
            // أحداث جهة الانتساب
            $('#Affiliation_AffiliationEntity').change(function() {
                var entityName = $(this).val();
                if (entityName) {
                    loadDivisions(entityName);
                } else {
                    $('#Affiliation_Division').prop('disabled', true).html('<option value="">-- اختر القسم --</option>');
                    $('#Affiliation_Section').prop('disabled', true).html('<option value="">-- اختر الشعبة --</option>');
                    $('#Affiliation_Group').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                }
            });
            
            $('#Affiliation_Division').change(function() {
                var divisionName = $(this).val();
                if (divisionName) {
                    loadSections(divisionName);
                } else {
                    $('#Affiliation_Section').prop('disabled', true).html('<option value="">-- اختر الشعبة --</option>');
                    $('#Affiliation_Group').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                }
            });
            
            $('#Affiliation_Section').change(function() {
                var sectionName = $(this).val();
                if (sectionName) {
                    loadGroups(sectionName);
                } else {
                    $('#Affiliation_Group').prop('disabled', true).html('<option value="">-- اختر الوحدة --</option>');
                }
            });
            
                    // استعادة القيم المحفوظة للاتحاد (محسنة)
        var savedFederationFullName = $('#FederationFullName').val();
        if (savedFederationFullName && savedFederationFullName !== '') {
            var parts = savedFederationFullName.split(' - ');
            console.log('🔄 استعادة بيانات الاتحاد:', parts);
    
            if (parts.length >= 1 && parts[0] && parts[0] !== '') {
                $('#FederationMasterName').val(parts[0]);
        
                if (parts.length >= 2 && parts[1] && parts[1] !== '') {
                    // تحميل الأقسام ثم تعيين القيمة
                    loadFederationDivisions(parts[0], parts[1], parts.length >= 3 ? parts[2] : null, parts.length >= 4 ? parts[3] : null);
            
                    if (parts.length >= 3 && parts[2] && parts[2] !== '') {
                        setTimeout(() => {
                            $('#FederationSectionName').val(parts[2]);
                            updateFederationFullName();
                        }, 500);
                    }
                } else {
                    loadFederationDivisions(parts[0]);
                }
            }
        }
            
            // استعادة القيم المحفوظة لجهة الانتساب بشكل مضمون
            const savedEntity = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Affiliation?.AffiliationEntity ?? ""));
            const savedDivision = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Affiliation?.Division ?? ""));
            const savedSection = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Affiliation?.Section ?? ""));
            const savedGroup = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Affiliation?.Group ?? ""));

            if (savedEntity) {
                $('#Affiliation_AffiliationEntity').val(savedEntity);
                loadDivisions(savedEntity, savedDivision);

                if (savedDivision) {
                    setTimeout(function() {
                        $('#Affiliation_Division').val(savedDivision);
                        loadSections(savedDivision, savedSection);

                        if (savedSection) {
                            setTimeout(function() {
                                $('#Affiliation_Section').val(savedSection);
                                loadGroups(savedSection, savedGroup);

                                if (savedGroup) {
                                    setTimeout(function() {
                                        $('#Affiliation_Group').val(savedGroup);
                                    }, 250);
                                }
                            }, 250);
                        }
                    }, 250);
                }
            }
        });
        (function() {
            setTimeout(function() {
                const governorateSelect = document.getElementById('GovernorateSelect');
                const districtSelectDiv = document.getElementById('districtSelectDiv');
                const districtInputDiv = document.getElementById('districtInputDiv');
                const districtSelect = document.getElementById('districtSelect');
                const districtInput = document.getElementById('Address_District');
                const hiddenDistrict = document.getElementById('hiddenDistrict');
                
                if (!governorateSelect) {
                    console.log('❌ لم يتم العثور على حقل المحافظة');
                    return;
                }
                
                function updateDistrictField() {
                    const selectedValue = governorateSelect.value;
                    console.log('المحافظة المختارة:', selectedValue);
                    
                    if (selectedValue === 'بغداد') {
                        districtSelectDiv.style.display = 'block';
                        districtInputDiv.style.display = 'none';
                        console.log('✅ تم إظهار القائمة المنسدلة');
                    } else {
                        districtSelectDiv.style.display = 'none';
                        districtInputDiv.style.display = 'block';
                        console.log('✅ تم إظهار حقل النص');
                    }
                }
                
                function syncValues() {
                    if (districtSelectDiv.style.display === 'block') {
                        if (districtSelect && hiddenDistrict) {
                            hiddenDistrict.value = districtSelect.value;
                            if (districtInput) districtInput.value = districtSelect.value;
                        }
                    } else {
                        if (districtInput && hiddenDistrict) {
                            hiddenDistrict.value = districtInput.value;
                        }
                    }
                }
                
                governorateSelect.addEventListener('change', function() {
                    updateDistrictField();
                    syncValues();
                });
                
                if (districtSelect) {
                    districtSelect.addEventListener('change', syncValues);
                }
                
                if (districtInput) {
                    districtInput.addEventListener('input', syncValues);
                }
                
                updateDistrictField();
                syncValues();
                
                console.log('✅ تم تهيئة نظام بغداد بنجاح');
            }, 500);
        })();
    </script>

}
