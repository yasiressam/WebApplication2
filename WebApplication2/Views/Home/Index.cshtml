@model IEnumerable<WebApplication2.Models.News>

<style>
    /* تصميم الصفحة الرئيسية - مبسط ومكبر */
    body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: #f8f9fa;
    }

    main {
        flex: 1 0 auto;
        min-height: calc(100vh - 180px);
    }

    /* العنوان الرئيسي - مكبر */
    h2 {
        font-size: 2.8rem;
        font-weight: 800;
        color: #2c3e50;
        text-align: center;
        margin: 40px 0 50px;
        padding-bottom: 20px;
        border-bottom: 4px solid #3498db;
        position: relative;
    }

        h2::after {
            content: '📰';
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 2.5rem;
        }

    /* ===== السلايدر المكبر ===== */
    #newsSlider {
        max-width: 1300px;
        margin: 0 auto 60px;
        position: relative;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        overflow: hidden;
        border: 3px solid #e9ecef;
    }

    .slider-item {
        display: none;
    }

        .slider-item.active {
            display: block;
        }

    /* النص فوق الصورة - مكبر */
    .slider-text {
        padding: 25px 35px;
        background: white;
        border-bottom: 2px solid #eee;
    }

        .slider-text h3 {
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 15px;
            color: #2c3e50;
            text-align: right;
            line-height: 1.4;
        }

        .slider-text p {
            font-size: 18px;
            line-height: 1.7;
            margin: 0;
            color: #555;
            text-align: right;
        }

    /* الصورة - مكبرة */
    .slider-image-container {
        height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

        .slider-image-container img {
            max-width: 96%;
            max-height: 96%;
            object-fit: contain;
            border-radius: 5px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

    /* المعلومات - مكبرة */
    .slider-info {
        padding: 20px 35px;
        background: #f8f9fa;
        border-top: 2px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .slider-info span {
            color: #555;
            font-size: 18px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .slider-info .btn {
            padding: 12px 30px;
            font-size: 18px;
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.3s ease;
            background: #3498db;
            border: none;
            box-shadow: 0 4px 10px rgba(52, 152, 219, 0.3);
        }

            .slider-info .btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 7px 15px rgba(52, 152, 219, 0.4);
                background: #2980b9;
            }

    /* أزرار التحكم - مكبرة */
    .slider-prev, .slider-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(52, 152, 219, 0.9);
        color: white;
        border: none;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        cursor: pointer;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        transition: all 0.3s ease;
        opacity: 0.9;
    }

        .slider-prev:hover, .slider-next:hover {
            background: #2980b9;
            opacity: 1;
            transform: translateY(-50%) scale(1.1);
        }

    .slider-prev {
        right: 20px;
    }

    .slider-next {
        left: 20px;
    }

    /* مؤشرات - مكبرة */
    .slider-dots {
        text-align: center;
        padding: 20px;
        background: #f8f9fa;
        border-top: 2px solid #eee;
    }

        .slider-dots button {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            border: 2px solid #ddd;
            background: white;
            margin: 0 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .slider-dots button:hover {
                background: #3498db;
                border-color: #3498db;
                transform: scale(1.2);
            }

            .slider-dots button.active-dot {
                background: #3498db;
                border-color: #3498db;
                transform: scale(1.3);
                box-shadow: 0 0 10px rgba(52, 152, 219, 0.5);
            }

    /* أيقونات الخدمات - مبسطة */
    .services-section {
        margin: 70px auto;
        max-width: 1300px;
    }

    .services-title {
        font-size: 2.5rem;
        color: #2c3e50;
        text-align: center;
        margin-bottom: 50px;
        font-weight: 700;
    }

    .icon-card {
        padding: 30px;
        background: white;
        border-radius: 15px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
        height: 100%;
        border: 2px solid transparent;
        margin-bottom: 25px;
    }

        .icon-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
            border-color: #3498db;
        }

        .icon-card i {
            font-size: 60px;
            color: #3498db;
            margin-bottom: 25px;
            display: block;
        }

        .icon-card h5 {
            color: #2c3e50;
            font-weight: 700;
            font-size: 1.8rem;
            margin-bottom: 20px;
        }

        .icon-card p {
            color: #666;
            font-size: 1.2rem;
            line-height: 1.7;
            margin: 0;
        }

    /* تصميم متجاوب للسلايدر */
    @@media (max-width: 1200px) {
        #newsSlider {
            max-width: 95%;
        }

        h2 {
            font-size: 2.5rem;
            margin: 35px 0 45px;
        }
    }

    @@media (max-width: 992px) {
        h2 {
            font-size: 2.2rem;
            margin: 30px 0 40px;
        }

        .slider-image-container {
            height: 450px;
        }

        .slider-text {
            padding: 20px 30px;
        }

            .slider-text h3 {
                font-size: 24px;
            }

            .slider-text p {
                font-size: 16px;
            }

        .services-title {
            font-size: 2.2rem;
        }

        .icon-card {
            padding: 25px;
        }

            .icon-card h5 {
                font-size: 1.6rem;
            }

            .icon-card p {
                font-size: 1.1rem;
            }
    }

    @@media (max-width: 768px) {
        main {
            min-height: calc(100vh - 160px);
        }

        h2 {
            font-size: 2rem;
            margin: 25px 0 35px;
        }

        .slider-image-container {
            height: 400px;
        }

        .slider-text {
            padding: 15px 25px;
        }

            .slider-text h3 {
                font-size: 22px;
            }

            .slider-text p {
                font-size: 16px;
            }

        .slider-info {
            padding: 15px 25px;
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }

            .slider-info .btn {
                width: 100%;
                max-width: 300px;
            }

        .slider-prev, .slider-next {
            width: 50px;
            height: 50px;
            font-size: 20px;
        }

        .services-title {
            font-size: 2rem;
            margin-bottom: 40px;
        }

        .icon-card {
            padding: 20px;
            margin-bottom: 20px;
        }

            .icon-card i {
                font-size: 50px;
                margin-bottom: 20px;
            }

            .icon-card h5 {
                font-size: 1.4rem;
                margin-bottom: 15px;
            }

            .icon-card p {
                font-size: 1rem;
            }
    }

    @@media (max-width: 576px) {
        h2 {
            font-size: 1.8rem;
            margin: 20px 0 30px;
            padding-bottom: 15px;
        }

        .slider-image-container {
            height: 350px;
        }

        .slider-text h3 {
            font-size: 20px;
        }

        .slider-info .btn {
            font-size: 16px;
            padding: 10px 25px;
        }

        .slider-prev, .slider-next {
            width: 45px;
            height: 45px;
            font-size: 18px;
        }

        .services-title {
            font-size: 1.8rem;
            margin-bottom: 35px;
        }

        .icon-card h5 {
            font-size: 1.3rem;
        }

        .slider-dots button {
            width: 14px;
            height: 14px;
            margin: 0 6px;
        }
    }

    @@media (max-width: 480px) {
        .slider-image-container {
            height: 300px;
        }

        h2 {
            font-size: 1.6rem;
        }

        .services-title {
            font-size: 1.6rem;
        }
    }
</style>

<h2>أحدث الأخبار</h2>

<!-- ===== السلايدر البسيط ===== -->
<div id="newsSlider">
    @if (Model.Any())
    {
        @for (int i = 0; i < Model.Count(); i++)
        {
            var news = Model.ElementAt(i);
            <div class="slider-item @(i==0 ? "active" : "")">
                <!-- النص فوق الصورة -->
                <div class="slider-text">
                    <h3>@news.Title</h3>
                    <p>
                        @(news.Content.Length > 150 ? news.Content.Substring(0, 150) + "..." : news.Content)
                    </p>
                </div>

                <!-- الصورة -->
                <div class="slider-image-container">
                    @if (!string.IsNullOrEmpty(news.ImageUrl))
                    {
                        <img src="@news.ImageUrl"
                             alt="@news.Title"
                             onerror="handleImageError(this, '@news.Title')">
                    }
                    else
                    {
                        <div class="no-image-placeholder">
                            <i class="bi bi-newspaper"></i>
                            <h4>@news.Title</h4>
                        </div>
                    }
                </div>

                <!-- المعلومات -->
                <div class="slider-info">
                    <span>
                        <i class="bi bi-calendar"></i>
                        @news.CreatedAt.ToString("yyyy-MM-dd")
                    </span>
                    <a href="@Url.Action("NewsDetails", "News", new { id = news.Id })"
                       class="btn btn-primary">
                        <i class="bi bi-book me-2"></i>قراءة المزيد
                    </a>
                </div>
            </div>
        }

        <!-- أزرار التحكم -->
        <button class="slider-prev" type="button" onclick="prevSlide()">
            <i class="bi bi-chevron-right"></i>
        </button>
        <button class="slider-next" type="button" onclick="nextSlide()">
            <i class="bi bi-chevron-left"></i>
        </button>

        <!-- مؤشرات -->
        <div class="slider-dots">
            @for (int i = 0; i < Model.Count(); i++)
            {
                <button type="button" onclick="goToSlide(@i)"
                        class="@(i==0 ? "active-dot" : "")"></button>
            }
        </div>
    }
    else
    {
        <div class="no-news-message">
            <i class="bi bi-newspaper"></i>
            <h4>لا توجد أخبار</h4>
            <p>سيتم إضافة الأخبار قريباً</p>
        </div>
    }
</div>

<!-- قسم الخدمات -->
<div class="services-section">
    <h3 class="services-title">خدماتنا المميزة</h3>
    <div class="row">
        <div class="col-md-4">
            <div class="icon-card">
                <i class="bi bi-lightning-charge"></i>
                <h5>أخبار سريعة</h5>
                <p>نوفر لكم آخر الأخبار بأسرع وقت ممكن مع تحديثات مستمرة على مدار الساعة</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="icon-card">
                <i class="bi bi-shield-check"></i>
                <h5>معلومات موثقة</h5>
                <p>جميع الأخبار تخضع للتحقق والتوثق قبل النشر لضمان مصداقية المعلومات</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="icon-card">
                <i class="bi bi-globe2"></i>
                <h5>تغطية شاملة</h5>
                <p>نغطي جميع محافظات العراق وأهم الأحداث العالمية المؤثرة</p>
            </div>
        </div>
    </div>
</div>

<script>
    // دالة لمعالجة أخطاء الصور
    function handleImageError(img, title) {
        console.log('خطأ في تحميل الصورة:', title);
        img.style.display = 'none';
        const container = img.parentElement;

        if (container) {
            container.innerHTML = `
                <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#666;">
                    <i class="bi bi-newspaper" style="font-size:60px;margin-bottom:20px;color:#adb5bd;"></i>
                    <h4 style="color:#495057;margin-bottom:10px;font-size:1.5rem;text-align:center;">${title}</h4>
                    <p style="color:#6c757d;font-size:14px;">لا توجد صورة</p>
                </div>
            `;
        }
    }

    // المتغيرات للسلايدر
    let currentSlide = 0;
    let slideInterval;
    let slides = [];
    let dots = [];

    // تهيئة السلايدر عند تحميل الصفحة
    document.addEventListener('DOMContentLoaded', function() {
        initSlider();
    });

    // تهيئة السلايدر
    function initSlider() {
        slides = document.querySelectorAll('.slider-item');
        dots = document.querySelectorAll('.slider-dots button');

        if (slides.length > 0) {
            showSlide(currentSlide);
            startAutoSlide();
        }
    }

    // عرض سلايد معين
    function showSlide(index) {
        // إخفاء جميع السلايدات
        slides.forEach(slide => {
            slide.classList.remove('active');
            slide.style.display = 'none';
        });

        // إزالة النشاط من جميع المؤشرات
        dots.forEach(dot => {
            dot.classList.remove('active-dot');
        });

        // عرض السلايد الحالي
        if (slides[index]) {
            slides[index].classList.add('active');
            slides[index].style.display = 'block';
        }

        // تفعيل المؤشر الحالي
        if (dots[index]) {
            dots[index].classList.add('active-dot');
        }

        currentSlide = index;
    }

    // السلايد التالي
    function nextSlide() {
        if (slides.length === 0) return;

        clearInterval(slideInterval);
        let nextIndex = (currentSlide + 1) % slides.length;
        showSlide(nextIndex);
        startAutoSlide();
    }

    // السلايد السابق
    function prevSlide() {
        if (slides.length === 0) return;

        clearInterval(slideInterval);
        let prevIndex = (currentSlide - 1 + slides.length) % slides.length;
        showSlide(prevIndex);
        startAutoSlide();
    }

    // الذهاب إلى سلايد محدد
    function goToSlide(index) {
        if (slides.length === 0) return;

        clearInterval(slideInterval);
        if (index >= 0 && index < slides.length) {
            showSlide(index);
            startAutoSlide();
        }
    }

    // بدء التبديل التلقائي
    function startAutoSlide() {
        if (slides.length > 1) {
            clearInterval(slideInterval);
            slideInterval = setInterval(() => {
                nextSlide();
            }, 5000); // التبديل كل 5 ثواني
        }
    }

    // إضافة إمكانية السحب على الأجهزة المحمولة
    document.addEventListener('DOMContentLoaded', function() {
        const slider = document.getElementById('newsSlider');

        if (slider) {
            let startX = 0;
            let endX = 0;

            slider.addEventListener('touchstart', (e) => {
                startX = e.touches[0].clientX;
            });

            slider.addEventListener('touchend', (e) => {
                endX = e.changedTouches[0].clientX;
                handleSwipe(startX, endX);
            });
        }
    });

    function handleSwipe(startX, endX) {
        const swipeThreshold = 50;

        if (startX - endX > swipeThreshold) {
            // سحب لليسار = التالي
            nextSlide();
        } else if (endX - startX > swipeThreshold) {
            // سحب لليمين = السابق
            prevSlide();
        }
    }
</script>