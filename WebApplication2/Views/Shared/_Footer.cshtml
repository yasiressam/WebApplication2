@using Microsoft.EntityFrameworkCore
@using WebApplication2.Data
@inject Microsoft.Extensions.DependencyInjection.IServiceScopeFactory ServiceScopeFactory

@{
    // الحصول على إعدادات الموقع مباشرة من قاعدة البيانات
    WebApplication2.Models.SiteSettings siteSettings;

    try
    {
        using var scope = ServiceScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        siteSettings = await context.SiteSettings.FirstOrDefaultAsync();

        if (siteSettings == null)
        {
            siteSettings = new WebApplication2.Models.SiteSettings();
            context.SiteSettings.Add(siteSettings);
            await context.SaveChangesAsync();
        }
    }
    catch
    {
        // في حالة الخطأ، استخدم القيم الافتراضية
        siteSettings = new WebApplication2.Models.SiteSettings();
    }
}

<footer class="footer">
    <div class="container">
        <div class="row">
            <!-- معلومات الموقع والوسائل الاجتماعية -->
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h5 class="mb-3 fw-bold">
                    <i class="bi bi-newspaper me-2"></i>موقع الأخبار العراقي
                </h5>
                <p class="text-light opacity-75">
                    @siteSettings.SiteDescription
                </p>

                <!-- وسائل التواصل الاجتماعي (الثلاثة فقط) -->
                <div class="social-icons">
                    @if (!string.IsNullOrEmpty(siteSettings.FacebookUrl))
                    {
                        <a href="@siteSettings.FacebookUrl" target="_blank" class="social-icon social-facebook" title="فيسبوك">
                            <i class="bi bi-facebook"></i>
                        </a>
                    }

                    @if (!string.IsNullOrEmpty(siteSettings.InstagramUrl))
                    {
                        <a href="@siteSettings.InstagramUrl" target="_blank" class="social-icon social-instagram" title="إنستغرام">
                            <i class="bi bi-instagram"></i>
                        </a>
                    }

                    @if (!string.IsNullOrEmpty(siteSettings.WhatsAppNumber))
                    {
                        <a href="https://wa.me/@siteSettings.WhatsAppNumber.Replace("+", "")"
                           target="_blank"
                           class="social-icon social-whatsapp"
                           title="واتساب">
                            <i class="bi bi-whatsapp"></i>
                        </a>
                    }
                </div>
            </div>

            <!-- معلومات الاتصال -->
            <div class="col-lg-6">
                <h5 class="mb-3 fw-bold">تواصل معنا</h5>

                <div class="contact-card">
                    <div class="contact-icon bg-primary bg-opacity-25">
                        <i class="bi bi-envelope text-light"></i>
                    </div>
                    <div class="contact-info">
                        <div class="contact-label">البريد الإلكتروني</div>
                        <div class="contact-value">@siteSettings.ContactEmail</div>
                    </div>
                </div>

                <div class="contact-card">
                    <div class="contact-icon bg-success bg-opacity-25">
                        <i class="bi bi-telephone text-light"></i>
                    </div>
                    <div class="contact-info">
                        <div class="contact-label">رقم الهاتف</div>
                        <div class="contact-value">@siteSettings.ContactPhone</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(siteSettings.SiteAddress))
                {
                    <div class="contact-card">
                        <div class="contact-icon bg-warning bg-opacity-25">
                            <i class="bi bi-geo-alt text-light"></i>
                        </div>
                        <div class="contact-info">
                            <div class="contact-label">العنوان</div>
                            <div class="contact-value">@siteSettings.SiteAddress</div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(siteSettings.WhatsAppNumber))
                {
                    <div class="mt-3">
                        <a href="https://wa.me/@siteSettings.WhatsAppNumber.Replace("+", "")"
                           target="_blank"
                           class="btn-whatsapp-direct">
                            <i class="bi bi-whatsapp me-2"></i>تواصل معنا عبر واتساب
                        </a>
                    </div>
                }
            </div>
        </div>

        <hr class="my-4 opacity-25">

        <div class="text-center">
            <p class="mb-0 text-light opacity-75">
                &copy; @DateTime.Now.Year - موقع الأخبار العراقي. جميع الحقوق محفوظة.
                <span class="d-block d-sm-inline mt-2 mt-sm-0">
                    <a href="/Home/Privacy" class="text-light opacity-75 text-decoration-none mx-2">سياسة الخصوصية</a> |
                    <a href="/Home/Terms" class="text-light opacity-75 text-decoration-none mx-2">الشروط والأحكام</a>
                </span>
            </p>
            <small class="text-light opacity-50 mt-2 d-block">
                <i class="bi bi-clock-history me-1"></i>
                آخر تحديث: @siteSettings.LastUpdated.ToString("yyyy/MM/dd HH:mm")
            </small>
        </div>
    </div>
</footer>