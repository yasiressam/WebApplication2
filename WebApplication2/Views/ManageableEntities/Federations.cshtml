@model IEnumerable<WebApplication2.Models.Federation>

@{
    ViewData["Title"] = "إدارة الاتحادات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-6">
            <h2><i class="bi bi-diagram-2"></i> الاتحادات</h2>
        </div>
        <div class="col-6 text-start">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addFederationModal">
                <i class="bi bi-plus-circle"></i> إضافة اتحاد جديد
            </button>
            <a href="@Url.Action("Dashboard")" class="btn btn-secondary">
                <i class="bi bi-arrow-right"></i> عودة
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>اسم الاتحاد</th>
                            <th>تاريخ الإنشاء</th>
                            <th>تمت الإضافة بواسطة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int i = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@(i++)</td>
                                    <td><strong>@item.Name</strong></td>
                                    <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@(!string.IsNullOrEmpty(item.CreatedBy) ? item.CreatedBy : "---")</td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <!-- ✅ تم التعديل: من FederationDivisions إلى FederationDetails -->
                                            <a href="@Url.Action("FederationDetails", new { id = item.Id })"
                                                   class="btn btn-info"
                                                   title="إدارة الاتحاد">
                                                <i class="bi bi-diagram-3"></i> إدارة
                                            </a>
                                            <button class="btn btn-danger" onclick="deleteFederation(@item.Id, '@item.Name')" title="حذف الاتحاد">
                                                <i class="bi bi-trash"></i> حذف
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    لا توجد اتحادات
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal إضافة اتحاد -->
<div class="modal fade" id="addFederationModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-plus-circle"></i> إضافة اتحاد جديد</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateFederation" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">اسم الاتحاد <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control" required placeholder="أدخل اسم الاتحاد" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary">حفظ</button>
                </div>
            </form>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function deleteFederation(id, name) {
            if (confirm(`هل أنت متأكد من حذف الاتحاد "${name}"؟`)) {
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("DeleteFederation", "ManageableEntities")',
                    type: 'POST',
                    data: { id: id },
                    headers: { 'RequestVerificationToken': token },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert("فشل الحذف: " + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('خطأ في الاتصال: ' + error);
                    }
                });
            }
        }
    </script>
}