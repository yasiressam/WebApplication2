                        <option value="بكالوريوس">بكالوريوس</option>
                        <option value="طالب جامعي">طالب جامعي</option>
                        <option value="ماجستير">ماجستير</option>
                        <option value="دكتوراه">دكتوراه</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label fw-bold">👔 المستوى الإداري:</label>
                    <select class="form-select" id="managerLevelFilter">
    <option value="">جميع المسؤوليات</option>

    <optgroup label="المسؤول">
        <option value="manager-entity">🏢 مسؤول جهة</option>
        <option value="manager-division">📁 مسؤول قسم</option>
        <option value="manager-section">📂 مسؤول شعبة</option>
        <option value="manager-group">👥 مسؤول وحدة</option>
    </optgroup>

    <optgroup label="المعاون">
        <option value="assistant-entity">🏢 معاون جهة</option>
        <option value="assistant-division">📁 معاون قسم</option>
        <option value="assistant-section">📂 معاون شعبة</option>
        <option value="assistant-group">👥 معاون وحدة</option>
    </optgroup>
</select>
                </div>
                <div class="col-md-4 mb-3 d-flex align-items-end">
                    <div class="btn-group">
                        <button class="btn btn-primary" id="applyFilter"><i class="fas fa-filter"></i> تطبيق الفلتر</button>
                        <button class="btn btn-outline-secondary" id="clearFilter"><i class="fas fa-times"></i> مسح الفلاتر</button>
                    </div>
                    <div class="alert alert-info ms-3 mb-0 py-2">
                        <i class="fas fa-info-circle"></i> إجمالي النتائج: <span id="filteredCount">@filteredUsers</span> @(administrativeOnly ? "مسؤول/معاون" : "مستخدم")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- جدول المستخدمين -->
    <div class="table-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-users"></i> جميع المستخدمين
                <span class="badge bg-light text-dark ms-2">@filteredUsers</span>
            </div>
            <a asp-action="CreateUserByAdmin" asp-controller="Account" class="btn-add-user">
                <i class="fas fa-user-plus"></i> إضافة مستخدم
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="usersTable">
                    <thead class="table-light">
                        <tr>
                            <th class="checkbox-column"><input type="checkbox" id="selectAll" onclick="toggleAll(this)"></th>
                            <th style="width: 3%;">#</th>
                            <th style="width: 12%;">البريد</th>
                            <th style="width: 12%;">الاسم</th>
                            <th style="width: 10%;">الدور</th>
                            <th style="width: 8%;">السكن</th>
                            <th style="width: 8%;">العمل</th>
                            <th style="width: 8%;">التحصيل الدراسي</th>
                            <th style="width: 10%;">المسؤولية الإدارية</th>
                            <th style="width: 6%;">الحالة</th>
                            <th style="width: 14%;">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count(); i++)
                        {
                            var user = Model.ElementAt(i);
                            var isAdmin = user.Roles?.Contains("Admin") == true || user.Roles?.Contains("DistrictAdmin") == true;
                            var isMapViewer = user.Roles?.Contains("MapViewer") == true;
                            var isSuperAdmin = user.Roles?.Contains("SuperAdmin") == true;
                            var rowNumber = ((currentPage - 1) * pageSize) + i + 1;
                            
                            <tr data-user
                                data-index="@rowNumber"
                                data-name="@user.FullName?.ToLower() ?? "" "
                                data-email="@user.Email?.ToLower() ?? "" "
                                data-search="@user.SearchText"
                                data-role="@user.Roles?.ToLower() ?? "" "
                                data-residence-governorate="@user.ResidenceGovernorate?.ToLower() ?? "" "
                                data-work-governorate="@user.WorkGovernorate?.ToLower() ?? "" "
                                data-gender="@user.Gender?.ToLower() ?? "" "
                                data-status="@(user.IsActive ? "active" : "inactive")"
                               data-ismanager="@(user.IsManager ? "yes" : "no")"
data-managerlevel="@(user.ManagementLevel?.ToLower() ?? "")"
data-assignmentrole="@(user.AssignmentRole?.ToLower() ?? "")"
                                class="@(isSuperAdmin ? "table-danger" : isAdmin ? "table-warning" : "")">

                                <!-- خانة الاختيار -->
                                <td class="checkbox-column" data-label="اختيار">
                                    <input type="checkbox" class="user-checkbox" value="@user.Id" onchange="updateSelectedCount()">
                                </td>

                                <!-- رقم المستخدم -->
                                <td data-label="#">
                                    <span class="num-wrapper">@rowNumber</span>
                                </td>

                                <!-- البريد الإلكتروني -->
                                <td data-label="البريد">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar me-1">
                                            @if (!string.IsNullOrWhiteSpace(user.CoverImage))
                                            {
                                                <img src="@user.CoverImage" class="user-table-avatar" alt="@user.FullName" />
                                            }
                                            else
                                            {
                                                <div class="user-table-avatar-fallback">
                                                    @(string.IsNullOrEmpty(user.FullName) ? "?" : user.FullName[0].ToString())
                                                </div>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-bold small">@user.Email</div>
                                            <small class="text-muted" style="font-size: 0.65rem;">@user.Id.Substring(0, Math.Min(6, user.Id.Length))...</small>
                                        </div>
                                    </div>
                                </td>

                                <!-- الاسم -->
                                <td data-label="الاسم">
                                    <div class="fw-bold small">@user.FullName</div>
                                    @if ((isAdmin || isMapViewer) && !string.IsNullOrEmpty(user.ManagedGovernorate))
                                    {
                                        <small class="text-warning" style="font-size: 0.65rem;">
                                            <i class="fas fa-map-marker-alt"></i> @user.ManagedGovernorate
                                        </small>
                                    }
                                    @if (isMapViewer && string.IsNullOrEmpty(user.ManagedGovernorate))
                                    {
                                        <small class="text-primary" style="font-size: 0.65rem;">
                                            <i class="fas fa-globe"></i> عرض مركزي
                                        </small>
                                    }
                                </td>

                                <!-- الدور -->
                                <td data-label="الدور">
                                    @{
                                        var rolesList = (user.Roles ?? "").Split(',').Select(r => r.Trim()).Where(r => !string.IsNullOrEmpty(r)).ToList();
                                    }
                                    @foreach (var role in rolesList)
                                    {
                                        switch (role)
                                        {
                                            case "SuperAdmin":
                                                <span class="badge bg-danger"><i class="fas fa-crown"></i> سوبر أدمن</span>
                                                break;
                                            case "Admin":
                                            case "DistrictAdmin":
                                                <span class="badge bg-success"><i class="fas fa-user-shield"></i> مدير محافظة</span>
                                                break;
                                            case "فرد":
                                                <span class="badge bg-warning text-dark"><i class="fas fa-star"></i> فرد</span>
                                                break;
                                            case "NewsEditor":
                                                <span class="badge bg-info"><i class="fas fa-newspaper"></i> محرر أخبار</span>
                                                break;
                                            case "MapViewer":
                                                <span class="badge bg-primary"><i class="fas fa-map"></i> مشاهد خريطة</span>
                                                break;
                                            case "Manager":
                                                <span class="badge bg-info"><i class="fas fa-user-tie"></i> مسؤول</span>
                                                break;
                                            case "AssistantManager":
                                                <span class="badge" style="background: #fd7e14; color: white;"><i class="fas fa-user-friends"></i> معاون</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary"><i class="fas fa-user"></i> مستخدم</span>
                                                break;
                                        }
                                    }
                                </td>

                                <!-- السكن -->
                                <td data-label="السكن">
                                    <span class="badge bg-secondary">
                                        @(!string.IsNullOrWhiteSpace(user.ResidenceGovernorate) && user.ResidenceGovernorate != "غير محدد"
                                            ? $"محافظة {user.ResidenceGovernorate}"
                                            : "---")
                                    </span>
                                </td>

                                <!-- العمل -->
                                <td data-label="العمل">
                                    <span class="badge bg-warning text-dark">
                                        @(!string.IsNullOrWhiteSpace(user.WorkGovernorate) && user.WorkGovernorate != "غير محدد"
                                            ? $"محافظة {user.WorkGovernorate}"
                                            : "---")
                                    </span>
                                </td>

                                <!-- التحصيل الدراسي -->
                                <td data-label="التحصيل الدراسي">
                                    @if (!string.IsNullOrEmpty(user.Education) && user.Education != "---")
                                    {
                                        <span class="badge bg-secondary">@user.Education</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">---</span>
                                    }
                                </td>

                              <!-- المسؤولية الإدارية -->
<td data-label="المسؤولية الإدارية">
    @if (user.IsManager)
    {
        <div class="d-flex flex-column gap-1">
            @{
                var badgeStyle = user.AssignmentRole == "Assistant"
                    ? "background: linear-gradient(135deg, #fd7e14, #e8590c); color: white;"
                    : "background: linear-gradient(135deg, #17a2b8, #138496); color: white;";

                var levelText = user.ManagementLevel switch
                {
                    "Entity" => "جهة",
                    "Division" => "قسم",
                    "Section" => "شعبة",
                    "Group" => "وحدة",
                    _ => "جهة إدارية"
                };

                var roleText = user.AssignmentRole == "Assistant" ? "معاون" : "مسؤول";
                var fullRoleText = $"{roleText} {levelText}";
            }

            <span class="badge" style="@badgeStyle">
                <i class="bi bi-person-badge-fill"></i> @fullRoleText
            </span>

            @if (!string.IsNullOrWhiteSpace(user.ManagedEntityName))
            {
                <small class="text-muted" style="font-size: 0.70rem;">
                    @user.ManagedEntityName
                </small>
            }

            @if (!string.IsNullOrWhiteSpace(user.ManagedGovernorate))
            {
                <small class="text-secondary" style="font-size: 0.65rem;">
                    @user.ManagedGovernorate
                </small>
            }
        </div>
    }
    else
    {
        <span class="badge bg-secondary">لا يوجد</span>
    }
</td>

                                <!-- الحالة -->
                                <td data-label="الحالة">
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">مفعل</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">معطل</span>
                                    }
                                </td>

                                <!-- الإجراءات -->
                                <td data-label="الإجراءات">
                                    <div class="action-buttons-container">
                                        <a href="@Url.Action("UserDetails", "SuperAdmin", new { id = user.Id })"
                                           class="btn-action btn-details" title="تفاصيل">
                                            <i class="fas fa-eye"></i> <span>تفاصيل</span>
                                        </a>

                                        @if (user.AccountType == "فرد" && user.IsPromoted && !user.IsManager)
                                        {
                                            <a href="@Url.Action("Assign", "ManagementAssignments", new { userId = user.Id })"
                                               class="btn-action btn-assign"
                                               title="تعيين مسؤول أو معاون">
                                                <i class="fas fa-user-plus"></i> <span>تعيين</span>
                                            </a>
                                        }

                                        <button class="btn-action btn-roles edit-roles-btn"
                                                data-user-id="@user.Id"
                                                data-user-email="@user.Email"
                                                data-user-role="@user.Roles"
                                                data-user-governorate="@(user.ManagedGovernorate ?? "")"
                                                data-user-district="@(user.ManagedDistrict ?? "")"
                                                title="تعديل الأدوار">
                                            <i class="fas fa-user-cog"></i> <span>أدوار</span>
                                        </button>

                                        @if (!isSuperAdmin)
                                        {
                                            <button class="btn-action btn-toggle @(user.IsActive ? "" : "inactive") toggle-status-btn"
                                                    data-user-id="@user.Id"
                                                    title="@(user.IsActive ? "تعطيل" : "تفعيل")">
                                                <i class="fas fa-power-off"></i> <span>@(user.IsActive ? "تعطيل" : "تفعيل")</span>
                                            </button>

                                            <button class="btn-action btn-delete delete-user-btn"
                                                    data-user-id="@user.Id"
                                                    data-user-email="@user.Email"
                                                    data-user-name="@user.FullName"
                                                    title="حذف">
                                                <i class="fas fa-trash-alt"></i> <span>حذف</span>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer">
            <div class="row align-items-center">
                <div class="col-md-4">
                    @if (totalPages > 1)
                    {
                        var firstPage = Math.Max(1, currentPage - 2);
                        var lastPage = Math.Min(totalPages, currentPage + 2);
                        <nav aria-label="Page navigation">
                            <ul class="pagination pagination-sm mb-0" id="serverPagination">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="Users" asp-route-page="@(currentPage - 1)" asp-route-pageSize="@pageSize" asp-route-search="@currentSearch" asp-route-role="@currentRoleFilter" asp-route-residenceGovernorate="@currentResidenceGovernorateFilter" asp-route-workGovernorate="@currentWorkGovernorateFilter" asp-route-gender="@currentGenderFilter" asp-route-status="@currentStatusFilter" asp-route-managerLevel="@currentManagerLevelFilter" asp-route-education="@currentEducationFilter">السابق</a>
                                </li>
                                @if (firstPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Users" asp-route-page="1" asp-route-pageSize="@pageSize" asp-route-search="@currentSearch" asp-route-role="@currentRoleFilter" asp-route-residenceGovernorate="@currentResidenceGovernorateFilter" asp-route-workGovernorate="@currentWorkGovernorateFilter" asp-route-gender="@currentGenderFilter" asp-route-status="@currentStatusFilter" asp-route-managerLevel="@currentManagerLevelFilter" asp-route-education="@currentEducationFilter">1</a>
                                    </li>
                                    @if (firstPage > 2)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                }
                                @for (var p = firstPage; p <= lastPage; p++)
                                {
                                    <li class="page-item @(p == currentPage ? "active" : "")">
                                        <a class="page-link" asp-action="Users" asp-route-page="@p" asp-route-pageSize="@pageSize" asp-route-search="@currentSearch" asp-route-role="@currentRoleFilter" asp-route-residenceGovernorate="@currentResidenceGovernorateFilter" asp-route-workGovernorate="@currentWorkGovernorateFilter" asp-route-gender="@currentGenderFilter" asp-route-status="@currentStatusFilter" asp-route-managerLevel="@currentManagerLevelFilter" asp-route-education="@currentEducationFilter">@p</a>
                                    </li>
                                }
                                @if (lastPage < totalPages)
                                {
                                    @if (lastPage < totalPages - 1)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Users" asp-route-page="@totalPages" asp-route-pageSize="@pageSize" asp-route-search="@currentSearch" asp-route-role="@currentRoleFilter" asp-route-residenceGovernorate="@currentResidenceGovernorateFilter" asp-route-workGovernorate="@currentWorkGovernorateFilter" asp-route-gender="@currentGenderFilter" asp-route-status="@currentStatusFilter" asp-route-managerLevel="@currentManagerLevelFilter" asp-route-education="@currentEducationFilter">@totalPages</a>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="Users" asp-route-page="@(currentPage + 1)" asp-route-pageSize="@pageSize" asp-route-search="@currentSearch" asp-route-role="@currentRoleFilter" asp-route-residenceGovernorate="@currentResidenceGovernorateFilter" asp-route-workGovernorate="@currentWorkGovernorateFilter" asp-route-gender="@currentGenderFilter" asp-route-status="@currentStatusFilter" asp-route-managerLevel="@currentManagerLevelFilter" asp-route-education="@currentEducationFilter">التالي</a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
                <div class="col-md-4">
                    <div class="footer-page-size">
                        <label class="form-label fw-bold small">عدد العرض:</label>
                        <select class="form-select form-select-sm" id="pageSizeSelect">
                            <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10</option>
                            <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25</option>
                            <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50</option>
                            <option value="100" selected="@(pageSize == 100 ? "selected" : null)">100</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <div class="text-muted small">
                        <i class="fas fa-chart-bar"></i> عرض <span id="currentRange">@rangeStart-@rangeEnd</span> من @filteredUsers
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal لتعديل الأدوار -->
<div class="modal fade" id="rolesModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white py-2">
                <h5 class="modal-title"><i class="fas fa-user-cog"></i> تعديل أدوار المستخدم</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modalUserInfo" class="alert alert-info py-2 small"></div>
                <input type="hidden" id="modalUserId">
                <input type="hidden" id="currentUserGovernorate">
                <input type="hidden" id="currentUserDistrict">

                <div class="mb-3">
                    <label class="form-label fw-bold small">اختر الدور:</label>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="radio" name="roleOption" id="roleUser" value="User">
                                <label class="form-check-label small" for="roleUser"><i class="fas fa-user"></i> مستخدم عادي</label>
                            </div>
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="radio" name="roleOption" id="roleMember" value="فرد">
                                <label class="form-check-label small" for="roleMember"><i class="fas fa-star"></i> فرد</label>
                            </div>
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="radio" name="roleOption" id="roleAdmin" value="Admin">
                                <label class="form-check-label small" for="roleAdmin"><i class="fas fa-user-shield"></i> مدير محافظة</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="radio" name="roleOption" id="roleSuperAdmin" value="SuperAdmin">
                                <label class="form-check-label small" for="roleSuperAdmin"><i class="fas fa-crown"></i> سوبر أدمن</label>
                            </div>
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="radio" name="roleOption" id="roleNewsEditor" value="NewsEditor">
                                <label class="form-check-label small" for="roleNewsEditor"><i class="fas fa-newspaper"></i> محرر أخبار</label>
                            </div>
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="radio" name="roleOption" id="roleMapViewer" value="MapViewer">
                                <label class="form-check-label small" for="roleMapViewer"><i class="fas fa-map"></i> مشاهد خريطة</label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- حقول إضافية لتحديد النطاق (للأدمن أو مشاهد الخريطة) -->
                <div id="adminFields" style="display: none;">
                    <hr />
                    <div class="mb-3">
                        <label class="form-label fw-bold small">المحافظة / نطاق المشاهدة</label>
                        <select id="adminGovernorate" class="form-select">
                            <option value="">-- عرض مركزي لكل المحافظات --</option>
                            @{
                                var governorates = new List<string> { "بغداد مركزي", "بغداد - الكرخ", "بغداد - الرصافة", "الأنبار", "بابل", "البصرة", "ذي قار", "القادسية", "ديالى", "دهوك", "أربيل", "كربلاء", "كركوك", "ميسان", "المثنى", "النجف", "نينوى", "صلاح الدين", "السليمانية", "واسط" };
                            }
                            @foreach (var gov in governorates)
                            {
                                <option value="@gov">@gov</option>
                            }
                        </select>
                        <small class="text-muted" id="scopeHelpText">اختر المحافظة التي سيشاهدها أو يديرها هذا المستخدم</small>
                    </div>

                </div>

                <div class="alert alert-warning py-2 small" id="adminWarning" style="display: none;">
                    <i class="fas fa-info-circle"></i> سيتم حفظ نطاق العرض أو الإدارة حسب الدور المحدد.
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary btn-sm" id="saveRolesBtn">حفظ</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal تأكيد الحذف -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white py-2">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle"></i> تأكيد الحذف</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-3">
                    <i class="fas fa-user-slash fa-3x text-danger mb-2"></i>
                    <h6>هل أنت متأكد من حذف هذا المستخدم؟</h6>
                </div>
                <div id="deleteUserInfo" class="alert alert-warning py-2 small text-center"></div>
                <div class="alert alert-danger py-2 small">
                    <i class="fas fa-exclamation-circle"></i> هذا الإجراء لا يمكن التراجع عنه.
                </div>
                <input type="hidden" id="deleteUserId">
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirmDeleteBtn">حذف</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ========== المتغيرات العامة ==========
        let currentPage = 1;
        const rowsPerPage = @pageSize;
        const serverPageOffset = @((currentPage - 1) * pageSize);
        let filteredRows = [];
        const appliedServerFilters = {
            role: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentRoleFilter)),
            residenceGovernorate: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentResidenceGovernorateFilter)),
            workGovernorate: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentWorkGovernorateFilter)),
            gender: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentGenderFilter)),
            status: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentStatusFilter)),
            managerLevel: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentManagerLevelFilter)),
            education: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentEducationFilter))
        };

        function setSelectValue(id, value) {
            const element = document.getElementById(id);
            if (element && value) element.value = value;
        }

        setSelectValue('roleFilter', appliedServerFilters.role);
        setSelectValue('residenceGovernorateFilter', appliedServerFilters.residenceGovernorate);
        setSelectValue('workGovernorateFilter', appliedServerFilters.workGovernorate);
        setSelectValue('genderFilter', appliedServerFilters.gender);
        setSelectValue('statusFilter', appliedServerFilters.status);
        setSelectValue('managerLevelFilter', appliedServerFilters.managerLevel);
        setSelectValue('educationFilter', appliedServerFilters.education);

        function redirectWithServerFilters() {
            const params = new URLSearchParams();
            const add = (name, value) => {
                if (value) params.set(name, value);
            };

            add('search', document.getElementById('searchInput')?.value?.trim() || '');
            add('role', document.getElementById('roleFilter')?.value || '');
            add('residenceGovernorate', document.getElementById('residenceGovernorateFilter')?.value || '');
            add('workGovernorate', document.getElementById('workGovernorateFilter')?.value || '');
            add('gender', document.getElementById('genderFilter')?.value || '');
            add('status', document.getElementById('statusFilter')?.value || '');
            add('managerLevel', document.getElementById('managerLevelFilter')?.value || '');
            add('education', document.getElementById('educationFilter')?.value || '');
            add('pageSize', document.getElementById('pageSizeSelect')?.value || '@pageSize');

            window.location.href = '/SuperAdmin/Users' + (params.toString() ? '?' + params.toString() : '');
        }

        // ========== التحكم في ظهور حقول الأدمن ==========
        function toggleAdminFields() {
            const selectedRole = document.querySelector('input[name="roleOption"]:checked');
            const adminFields = document.getElementById('adminFields');
            const adminWarning = document.getElementById('adminWarning');
            
            const scopeHelpText = document.getElementById('scopeHelpText');

            if (selectedRole && (selectedRole.value === 'Admin' || selectedRole.value === 'MapViewer')) {
                adminFields.style.display = 'block';
                adminWarning.style.display = 'block';
                
                if (selectedRole.value === 'MapViewer') {
                    if (scopeHelpText) scopeHelpText.textContent = 'اتركها فارغة للعرض المركزي، أو اختر محافظة محددة للمشاهدة';
                } else {
                    if (scopeHelpText) scopeHelpText.textContent = 'اختر المحافظة التي سيديرها هذا الأدمن';
                }
            } else {
                adminFields.style.display = 'none';
                adminWarning.style.display = 'none';
            }
        }
        
        // ربط الأحداث
        document.querySelectorAll('input[name="roleOption"]').forEach(radio => {
            radio.addEventListener('change', toggleAdminFields);
        });
        
        
        // ========== تحديد الكل ==========
        function toggleAll(source) {
            document.querySelectorAll('.user-checkbox').forEach(cb => {
                cb.checked = source.checked;
            });
            updateSelectedCount();
        }

        function updateSelectedCount() {
            const count = document.querySelectorAll('.user-checkbox:checked').length;
            const selectedCountSpan = document.getElementById('selectedCount');
            const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
            if (selectedCountSpan) selectedCountSpan.textContent = count;
            if (bulkDeleteBtn) bulkDeleteBtn.disabled = count === 0;
        }

        // ========== حذف متعدد ==========
        async function bulkDeleteSelected() {
            const selectedIds = Array.from(document.querySelectorAll('.user-checkbox:checked')).map(cb => cb.value);
            if (selectedIds.length === 0) {
                Swal.fire('تنبيه', 'الرجاء اختيار مستخدمين للحذف', 'warning');
                return;
            }
            const result = await Swal.fire({
                title: 'تأكيد الحذف المتعدد',
                text: `هل أنت متأكد من حذف ${selectedIds.length} مستخدم؟`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'نعم، احذف',
                cancelButtonText: 'إلغاء'
            });
            if (!result.isConfirmed) return;
            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const response = await fetch('/SuperAdmin/BulkDeleteUsers', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({ userIds: selectedIds })
            });
            const data = await response.json();
           if (data.success) {
    Swal.fire('تم الحذف', data.message, 'success').then(() => {
        saveCurrentPage(); // ✅ حفظ الصفحة قبل إعادة التحميل
        location.reload();
    });
}
             else {
                Swal.fire('خطأ', data.message, 'error');
            }
        }

        // ========== الفلتر والترقيم ==========
        function initializeFilter() {
            const allRows = document.querySelectorAll('#usersTable tbody tr[data-user]');
            filteredRows = Array.from(allRows);
            currentPage = 1;
            updateTable();
            updateSelectedCount();
            document.querySelectorAll('.user-checkbox').forEach(cb => {
                cb.addEventListener('change', updateSelectedCount);
            });
        }

        function applyFilter() {
            redirectWithServerFilters();
            return;
            const searchText = document.getElementById('searchInput')?.value.toLowerCase() || '';
            const roleFilter = document.getElementById('roleFilter')?.value.toLowerCase() || '';
            const residenceGovernorateFilter = document.getElementById('residenceGovernorateFilter')?.value.toLowerCase() || '';
            const workGovernorateFilter = document.getElementById('workGovernorateFilter')?.value.toLowerCase() || '';
            const genderFilter = document.getElementById('genderFilter')?.value.toLowerCase() || '';
            const statusFilter = document.getElementById('statusFilter')?.value || '';
            const managerLevelFilter = document.getElementById('managerLevelFilter')?.value || '';
            const educationFilter = document.getElementById('educationFilter')?.value || '';

            const allRows = document.querySelectorAll('#usersTable tbody tr[data-user]');
            filteredRows = Array.from(allRows).filter(row => {
                const name = row.dataset.name || '';
                const email = row.dataset.email || '';
                const rowSearch = row.dataset.search || '';
                const role = row.dataset.role || '';
                const residenceGovernorate = row.dataset.residenceGovernorate || '';
                const workGovernorate = row.dataset.workGovernorate || '';
                const gender = row.dataset.gender || '';
                const status = row.dataset.status || '';
                const managerLevel = row.dataset.managerlevel || '';
                const assignmentRole = row.dataset.assignmentrole || '';
                
                const educationCell = row.querySelector('td[data-label="التحصيل الدراسي"]');
                const education = educationCell?.innerText?.trim() || '';

                if (searchText && !name.includes(searchText) && !email.includes(searchText) && !rowSearch.includes(searchText)) return false;
                if (roleFilter) {
                    if (roleFilter === 'member' && !role.includes('فرد')) return false;
                    else if (roleFilter !== 'member' && !role.includes(roleFilter)) return false;
                }
                if (residenceGovernorateFilter && !residenceGovernorate.includes(residenceGovernorateFilter)) return false;
                if (workGovernorateFilter && !workGovernorate.includes(workGovernorateFilter)) return false;
                if (genderFilter && gender !== genderFilter) return false;
                if (statusFilter === 'active' && status !== 'active') return false;
                if (statusFilter === 'inactive' && status !== 'inactive') return false;
               if (managerLevelFilter) {
    if (managerLevelFilter === 'manager-entity' && !(managerLevel === 'entity' && assignmentRole === 'manager')) return false;
    if (managerLevelFilter === 'manager-division' && !(managerLevel === 'division' && assignmentRole === 'manager')) return false;
    if (managerLevelFilter === 'manager-section' && !(managerLevel === 'section' && assignmentRole === 'manager')) return false;
    if (managerLevelFilter === 'manager-group' && !(managerLevel === 'group' && assignmentRole === 'manager')) return false;

    if (managerLevelFilter === 'assistant-entity' && !(managerLevel === 'entity' && assignmentRole === 'assistant')) return false;
    if (managerLevelFilter === 'assistant-division' && !(managerLevel === 'division' && assignmentRole === 'assistant')) return false;
    if (managerLevelFilter === 'assistant-section' && !(managerLevel === 'section' && assignmentRole === 'assistant')) return false;
    if (managerLevelFilter === 'assistant-group' && !(managerLevel === 'group' && assignmentRole === 'assistant')) return false;
}
                if (educationFilter && education !== educationFilter) return false;
                return true;
            });
            currentPage = 1;
            updateTable();
            updateSelectedCount();
        }

     function updateTable() {
    const allRows = document.querySelectorAll('#usersTable tbody tr[data-user]');
    allRows.forEach(row => row.style.display = 'none');
    const startIndex = (currentPage - 1) * rowsPerPage;
    const endIndex = startIndex + rowsPerPage;
    const currentRows = filteredRows.slice(startIndex, endIndex);
    currentRows.forEach((row, index) => {
        row.style.display = '';
        const numWrapper = row.querySelector('.num-wrapper');
        if (numWrapper) numWrapper.textContent = serverPageOffset + startIndex + index + 1;
    });
    document.getElementById('filteredCount').textContent = '@filteredUsers';
    const rangeStart = filteredRows.length > 0 ? serverPageOffset + startIndex + 1 : 0;
    const rangeEnd = serverPageOffset + Math.min(endIndex, filteredRows.length);
    document.getElementById('currentRange').textContent = rangeStart + '-' + rangeEnd;
    updatePagination();
    
    // ✅ حفظ رقم الصفحة الحالية (للعودة من التفاصيل أو الحذف)
    saveCurrentPage();
}

        function updatePagination() {
            const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
            const pagination = document.getElementById('pagination');
            if (!pagination) return;
            pagination.innerHTML = '';
            if (totalPages <= 1) return;
            const prevLi = document.createElement('li');
            prevLi.className = 'page-item ' + (currentPage === 1 ? 'disabled' : '');
            prevLi.innerHTML = '<a class="page-link" href="#" data-page="' + (currentPage - 1) + '">السابق</a>';
            pagination.appendChild(prevLi);
            for (let i = 1; i <= totalPages; i++) {
                const pageLi = document.createElement('li');
                pageLi.className = 'page-item ' + (currentPage === i ? 'active' : '');
                pageLi.innerHTML = '<a class="page-link" href="#" data-page="' + i + '">' + i + '</a>';
                pagination.appendChild(pageLi);
            }
            const nextLi = document.createElement('li');
            nextLi.className = 'page-item ' + (currentPage === totalPages ? 'disabled' : '');
            nextLi.innerHTML = '<a class="page-link" href="#" data-page="' + (currentPage + 1) + '">التالي</a>';
            pagination.appendChild(nextLi);
            pagination.querySelectorAll('.page-link').forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    const page = parseInt(this.dataset.page);
                    if (page >= 1 && page <= totalPages && page !== currentPage) {
                        currentPage = page;
                        updateTable();
                    }
                });
            });
        }

