@model WebApplication2.Models.SiteSettings


<style>
    /* تحسينات التصميم فقط - بدون تغيير في هيكل الكود */
    .card {
        border-radius: 20px !important;
        overflow: hidden;
        transition: transform 0.3s ease;
        border: none !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(30, 60, 114, 0.15) !important;
        }

    .card-header {
        background: linear-gradient(135deg, #1e3c72, #2a5a9c) !important;
        padding: 1.5rem 2rem !important;
        border: none !important;
    }

        .card-header h3 {
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            color: white;
        }

        .card-header i {
            font-size: 2rem;
            background: rgba(255,255,255,0.2);
            padding: 10px;
            border-radius: 12px;
            color: white;
        }

        .card-header small {
            color: rgba(255,255,255,0.9);
            font-size: 0.95rem;
        }

    .card-body {
        padding: 2rem !important;
        background: #ffffff;
    }

    /* تحسين العناوين */
    h4 {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 1.5rem !important;
        padding-bottom: 0.8rem !important;
    }

        h4.text-primary {
            color: #1e3c72 !important;
            border-bottom-color: #1e3c72 !important;
        }

        h4.text-success {
            color: #0d9488 !important;
            border-bottom-color: #0d9488 !important;
        }

        h4.text-info {
            color: #2563eb !important;
            border-bottom-color: #2563eb !important;
        }

        h4 i {
            font-size: 1.4rem;
            margin-left: 0.5rem;
        }

    /* تحسين الحقول */
    .form-label {
        font-weight: 600;
        color: #1e3c72;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .form-label i {
            color: #1e3c72;
            font-size: 1rem;
        }

    .form-control {
        border-radius: 12px !important;
        padding: 0.7rem 1rem !important;
        border: 2px solid #e2e8f0 !important;
        transition: all 0.3s;
        background: #ffffff;
    }

        .form-control:focus {
            border-color: #1e3c72 !important;
            box-shadow: 0 0 0 4px rgba(30, 60, 114, 0.1) !important;
            outline: none;
        }

        .form-control::placeholder {
            color: #cbd5e1;
        }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
    }

    .text-muted {
        color: #64748b !important;
        font-size: 0.9rem;
        margin-top: 0.5rem;
    }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 0.25rem;
    }

    /* تحسين كروت التواصل الاجتماعي */
    .border-primary {
        border-color: #1e3c72 !important;
        border-width: 2px !important;
    }

    .border-danger {
        border-color: #c41e3a !important;
        border-width: 2px !important;
    }

    .border-success {
        border-color: #0d9488 !important;
        border-width: 2px !important;
    }

    .card.h-100 {
        border-radius: 16px !important;
        transition: all 0.3s;
        background: #ffffff;
    }

        .card.h-100:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

    .card-body {
        padding: 1.5rem !important;
    }

    /* تحسين الأزرار */
    .btn {
        border-radius: 50px !important;
        padding: 0.7rem 1.8rem !important;
        font-weight: 600 !important;
        transition: all 0.3s !important;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1) !important;
        }

    .btn-outline-secondary {
        border: 2px solid #cbd5e1 !important;
        color: #475569 !important;
        background: transparent;
    }

        .btn-outline-secondary:hover {
            background: #f1f5f9 !important;
            border-color: #94a3b8 !important;
        }

    .btn-outline-warning {
        border: 2px solid #f59e0b !important;
        color: #b45309 !important;
        background: transparent;
    }

        .btn-outline-warning:hover {
            background: #f59e0b !important;
            color: white !important;
        }

    .btn-warning {
        background: #f59e0b !important;
        color: white !important;
        border: none;
    }

        .btn-warning:hover {
            background: #d97706 !important;
        }

    .btn-success {
        background: linear-gradient(135deg, #0d9488, #0f766e) !important;
        color: white !important;
        border: none;
    }

        .btn-success:hover {
            background: linear-gradient(135deg, #0f766e, #0d9488) !important;
        }

    /* تحسين تذييل البطاقة */
    .card-footer {
        background: #f8fafc !important;
        border-top: 2px solid #e2e8f0 !important;
        padding: 1rem 2rem !important;
    }

        .card-footer small {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #475569;
        }

        .card-footer i {
            color: #1e3c72;
        }

    /* تحسين التنبيهات */
    .alert {
        border-radius: 16px;
        padding: 1rem 1.5rem;
        border: none;
        display: flex;
        align-items: center;
        gap: 12px;
        animation: slideIn 0.3s ease;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
        border-right: 6px solid #0d9488;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
        border-right: 6px solid #dc2626;
    }

    .alert i {
        font-size: 1.3rem;
    }

    /* تحسينات الموبايل */
    @@media (max-width: 992px) {
        .card-header h3 {
            font-size: 1.5rem;
        }

        .d-flex.justify-content-between {
            flex-direction: column;
            gap: 15px;
        }

            .d-flex.justify-content-between > div {
                width: 100%;
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
            }

        .btn {
            flex: 1;
            justify-content: center;
        }
    }

    @@media (max-width: 768px) {
        .card-header {
            padding: 1.2rem !important;
        }

            .card-header h3 {
                font-size: 1.3rem;
            }

        .card-body {
            padding: 1.5rem !important;
        }

        .row {
            flex-direction: column;
        }

        .col-md-6, .col-md-4 {
            width: 100%;
            margin-bottom: 1rem;
        }

        .btn {
            width: 100%;
        }

        .card-footer .d-flex {
            flex-direction: column;
            gap: 10px;
            text-align: center;
        }
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg">
                <div class="card-header bg-gradient-primary text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-gear me-2"></i>إعدادات الموقع
                    </h3>
                    <small class="opacity-75">للمشرف العام فقط - تعديل معلومات الفوتر</small>
                </div>

                <div class="card-body">
                    <!-- رسائل -->
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" asp-action="Index" id="settingsForm">
                        @Html.AntiForgeryToken()

                        <!-- معلومات الاتصال الأساسية -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h4 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="bi bi-telephone me-2"></i>معلومات الاتصال
                                </h4>

                                <div class="mb-3">
                                    <label asp-for="ContactEmail" class="form-label fw-bold">
                                        <i class="bi bi-envelope me-1"></i>البريد الإلكتروني
                                    </label>
                                    <input asp-for="ContactEmail" type="email" class="form-control"
                                           placeholder="info@example.com" required>
                                    <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ContactPhone" class="form-label fw-bold">
                                        <i class="bi bi-phone me-1"></i>رقم الهاتف
                                    </label>
                                    <input asp-for="ContactPhone" class="form-control"
                                           placeholder="+964 XXX XXX XXXX" required>
                                    <span asp-validation-for="ContactPhone" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="SiteAddress" class="form-label fw-bold">
                                        <i class="bi bi-geo-alt me-1"></i>العنوان
                                    </label>
                                    <input asp-for="SiteAddress" class="form-control"
                                           placeholder="العراق - بغداد">
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h4 class="text-success border-bottom pb-2 mb-3">
                                    <i class="bi bi-info-circle me-2"></i>وصف الموقع
                                </h4>

                                <div class="mb-3">
                                    <label asp-for="SiteDescription" class="form-label fw-bold">
                                        <i class="bi bi-text-paragraph me-1"></i>وصف الموقع
                                    </label>
                                    <textarea asp-for="SiteDescription" class="form-control" rows="6"
                                              placeholder="أدخل وصف الموقع الذي سيظهر في الفوتر" required></textarea>
                                    <small class="text-muted">هذا الوصف سيظهر في قسم معلومات الموقع في الفوتر</small>
                                    <span asp-validation-for="SiteDescription" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- وسائل التواصل الاجتماعي (الثلاثة فقط) -->
                        <div class="mb-4">
                            <h4 class="text-info border-bottom pb-2 mb-3">
                                <i class="bi bi-share me-2"></i>وسائل التواصل الاجتماعي
                            </h4>
                            <p class="text-muted mb-3">أدخل روابط وسائل التواصل الاجتماعي (اترك الحقل فارغاً إذا كنت لا تريد إظهاره)</p>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 border-primary">
                                        <div class="card-body">
                                            <label asp-for="FacebookUrl" class="form-label fw-bold">
                                                <i class="bi bi-facebook text-primary me-1"></i>فيسبوك
                                            </label>
                                            <input asp-for="FacebookUrl" type="url" class="form-control"
                                                   placeholder="https://facebook.com/username">
                                            <span asp-validation-for="FacebookUrl" class="text-danger small"></span>
                                            <small class="text-muted mt-2 d-block">
                                                <i class="bi bi-info-circle me-1"></i>
                                                مثال: https://facebook.com/yourpage
                                            </small>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 border-danger">
                                        <div class="card-body">
                                            <label asp-for="InstagramUrl" class="form-label fw-bold">
                                                <i class="bi bi-instagram text-danger me-1"></i>إنستغرام
                                            </label>
                                            <input asp-for="InstagramUrl" type="url" class="form-control"
                                                   placeholder="https://instagram.com/username">
                                            <span asp-validation-for="InstagramUrl" class="text-danger small"></span>
                                            <small class="text-muted mt-2 d-block">
                                                <i class="bi bi-info-circle me-1"></i>
                                                مثال: https://instagram.com/yourpage
                                            </small>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 border-success">
                                        <div class="card-body">
                                            <label asp-for="WhatsAppNumber" class="form-label fw-bold">
                                                <i class="bi bi-whatsapp text-success me-1"></i>واتساب
                                            </label>
                                            <input asp-for="WhatsAppNumber" class="form-control"
                                                   placeholder="+964XXXXXXXXX">
                                            <span asp-validation-for="WhatsAppNumber" class="text-danger small"></span>
                                            <small class="text-muted mt-2 d-block">
                                                <i class="bi bi-info-circle me-1"></i>
                                                مثال: +9647701234567
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- أزرار التحكم -->
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <div>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-right me-1"></i>العودة للرئيسية
                                </a>

                                <a asp-action="Reset" class="btn btn-outline-warning ms-2"
                                   onclick="return confirm('هل أنت متأكد من إعادة تعيين جميع الإعدادات إلى القيم الافتراضية؟')">
                                    <i class="bi bi-arrow-clockwise me-1"></i>إعادة التعيين
                                </a>
                            </div>

                            <div>
                                <button type="reset" class="btn btn-warning me-2">
                                    <i class="bi bi-arrow-clockwise me-1"></i>إعادة تعيين النموذج
                                </button>
                                <button type="submit" class="btn btn-success" id="saveBtn">
                                    <i class="bi bi-save me-1"></i>حفظ التغييرات
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light text-muted">
                    <div class="d-flex justify-content-between align-items-center">
                        <small>
                            <i class="bi bi-info-circle me-1"></i>
                            سيتم تطبيق التغييرات مباشرة على الفوتر في جميع صفحات الموقع
                        </small>
                        <small>
                            <i class="bi bi-clock-history me-1"></i>
                            آخر تحديث: @Model.LastUpdated.ToString("yyyy/MM/dd HH:mm")
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            // تأكيد الحفظ
            $('#settingsForm').submit(function(e) {
                if ($(this).valid()) {
                    $('#saveBtn').prop('disabled', true).html('<i class="bi bi-hourglass-split me-1"></i>جاري الحفظ...');
                    return true;
                }
                return false;
            });

            // إضافة https:// تلقائياً لروابط السوشيال ميديا
            $('#FacebookUrl, #InstagramUrl').blur(function() {
                var val = $(this).val();
                if (val && !val.startsWith('http')) {
                    $(this).val('https://' + val);
                }
            });

            // تنسيق رقم الهاتف
            $('#ContactPhone').on('input', function() {
                var value = $(this).val().replace(/\D/g, '');
                if (value.length > 0) {
                    if (!value.startsWith('964')) {
                        value = '+964' + value;
                    } else if (!value.startsWith('+')) {
                        value = '+' + value;
                    }
                }
                $(this).val(value);
            });

            // تنسيق رقم واتساب
            $('#WhatsAppNumber').on('input', function() {
                var value = $(this).val().replace(/\D/g, '');
                if (value.length > 0) {
                    if (!value.startsWith('964')) {
                        value = '+964' + value;
                    } else if (!value.startsWith('+')) {
                        value = '+' + value;
                    }
                }
                $(this).val(value);
            });
        });
    </script>
}