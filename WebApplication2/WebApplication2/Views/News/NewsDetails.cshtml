@model WebApplication2.Models.News

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- زر العودة -->
            <div class="mb-4">
                <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-right me-2"></i> العودة للأخبار
                </a>
            </div>

            <!-- عنوان الخبر -->
            <h1 class="display-5 fw-bold text-primary mb-3">@Model.Title</h1>

            <!-- تاريخ ونشر الخبر -->
            <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                <div>
                    <small class="text-muted">
                        <i class="bi bi-calendar3 me-2"></i>
                        نشر في: @Model.CreatedAt.ToString("dd MMMM yyyy - hh:mm tt")
                    </small>
                </div>
                <div>
                    <button onclick="shareNews()" class="btn btn-sm btn-outline-primary rounded-pill">
                        <i class="bi bi-share me-1"></i> مشاركة
                    </button>
                    <button onclick="window.print()" class="btn btn-sm btn-outline-secondary rounded-pill">
                        <i class="bi bi-printer me-1"></i> طباعة
                    </button>
                </div>
            </div>

            <!-- صورة الخبر -->
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="text-center mb-5">
                    <img src="@Model.ImageUrl"
                         class="img-fluid rounded shadow-lg"
                         alt="@Model.Title"
                         style="max-height: 500px; width: 100%; object-fit: cover;" />
                </div>
            }
            else
            {
                <div class="text-center mb-5 bg-light rounded-4 py-5">
                    <i class="bi bi-newspaper display-1 text-muted"></i>
                    <p class="text-muted mt-3">لا توجد صورة مرفقة</p>
                </div>
            }

           

            <!-- محتوى الخبر -->
            <div class="news-content mb-5" style="font-size: 1.2rem; line-height: 1.8; text-align: justify;">
                @Html.Raw(Model.Content.Replace("\n", "<br><br>"))
            </div>

@section Styles {
    <style>
        .news-content {
            font-family: 'Tajawal', sans-serif;
        }

            .news-content h2, .news-content h3 {
                color: #1e3c72;
                margin-top: 30px;
                margin-bottom: 20px;
                font-weight: bold;
            }

            .news-content p {
                margin-bottom: 25px;
            }

            .news-content img {
                max-width: 100%;
                height: auto;
                border-radius: 8px;
                margin: 20px 0;
            }

        .btn-outline-primary {
            border-color: #1e3c72;
            color: #1e3c72;
        }

            .btn-outline-primary:hover {
                background: #1e3c72;
                border-color: #1e3c72;
            }

        .btn-primary {
            background: linear-gradient(135deg, #1e3c72, #2a5a9c);
            border: none;
        }

            .btn-primary:hover {
                background: linear-gradient(135deg, #2a5a9c, #1e3c72);
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(30, 60, 114, 0.3);
            }

        .btn-outline-secondary {
            transition: all 0.3s ease;
        }

            .btn-outline-secondary:hover {
                transform: translateX(-3px);
            }

        .bg-light {
            background: linear-gradient(135deg, #f8fafc, #f1f5f9) !important;
        }

        @@media print {
            .btn, .d-print-none, .border-top, .bg-light {
                display: none !important;
            }
            
            .news-content {
                font-size: 12pt;
            }
            
            h1 {
                font-size: 18pt;
            }
        }

        @@media (max-width: 768px) {
            .display-5 {
                font-size: 1.8rem;
            }
            
            .d-flex.justify-content-between {
                flex-direction: column;
                gap: 1rem;
            }
            
            .news-content {
                font-size: 1rem;
            }
        }
    </style>
}

@section Scripts {
    <script>
        // مشاركة الخبر
        function shareNews() {
            const title = '@Html.Raw(Model.Title)';
            const text = '@Html.Raw(Model.Content.Length > 100 ? Model.Content.Substring(0, 100) + "..." : Model.Content)';
            const url = window.location.href;
            
            if (navigator.share) {
                navigator.share({
                    title: title,
                    text: text,
                    url: url
                }).catch(() => {
                    copyToClipboard(url);
                });
            } else {
                copyToClipboard(url);
            }
        }

        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                showToast('تم نسخ رابط الخبر إلى الحافظة!');
            }).catch(() => {
                alert('تم نسخ رابط الخبر: ' + text);
            });
        }

        function showToast(message) {
            // إنشاء توست بسيط
            const toast = document.createElement('div');
            toast.className = 'position-fixed bottom-0 end-0 m-3 p-3 bg-success text-white rounded shadow';
            toast.style.zIndex = '9999';
            toast.innerHTML = '<i class="bi bi-check-circle me-2"></i>' + message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>
}