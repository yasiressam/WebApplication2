@model IEnumerable<WebApplication2.Models.SuperAdminUserVM>
@{

    Layout = "_Layout";

    // جلب الإحصائيات
    var totalUsers = Model.Count();
    var activeUsers = Model.Count(u => u.IsActive);
    var admins = Model.Count(u => u.Roles.Contains("Admin"));
    var superAdmins = Model.Count(u => u.Roles.Contains("SuperAdmin"));
}

<style>
    /* تحسينات بسيطة على التصميم */
    :root {
        --primary: #1e3c72;
        --primary-light: #2a5a9c;
        --primary-soft: #e8f0fe;
    }

    /* تحسين بطاقات الإحصائيات */
    .stat-card {
        border-radius: 15px !important;
        transition: all 0.3s ease;
        border: none !important;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
        }

        .stat-card .card-body {
            padding: 1.5rem !important;
        }

        .stat-card h5 {
            font-size: 0.95rem;
            opacity: 0.9;
            margin-bottom: 0.5rem;
        }

        .stat-card h2 {
            font-size: 2rem;
            font-weight: 700;
        }

        .stat-card i {
            transition: all 0.3s;
        }

        .stat-card:hover i {
            transform: scale(1.1) rotate(5deg);
            opacity: 0.7;
        }

    /* تنسيق بطاقة البحث - باللون الأبيض */
    .filter-card {
        border-radius: 15px !important;
        border: none !important;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05) !important;
        margin-bottom: 25px;
        background: white;
    }

        .filter-card .card-header {
            background: white !important;
            border-bottom: 2px solid #f0f2f5 !important;
            padding: 1.2rem 1.5rem !important;
        }

            .filter-card .card-header h5 {
                color: var(--primary);
                font-size: 1.1rem;
                font-weight: 700;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .filter-card .card-header i {
                color: var(--primary);
                font-size: 1.2rem;
            }

        .filter-card .card-body {
            background: white;
            padding: 1.5rem !important;
        }

    /* تنسيق الحقول */
    .form-label {
        color: var(--primary);
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 0.4rem;
    }

    .input-group, .form-control, .form-select {
        border-radius: 10px !important;
        border: 1px solid #e0e4e9 !important;
        padding: 0.6rem 1rem !important;
        transition: all 0.3s;
        background: white;
    }

        .input-group:focus-within,
        .form-control:focus,
        .form-select:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(30,60,114,0.1) !important;
            outline: none;
        }

    .input-group-text {
        background: white;
        border: 1px solid #e0e4e9 !important;
        border-right: none !important;
        border-radius: 0 10px 10px 0 !important;
        color: #6c757d;
    }

    /* تنسيق الأزرار */
    .btn-group {
        gap: 8px;
    }

    .btn-outline-primary {
        border: 1px solid var(--primary) !important;
        color: var(--primary) !important;
        border-radius: 8px !important;
        padding: 0.5rem 1.2rem !important;
        font-weight: 600;
        transition: all 0.3s;
        background: white;
    }

        .btn-outline-primary:hover {
            background: var(--primary) !important;
            color: white !important;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(30,60,114,0.2);
        }

    .btn-outline-secondary {
        border: 1px solid #dee2e6 !important;
        color: #6c757d !important;
        border-radius: 8px !important;
        padding: 0.5rem 1.2rem !important;
        font-weight: 600;
        transition: all 0.3s;
        background: white;
    }

        .btn-outline-secondary:hover {
            background: #6c757d !important;
            color: white !important;
            transform: translateY(-2px);
        }

    /* تنسيق عداد النتائج */
    .alert-info {
        background: #e8f0fe !important;
        border: 1px solid var(--primary) !important;
        border-radius: 20px !important;
        color: var(--primary) !important;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0.5rem 1.5rem !important;
    }

        .alert-info i {
            font-size: 1rem;
        }

    /* تحسين الجدول */
    .table-card {
        border-radius: 15px !important;
        border: none !important;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05) !important;
    }

        .table-card .card-header {
            background: linear-gradient(135deg, var(--primary), var(--primary-light)) !important;
            padding: 1.2rem 1.5rem !important;
            border: none !important;
        }

            .table-card .card-header div {
                color: white;
                font-size: 1.1rem;
                font-weight: 700;
            }

            .table-card .card-header .badge {
                background: rgba(255,255,255,0.2) !important;
                color: white !important;
                font-size: 0.9rem;
                padding: 0.4rem 0.8rem;
                border-radius: 20px;
            }

    .table {
        margin-bottom: 0;
    }

        .table thead th {
            background: #f8f9fa;
            color: var(--primary);
            font-weight: 700;
            font-size: 0.9rem;
            padding: 1rem;
            border: none;
            border-bottom: 2px solid #e9ecef;
        }

        .table tbody tr {
            transition: all 0.3s;
        }

            .table tbody tr:hover {
                background: #f8f9fa;
            }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #e9ecef;
        }

    /* تحسين الأفاتار */
    .avatar div {
        width: 35px;
        height: 35px;
        font-size: 0.9rem;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    /* تحسين البادجات */
    .badge {
        padding: 0.5rem 0.8rem;
        font-weight: 600;
        font-size: 0.8rem;
        border-radius: 20px;
    }

        .badge.bg-warning {
            background: #fff3cd !important;
            color: #856404 !important;
        }

        .badge.bg-secondary {
            background: #e9ecef !important;
            color: #495057 !important;
        }

    /* تحسين أزرار الإجراءات */
    .btn-group .btn {
        border-radius: 8px !important;
        padding: 0.3rem 0.8rem !important;
        font-size: 0.85rem;
        margin: 0 2px;
        transition: all 0.3s;
        cursor: pointer;
        border: 1px solid transparent;
    }

        .btn-group .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

    .btn-outline-info {
        border: 1px solid #17a2b8 !important;
        color: #17a2b8 !important;
        background: white;
    }

        .btn-outline-info:hover {
            background: #17a2b8 !important;
            color: white !important;
        }

    .btn-outline-primary {
        border: 1px solid var(--primary) !important;
        color: var(--primary) !important;
        background: white;
    }

        .btn-outline-primary:hover {
            background: var(--primary) !important;
            color: white !important;
        }

    .btn-outline-warning {
        border: 1px solid #ffc107 !important;
        color: #856404 !important;
        background: white;
    }

        .btn-outline-warning:hover {
            background: #ffc107 !important;
            color: #212529 !important;
        }

    .btn-outline-success {
        border: 1px solid #28a745 !important;
        color: #28a745 !important;
        background: white;
    }

        .btn-outline-success:hover {
            background: #28a745 !important;
            color: white !important;
        }

    /* زر الحذف الجديد */
    .btn-outline-danger {
        border: 1px solid #dc3545 !important;
        color: #dc3545 !important;
        background: white;
    }

        .btn-outline-danger:hover {
            background: #dc3545 !important;
            color: white !important;
        }

    /* تحسين تذييل الجدول */
    .card-footer {
        background: white !important;
        border-top: 2px solid #f0f2f5 !important;
        padding: 1rem 1.5rem !important;
    }

    .pagination {
        margin: 0;
        gap: 3px;
    }

    .page-link {
        border-radius: 8px !important;
        border: 1px solid #dee2e6 !important;
        color: var(--primary);
        padding: 0.4rem 0.8rem;
        font-size: 0.9rem;
        transition: all 0.3s;
    }

        .page-link:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

    .page-item.active .page-link {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    .text-muted {
        color: #6c757d !important;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* تحسين المودال */
    .modal-content {
        border-radius: 15px !important;
        border: none !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .modal-header {
        background: linear-gradient(135deg, var(--primary), var(--primary-light)) !important;
        padding: 1.2rem 1.5rem !important;
        border: none !important;
    }

        .modal-header .btn-close {
            background: rgba(255,255,255,0.2);
            border-radius: 8px;
            padding: 0.5rem;
        }

    .modal-body {
        padding: 1.5rem !important;
    }

    .modal-footer {
        border-top: 2px solid #f0f2f5 !important;
        padding: 1rem 1.5rem !important;
        background: #f8f9fa;
    }

    .alert-info {
        background: #e8f0fe !important;
        border: 1px solid var(--primary) !important;
        border-radius: 10px !important;
        color: var(--primary) !important;
        padding: 1rem !important;
    }

    .form-check {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: 10px;
        border: 1px solid transparent;
        transition: all 0.3s;
        margin-bottom: 0.5rem !important;
    }

        .form-check:hover {
            background: white;
            border-color: var(--primary);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

    .form-check-input {
        width: 1.1rem;
        height: 1.1rem;
        border-radius: 5px !important;
        border: 2px solid #dee2e6;
        cursor: pointer;
    }

        .form-check-input:checked {
            background-color: var(--primary);
            border-color: var(--primary);
        }

    .form-check-label {
        font-weight: 600;
        color: #495057;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

        .form-check-label i {
            color: var(--primary);
            font-size: 1rem;
        }

    .alert-warning {
        background: #fff3cd !important;
        border: 1px solid #ffc107 !important;
        border-radius: 10px !important;
        color: #856404 !important;
        padding: 1rem !important;
        margin-top: 1rem;
    }

    /* تحسينات الموبايل */
    @@media (max-width: 768px) {
        .stat-card h2 {
            font-size: 1.5rem;
        }

        .btn-group {
            width: 100%;
        }

            .btn-group .btn {
                flex: 1;
            }

        .alert-info {
            width: 100%;
            justify-content: center;
        }

        .table thead {
            display: none;
        }

        .table tbody tr {
            display: block;
            margin-bottom: 1rem;
            border: 1px solid #dee2e6;
            border-radius: 10px;
            padding: 0.5rem;
        }

        .table tbody td {
            display: flex;
            align-items: center;
            padding: 0.5rem;
            border: none;
            border-bottom: 1px dashed #dee2e6;
        }

            .table tbody td:last-child {
                border-bottom: none;
            }

            .table tbody td::before {
                content: attr(data-label);
                font-weight: 700;
                color: var(--primary);
                min-width: 100px;
                font-size: 0.85rem;
            }

        .btn-group {
            flex-wrap: wrap;
        }

            .btn-group .btn {
                flex: 1 0 auto;
                margin: 2px;
            }

        .card-footer .row {
            flex-direction: column;
            gap: 15px;
        }

        .text-end {
            text-align: center !important;
        }
    }

    /* تحسين عمود الرقم ليكون متناسق مع الجدول */
    .table tbody td:first-child {
        font-weight: 700;
        color: var(--primary);
        font-size: 1rem;
        text-align: center;
        vertical-align: middle;
        background: linear-gradient(135deg, rgba(30,60,114,0.02), transparent);
        width: 60px;
        padding: 1rem 0.5rem;
    }

    .num-wrapper {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: var(--primary-soft);
        border-radius: 8px;
        color: var(--primary);
        font-weight: 700;
        font-size: 0.95rem;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        border: 1px solid rgba(30,60,114,0.1);
    }

    tr:hover .num-wrapper {
        transform: scale(1.05);
        background: var(--primary);
        color: white;
        box-shadow: 0 4px 10px rgba(30,60,114,0.2);
    }

    /* إضافة فاصل بسيط بين الأعمدة */
    .table tbody td:first-child::after {
        content: '';
        position: absolute;
        right: 0;
        top: 25%;
        height: 50%;
        width: 1px;
        background: linear-gradient(to bottom, transparent, var(--primary), transparent);
        opacity: 0.2;
    }

    /* تحسين عرض الجدول */
    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    /* تنسيق زر إضافة مستخدم جديد */
    .btn-add-user {
        background: rgba(255,255,255,0.2) !important;
        border: 1px solid rgba(255,255,255,0.3) !important;
        color: white !important;
        padding: 0.6rem 1.5rem !important;
        border-radius: 50px !important;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        backdrop-filter: blur(10px);
        font-size: 0.95rem;
    }

        .btn-add-user:hover {
            background: white !important;
            color: var(--primary) !important;
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .btn-add-user i {
            font-size: 1.1rem;
        }
</style>

<div class="container mt-4">
    <h3 class="mb-4">👑 إدارة المستخدمين</h3>

    <!-- بطاقات الإحصائيات -->
    <div class="row mb-4">
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card stat-card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">المستخدمين</h5>
                            <h2 class="mb-0">@totalUsers</h2>
                        </div>
                        <i class="fas fa-users fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card stat-card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">المفعلين</h5>
                            <h2 class="mb-0">@activeUsers</h2>
                        </div>
                        <i class="fas fa-user-check fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card stat-card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">الأدمنية</h5>
                            <h2 class="mb-0">@admins</h2>
                        </div>
                        <i class="fas fa-user-shield fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card stat-card bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">سوبر أدمن</h5>
                            <h2 class="mb-0">@superAdmins</h2>
                        </div>
                        <i class="fas fa-crown fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- بطاقة البحث والفلاتر - باللون الأبيض -->
    <div class="filter-card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="fas fa-filter"></i> البحث والتصفية
            </h5>
        </div>
        <div class="card-body">
            <div class="row">
                <!-- البحث بالاسم أو البريد -->
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">🔍 البحث:</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" class="form-control" id="searchInput"
                               placeholder="ابحث بالاسم أو البريد...">
                    </div>
                </div>

                <!-- تصفية بالأدوار -->
                <div class="col-md-3 mb-3">
                    <label class="form-label fw-bold">👤 الدور:</label>
                    <select class="form-select" id="roleFilter">
                        <option value="">جميع الأدوار</option>
                        <option value="User">مستخدم</option>
                        <option value="Admin">أدمن</option>
                        <option value="SuperAdmin">سوبر أدمن</option>
                    </select>
                </div>

                <!-- تصفية بالمحافظة -->
                <div class="col-md-3 mb-3">
                    <label class="form-label fw-bold">📍 المحافظة:</label>
                    <select class="form-select" id="governorateFilter">
                        <option value="">جميع المحافظات</option>
                        <option value="بغداد">بغداد</option>
                        <option value="الأنبار">الأنبار</option>
                        <option value="بابل">بابل</option>
                        <option value="البصرة">البصرة</option>
                        <option value="ذي قار">ذي قار</option>
                        <option value="القادسية">القادسية</option>
                        <option value="ديالى">ديالى</option>
                        <option value="دهوك">دهوك</option>
                        <option value="أربيل">أربيل</option>
                        <option value="كربلاء">كربلاء</option>
                        <option value="كركوك">كركوك</option>
                        <option value="ميسان">ميسان</option>
                        <option value="المثنى">المثنى</option>
                        <option value="النجف">النجف</option>
                        <option value="نينوى">نينوى</option>
                        <option value="صلاح الدين">صلاح الدين</option>
                        <option value="السليمانية">السليمانية</option>
                        <option value="واسط">واسط</option>
                    </select>
                </div>

                <!-- تصفية بالحالة -->
                <div class="col-md-2 mb-3">
                    <label class="form-label fw-bold">🟢 الحالة:</label>
                    <select class="form-select" id="statusFilter">
                        <option value="">جميع الحالات</option>
                        <option value="active">المفعلين فقط</option>
                        <option value="inactive">المعطلين فقط</option>
                    </select>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-8">
                    <div class="btn-group" role="group">
                        <button class="btn btn-outline-primary" id="applyFilter">
                            <i class="fas fa-filter"></i> تطبيق الفلتر
                        </button>
                        <button class="btn btn-outline-secondary" id="clearFilter">
                            <i class="fas fa-times"></i> مسح الفلاتر
                        </button>
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <div class="alert alert-info mb-0 py-2">
                        <i class="fas fa-info-circle"></i>
                        عرض <span id="filteredCount" class="fw-bold">@totalUsers</span> من @totalUsers مستخدم
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- جدول المستخدمين -->
    <div class="table-card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-users"></i> جميع المستخدمين
                <span class="badge bg-light text-dark ms-2">@totalUsers</span>
            </div>
            <a asp-action="CreateUserByAdmin" asp-controller="Account" class="btn-add-user">
                <i class="fas fa-user-plus"></i> إضافة مستخدم جديد
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="usersTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 5%;">#</th>
                            <th style="width: 20%;">البريد</th>
                            <th style="width: 15%;">الاسم</th>
                            <th style="width: 15%;">المحافظة</th>
                            <th style="width: 15%;">الأدوار</th>
                            <th style="width: 10%;">الحالة</th>
                            <th style="width: 20%;">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count(); i++)
                        {
                            var user = Model.ElementAt(i);
                            <tr data-user data-index="@(i + 1)"
                                data-name="@user.FullName.ToLower()"
                                data-email="@user.Email.ToLower()"
                                data-role="@user.Roles.ToLower()"
                                data-governorate="@(user.ManagedGovernorate?.ToLower() ?? user.Governorate?.ToLower() ?? "")"
                                data-status="@(user.IsActive ? "active" : "inactive")">
                                <td data-label="#">
                                    <span class="num-wrapper">@(i + 1)</span>
                                </td>
                                <td data-label="البريد">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar me-2">
                                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width: 32px; height: 32px;">
                                                @user.FullName[0].ToString().ToUpper()
                                            </div>
                                        </div>
                                        <div>
                                            <div class="fw-bold">@user.Email</div>
                                            <small class="text-muted">@user.Id.Substring(0, 8)...</small>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="الاسم">
                                    <div class="fw-bold">@user.FullName</div>
                                    @if (!string.IsNullOrEmpty(user.ManagedGovernorate))
                                    {
                                        <small class="text-warning">
                                            <i class="fas fa-crown"></i> مدير
                                        </small>
                                    }
                                </td>
                                <td data-label="المحافظة">
                                    @if (!string.IsNullOrEmpty(user.ManagedGovernorate))
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fas fa-crown"></i> @user.ManagedGovernorate
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@user.Governorate</span>
                                    }
                                </td>
                                <td data-label="الأدوار">
                                    @if (user.Roles.Contains("SuperAdmin"))
                                    {
                                        <span class="badge bg-danger">
                                            <i class="fas fa-crown"></i> سوبر أدمن
                                        </span>
                                    }
                                    else if (user.Roles.Contains("Admin"))
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-user-shield"></i> أدمن
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="fas fa-user"></i> مستخدم
                                        </span>
                                    }
                                </td>
                                <td data-label="الحالة">
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle"></i> مفعل
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="fas fa-times-circle"></i> معطل
                                        </span>
                                    }
                                </td>
                                <td data-label="الإجراءات">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <!-- زر عرض التفاصيل -->
                                        <a href="@Url.Action("UserDetails", "SuperAdmin", new { id = user.Id })"
                                           class="btn btn-outline-info"
                                           title="عرض التفاصيل"
                                           data-user-id="@user.Id">
                                            <i class="fas fa-eye"></i>
                                            <span class="d-none d-md-inline"> عرض</span>
                                        </a>

                                        <!-- زر تعديل الأدوار -->
                                        <button class="btn btn-outline-primary edit-roles-btn"
                                                data-user-id="@user.Id"
                                                data-user-email="@user.Email"
                                                title="تعديل الأدوار">
                                            <i class="fas fa-user-cog"></i>
                                            <span class="d-none d-md-inline"> أدوار</span>
                                        </button>

                                        <!-- زر تفعيل/تعطيل -->
                                        <button class="btn @(user.IsActive ? "btn-outline-warning" : "btn-outline-success") toggle-status-btn"
                                                data-user-id="@user.Id"
                                                title="@(user.IsActive ? "تعطيل" : "تفعيل")">
                                            <i class="fas fa-power-off"></i>
                                            <span class="d-none d-md-inline"> @(user.IsActive ? "تعطيل" : "تفعيل")</span>
                                        </button>

                                        <!-- زر حذف المستخدم -->
                                        <button class="btn btn-outline-danger delete-user-btn"
                                                data-user-id="@user.Id"
                                                data-user-email="@user.Email"
                                                data-user-name="@user.FullName"
                                                title="حذف المستخدم">
                                            <i class="fas fa-trash-alt"></i>
                                            <span class="d-none d-md-inline"> حذف</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0" id="pagination">
                            <!-- سيتم إنشاء ترقيم الصفحات بالجافاسكريبت -->
                        </ul>
                    </nav>
                </div>
                <div class="col-md-6 text-end">
                    <div class="text-muted">
                        <i class="fas fa-chart-bar"></i>
                        <span id="currentRange">1-@(totalUsers > 10 ? 10 : totalUsers)</span> من @totalUsers
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal لتعديل الأدوار -->
<div class="modal fade" id="rolesModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-user-cog"></i> تعديل أدوار المستخدم
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modalUserInfo" class="alert alert-info">
                    <!-- سيتم تعبئته بالجافاسكريبت -->
                </div>

                <input type="hidden" id="modalUserId">

                <div class="mb-3">
                    <label class="form-label fw-bold">اختر الدور:</label>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="roleOption" id="roleUser" value="User">
                        <label class="form-check-label" for="roleUser">
                            <i class="fas fa-user"></i> مستخدم عادي
                        </label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="roleOption" id="roleAdmin" value="Admin">
                        <label class="form-check-label" for="roleAdmin">
                            <i class="fas fa-user-shield"></i> أدمن (سيرى مستخدمي محافظته فقط)
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="roleOption" id="roleSuperAdmin" value="SuperAdmin">
                        <label class="form-check-label" for="roleSuperAdmin">
                            <i class="fas fa-crown"></i> سوبر أدمن (يرى جميع المستخدمين)
                        </label>
                    </div>
                </div>

                <div class="alert alert-warning" id="adminWarning" style="display: none;">
                    <i class="fas fa-info-circle"></i>
                    سيتم تعيينه أدمن على محافظته الحالية تلقائيًا
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> إلغاء
                </button>
                <button type="button" class="btn btn-primary" id="saveRolesBtn">
                    <i class="fas fa-save"></i> حفظ التغييرات
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal تأكيد الحذف -->
<div class="modal fade" id="deleteConfirmModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle"></i> تأكيد الحذف
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <i class="fas fa-user-slash fa-4x text-danger mb-3"></i>
                    <h5>هل أنت متأكد من حذف هذا المستخدم؟</h5>
                </div>

                <div id="deleteUserInfo" class="alert alert-warning">
                    <!-- سيتم تعبئته بالجافاسكريبت -->
                </div>

                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <strong>تحذير:</strong> هذا الإجراء لا يمكن التراجع عنه. سيتم حذف جميع بيانات المستخدم بما في ذلك ملفه الشخصي وعنوانه.
                </div>

                <input type="hidden" id="deleteUserId">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> إلغاء
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fas fa-trash-alt"></i> نعم، احذف المستخدم
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // متغيرات عامة
        let selectedUserId = '';
        let selectedUserEmail = '';
        let currentPage = 1;
        const rowsPerPage = 10;
        let filteredRows = [];

        // تهيئة الفلتر
        function initializeFilter() {
            const allRows = document.querySelectorAll('#usersTable tbody tr[data-user]');
            filteredRows = Array.from(allRows);

            // تخزين الأرقام الأصلية
            filteredRows.forEach((row, index) => {
                const originalNumber = index + 1;
                const numWrapper = row.querySelector('.num-wrapper');
                if (numWrapper) {
                    numWrapper.textContent = originalNumber;
                }
                row.setAttribute('data-original-index', originalNumber);
            });

            updateTable();
        }

        // تطبيق الفلتر
        function applyFilter() {
            const searchText = document.getElementById('searchInput').value.toLowerCase();
            const roleFilter = document.getElementById('roleFilter').value.toLowerCase();
            const governorateFilter = document.getElementById('governorateFilter').value.toLowerCase();
            const statusFilter = document.getElementById('statusFilter').value;

            const allRows = document.querySelectorAll('#usersTable tbody tr[data-user]');
            filteredRows = Array.from(allRows).filter(row => {
                const name = row.dataset.name;
                const email = row.dataset.email;
                const role = row.dataset.role;
                const governorate = row.dataset.governorate;
                const status = row.dataset.status;

                // البحث
                if (searchText && !name.includes(searchText) && !email.includes(searchText)) {
                    return false;
                }

                // فلتر الدور
                if (roleFilter && !role.includes(roleFilter)) {
                    return false;
                }

                // فلتر المحافظة
                if (governorateFilter && !governorate.includes(governorateFilter)) {
                    return false;
                }

                // فلتر الحالة
                if (statusFilter) {
                    if (statusFilter === 'active' && status !== 'active') return false;
                    if (statusFilter === 'inactive' && status !== 'inactive') return false;
                }

                return true;
            });

            currentPage = 1;
            updateTable();
        }

        // تحديث الجدول
        function updateTable() {
            const allRows = document.querySelectorAll('#usersTable tbody tr[data-user]');

            // إخفاء جميع الصفوف
            allRows.forEach(row => row.style.display = 'none');

            // حساب بداية ونهاية الصفوف للصفحة الحالية
            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const currentRows = filteredRows.slice(startIndex, endIndex);

            // عرض الصفوف للصفحة الحالية
            currentRows.forEach((row, index) => {
                row.style.display = '';

                // تحديث رقم التسلسل مع الحفاظ على التنسيق
                const numWrapper = row.querySelector('.num-wrapper');
                if (numWrapper) {
                    numWrapper.textContent = startIndex + index + 1;
                }
            });

            // تحديث العداد
            document.getElementById('filteredCount').textContent = filteredRows.length;

            // تحديث نطاق العرض
            const rangeStart = filteredRows.length > 0 ? startIndex + 1 : 0;
            const rangeEnd = Math.min(endIndex, filteredRows.length);
            document.getElementById('currentRange').textContent = `${rangeStart}-${rangeEnd}`;

            // تحديث الترقيم
            updatePagination();
        }

        // تحديث الترقيم
        function updatePagination() {
            const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
            const pagination = document.getElementById('pagination');
            pagination.innerHTML = '';

            if (totalPages <= 1) return;

            // زر السابق
            const prevLi = document.createElement('li');
            prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
            prevLi.innerHTML = `<a class="page-link" href="#" data-page="${currentPage - 1}">السابق</a>`;
            pagination.appendChild(prevLi);

            // أرقام الصفحات
            const maxVisiblePages = 5;
            let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
            let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);

            if (endPage - startPage + 1 < maxVisiblePages) {
                startPage = Math.max(1, endPage - maxVisiblePages + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const pageLi = document.createElement('li');
                pageLi.className = `page-item ${currentPage === i ? 'active' : ''}`;
                pageLi.innerHTML = `<a class="page-link" href="#" data-page="${i}">${i}</a>`;
                pagination.appendChild(pageLi);
            }

            // زر التالي
            const nextLi = document.createElement('li');
            nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
            nextLi.innerHTML = `<a class="page-link" href="#" data-page="${currentPage + 1}">التالي</a>`;
            pagination.appendChild(nextLi);

            // إضافة مستمعي الأحداث
            pagination.querySelectorAll('.page-link').forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    const page = parseInt(this.dataset.page);
                    if (page >= 1 && page <= totalPages && page !== currentPage) {
                        currentPage = page;
                        updateTable();
                    }
                });
            });
        }

        // تطبيق الفلتر عند الضغط على Enter
        document.getElementById('searchInput').addEventListener('keyup', function(e) {
            if (e.key === 'Enter') {
                applyFilter();
            }
        });

        // تطبيق الفلتر عند تغيير القوائم
        ['roleFilter', 'governorateFilter', 'statusFilter'].forEach(id => {
            document.getElementById(id).addEventListener('change', applyFilter);
        });

        // زر تطبيق الفلتر
        document.getElementById('applyFilter').addEventListener('click', applyFilter);

        // زر مسح الفلاتر
        document.getElementById('clearFilter').addEventListener('click', function() {
            document.getElementById('searchInput').value = '';
            document.getElementById('roleFilter').value = '';
            document.getElementById('governorateFilter').value = '';
            document.getElementById('statusFilter').value = '';
            applyFilter();
        });

        // 1. عند النقر على زر تعديل الأدوار
        document.querySelectorAll('.edit-roles-btn').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.stopPropagation();
                console.log('تم النقر على زر تعديل الأدوار'); // للتأكد

                selectedUserId = this.dataset.userId;
                selectedUserEmail = this.dataset.userEmail;

                // عرض معلومات المستخدم
                document.getElementById('modalUserInfo').innerHTML =
                    `<i class="fas fa-user"></i> <strong>${selectedUserEmail}</strong>`;

                document.getElementById('modalUserId').value = selectedUserId;

                // جلب الأدوار الحالية
                try {
                    const response = await fetch(`/SuperAdmin/GetUserRoles?userId=${selectedUserId}`);
                    const data = await response.json();

                    if (data.success) {
                        // إلغاء تحديد جميع الخيارات
                        document.querySelectorAll('input[name="roleOption"]').forEach(radio => {
                            radio.checked = false;
                        });

                        // تحديد الدور الحالي
                        if (data.data.CurrentRoles) {
                            data.data.CurrentRoles.forEach(role => {
                                const radio = document.getElementById(`role${role}`);
                                if (radio) radio.checked = true;
                            });
                        }
                    }
                } catch (error) {
                    console.error('خطأ:', error);
                    alert('حدث خطأ في جلب البيانات');
                }

                // فتح الـ Modal
                const modal = new bootstrap.Modal(document.getElementById('rolesModal'));
                modal.show();
            });
        });

        // إظهار/إخفاء تحذير الأدمن عند اختيار دور الأدمن
        document.querySelectorAll('input[name="roleOption"]').forEach(radio => {
            radio.addEventListener('change', function() {
                if (this.value === 'Admin') {
                    document.getElementById('adminWarning').style.display = 'block';
                } else {
                    document.getElementById('adminWarning').style.display = 'none';
                }
            });
        });

        // 2. عند النقر على زر حفظ الأدوار
        document.getElementById('saveRolesBtn').addEventListener('click', async function() {
            if (!selectedUserId) {
                alert('❌ لم يتم اختيار مستخدم');
                return;
            }

            // الحصول على الدور المختار
            const selectedRole = document.querySelector('input[name="roleOption"]:checked');

            if (!selectedRole) {
                alert('❌ الرجاء اختيار دور للمستخدم');
                return;
            }

            const selectedRoles = [selectedRole.value];

            // إرسال الطلب
            try {
                const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

                const response = await fetch('/SuperAdmin/UpdateUserRoles', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': csrfToken
                    },
                    body: JSON.stringify({
                        UserId: selectedUserId,
                        SelectedRoles: selectedRoles
                    })
                });

                const result = await response.json();

                if (result.success) {
                    alert('✅ ' + result.message);
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    alert('❌ ' + result.message);
                }
            } catch (error) {
                console.error('خطأ:', error);
                alert('❌ حدث خطأ في الاتصال');
            }
        });

        // 3. عند النقر على زر تفعيل/تعطيل
        document.querySelectorAll('.toggle-status-btn').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.stopPropagation();

                const userId = this.dataset.userId;

                // التحقق من كلاس الزر لمعرفة الحالة الحالية
                const isActive = this.classList.contains('btn-outline-warning');
                const action = isActive ? 'تعطيل' : 'تفعيل';

                if (confirm(`هل تريد ${action} هذا المستخدم؟`)) {
                    try {
                        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

                        const response = await fetch('/SuperAdmin/ToggleUserStatus', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': csrfToken
                            },
                            body: JSON.stringify({ UserId: userId })
                        });

                        const result = await response.json();

                        if (result.success) {
                            // تغيير هذه الرسالة
                            let successMessage = isActive ? '✅ تم تعطيل هذا الحساب' : '✅ تم تفعيل هذا الحساب';
                            alert(successMessage);
                            setTimeout(() => window.location.reload(), 1000);
                        } else {
                            alert('❌ ' + result.message);
                        }
                    } catch (error) {
                        console.error('خطأ:', error);
                        alert('❌ حدث خطأ');
                    }
                }
            });
        });

        // 4. زر حذف المستخدم
        document.querySelectorAll('.delete-user-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();

                const userId = this.dataset.userId;
                const userEmail = this.dataset.userEmail;
                const userName = this.dataset.userName;

                // عرض معلومات المستخدم
                document.getElementById('deleteUserInfo').innerHTML =
                    `<i class="fas fa-user"></i> <strong>${userName}</strong><br>
                     <small class="text-muted">${userEmail}</small>`;

                document.getElementById('deleteUserId').value = userId;

                // فتح الـ Modal
                const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
                modal.show();
            });
        });

        // 5. تأكيد حذف المستخدم
        document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
            const userId = document.getElementById('deleteUserId').value;

            if (!userId) {
                alert('❌ لم يتم اختيار مستخدم');
                return;
            }

            try {
                const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

                const response = await fetch('/SuperAdmin/DeleteUser', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': csrfToken
                    },
                    body: JSON.stringify({ UserId: userId })
                });

                const result = await response.json();

                if (result.success) {
                    alert('✅ ' + result.message);
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    alert('❌ ' + result.message);
                }
            } catch (error) {
                console.error('خطأ:', error);
                alert('❌ حدث خطأ في الاتصال');
            }
        });

        // 6. عند النقر على صف الجدول (للانتقال للتفاصيل)
        document.querySelectorAll('#usersTable tbody tr[data-user]').forEach(row => {
            row.addEventListener('click', function(e) {
                // منع الانتقال إذا كان النقر على زر
                if (e.target.tagName === 'BUTTON' || e.target.tagName === 'A' ||
                    e.target.closest('button') || e.target.closest('a')) {
                    return;
                }

                const userId = this.querySelector('.edit-roles-btn').dataset.userId;
                window.location.href = `/SuperAdmin/UserDetails/${userId}`;
            });
        });

        // 7. إضافة تأثير عند التمرير على الأزرار
        document.querySelectorAll('.btn-group .btn').forEach(btn => {
            btn.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-2px)';
            });

            btn.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });

        // تهيئة الفلتر عند تحميل الصفحة
        document.addEventListener('DOMContentLoaded', function() {
            initializeFilter();
        });
    </script>
}