@{
    ViewData["Title"] = "إدخال كود التحقق";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white text-center">
                    <h3>🔑 إدخال كود التحقق</h3>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <div class="alert alert-info">
                        تم إرسال الكود إلى <strong>@ViewBag.PhoneNumber</strong>
                    </div>

                    @if (ViewBag.OtpCode != null)
                    {
                        <div class="alert alert-warning">
                            الكود: <strong>@ViewBag.OtpCode</strong>
                        </div>
                    }

                    <form asp-action="VerifyOtp" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <input type="text" name="otpCode" class="form-control text-center"
                                   placeholder="123456" maxlength="6" required />
                        </div>

                        <button type="submit" class="btn btn-success w-100" id="verifyBtn">
                            تحقق
                        </button>

                        <div class="text-center mt-3">
                            <a asp-action="Index">استخدام رقم آخر</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('verifyBtn').addEventListener('click', function() {
            this.disabled = true;
            this.innerHTML = 'جاري التحقق...';
        });
    </script>
}