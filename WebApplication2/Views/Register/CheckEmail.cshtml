@{
    Layout = "_Layout";
}

<style>
    :root {
        --primary-blue: #3498db;
        --primary-dark: #2c3e50;
        --primary-gradient: linear-gradient(135deg, #3498db, #2c3e50);
        --success: #2ecc71;
        --warning: #f39c12;
        --danger: #e74c3c;
        --text-dark: #2c3e50;
        --text-muted: #6c757d;
        --border-color: rgba(52, 152, 219, 0.2);
        --shadow-color: rgba(0, 0, 0, 0.15);
    }

    .card {
        border-radius: 20px !important;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1) !important;
    }

    .card-header {
        background: var(--primary-gradient) !important;
        padding: 2rem !important;
        border-bottom: none !important;
    }

        .card-header i {
            color: white;
            font-size: 4rem;
            display: block;
            margin-bottom: 1rem;
        }

        .card-header h2 {
            color: white;
            font-weight: 700;
            margin: 0;
        }

    .card-body {
        padding: 2.5rem !important;
    }

    .alert-success {
        background: linear-gradient(135deg, rgba(46, 204, 113, 0.1), rgba(46, 204, 113, 0.05));
        border-right: 4px solid var(--success);
        border-radius: 12px;
        color: var(--text-dark);
        padding: 1.5rem !important;
    }

        .alert-success .alert-heading {
            color: var(--success);
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .alert-success strong.text-dark {
            color: var(--primary-dark) !important;
            font-weight: 700;
        }

    .step-number {
        background: var(--primary-gradient) !important;
        width: 45px !important;
        height: 45px !important;
        font-size: 1.2rem;
        font-weight: 700;
        box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3);
        margin-bottom: 0.5rem;
    }

    .steps p {
        color: var(--text-muted);
        font-weight: 500;
    }

    .alert-warning {
        background: linear-gradient(135deg, rgba(243, 156, 18, 0.1), rgba(243, 156, 18, 0.05));
        border-right: 4px solid var(--warning);
        border-radius: 12px;
        color: var(--text-dark);
        padding: 1.5rem !important;
    }

        .alert-warning h6 {
            color: var(--warning);
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

    .btn-success {
        background: var(--primary-gradient) !important;
        border: none !important;
        color: white !important;
        padding: 0.75rem 2rem !important;
        border-radius: 50px !important;
        font-weight: 600 !important;
        transition: all 0.3s !important;
        box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3) !important;
    }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(52, 152, 219, 0.4) !important;
        }

    .btn-outline-secondary {
        background: transparent !important;
        border: 2px solid var(--border-color) !important;
        color: var(--text-muted) !important;
        padding: 0.75rem 2rem !important;
        border-radius: 50px !important;
        font-weight: 600 !important;
        transition: all 0.3s !important;
    }

        .btn-outline-secondary:hover {
            background: var(--primary-gradient) !important;
            border-color: transparent !important;
            color: white !important;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3) !important;
        }

    .border-top {
        border-top: 2px solid var(--border-color) !important;
        margin-top: 2rem !important;
        padding-top: 2rem !important;
    }

    /* تنسيقات إضافية */
    h5.mb-3 {
        color: var(--primary-dark);
        font-weight: 700;
    }

    .text-dark {
        color: var(--primary-dark) !important;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-0">
                <div class="card-header text-center">
                    <i class="bi bi-envelope-check"></i>
                    <h2 class="mb-0">تم إرسال رابط التأكيد!</h2>
                </div>

                <div class="card-body p-5 text-center">
                    <div class="alert alert-success mb-4">
                        <h5 class="alert-heading">
                            <i class="bi bi-check-circle"></i> شكراً لتسجيلك!
                        </h5>
                        <p class="mb-0">
                            تم إرسال رابط تأكيد الحساب إلى:
                            <strong class="text-dark">@ViewBag.Email</strong>
                        </p>
                    </div>

                    <div class="steps mb-5">
                        <h5 class="mb-3">📋 ماذا بعد؟</h5>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div class="step-number bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center">
                                    1
                                </div>
                                <p class="mt-2 mb-0 small">افتح بريدك الإلكتروني</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="step-number bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center">
                                    2
                                </div>
                                <p class="mt-2 mb-0 small">اضغط على رابط التأكيد</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="step-number bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center">
                                    3
                                </div>
                                <p class="mt-2 mb-0 small">سجل الدخول بحسابك</p>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <h6><i class="bi bi-exclamation-triangle"></i> ملاحظة مهمة</h6>
                        <p class="mb-0">
                            إذا لم تجد الإيميل في صندوق الوارد خلال 5 دقائق، يرجى التحقق من مجلد
                            <strong>الرسائل غير المرغوب فيها (Spam)</strong>.
                        </p>
                    </div>

                    <div class="mt-4 pt-3 border-top">
                        <a href="https://mail.google.com" target="_blank" class="btn btn-success me-2">
                            <i class="bi bi-google"></i> فتح Gmail
                        </a>
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> العودة للتسجيل
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>