@model WebApplication2.Models.RegisterViewModel

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">
        <div class="custom-card">
            <div class="custom-card-header">
                <h4 class="mb-0">إنشاء حساب جديد</h4>
                <p class="mb-0 small">سجل في ثوانٍ وانضم إلى مجتمعنا</p>
            </div>
            <div class="custom-card-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger mb-3">
                        <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
                    </div>
                }
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success mb-3">
                        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                    </div>
                }

                <form asp-action="Index" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <input asp-for="RegistrationMethod" type="hidden" id="RegistrationMethod" />

                    <div class="registration-mode-switch mb-4">
                        <button type="button" class="mode-btn" data-mode="whatsapp">التسجيل بالواتساب</button>
                        <button type="button" class="mode-btn" data-mode="email">التسجيل بالبريد</button>
                    </div>

                    <div class="mb-3" id="whatsappPanel">
                        <label asp-for="PhoneNumber" class="form-label">
                            <i class="fab fa-whatsapp me-1"></i> رقم الواتساب
                        </label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="07XXXXXXXXX" autocomplete="off" dir="ltr" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3 d-none" id="emailPanel">
                        <label asp-for="Email" class="form-label">
                            <i class="fas fa-envelope me-1"></i> البريد الإلكتروني
                        </label>
                        <input asp-for="Email" class="form-control" placeholder="example@email.com" autocomplete="off" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">
                            <i class="fas fa-lock me-1"></i> كلمة المرور
                        </label>
                        <input asp-for="Password" type="password" class="form-control" id="PasswordInput" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger"></span>

                        <div id="passwordRulesBox" class="password-rules-card mt-2 d-none">
                            <div class="fw-bold mb-2">
                                <i class="fas fa-shield-alt me-1"></i> شروط كلمة المرور
                            </div>
                            <ul class="mb-0 pe-3 list-unstyled">
                                <li id="ruleLength" class="text-danger"><i class="fas fa-times-circle me-1"></i>6 أحرف أو أكثر</li>
                                <li id="ruleUpper" class="text-danger"><i class="fas fa-times-circle me-1"></i>حرف كبير واحد على الأقل</li>
                                <li id="ruleLower" class="text-danger"><i class="fas fa-times-circle me-1"></i>حرف صغير واحد على الأقل</li>
                                <li id="ruleSymbol" class="text-danger"><i class="fas fa-times-circle me-1"></i>رمز خاص واحد على الأقل</li>
                            </ul>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">
                            <i class="fas fa-lock me-1"></i> تأكيد كلمة المرور
                        </label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="custom-btn-primary">
                            <i class="fas fa-user-plus me-2"></i> إنشاء حساب
                        </button>
                    </div>
                </form>

                <div class="text-center mt-4 pt-3 border-top">
                    <p class="text-muted mb-2">لديك حساب بالفعل؟</p>
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-success">
                        تسجيل الدخول
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.registration-mode-switch {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
}

.mode-btn {
    border: 2px solid #d7e3f4;
    background: #f8fbff;
    color: #1f3c68;
    border-radius: 14px;
    padding: 12px 14px;
    font-weight: 700;
    transition: all 0.2s ease;
}

.mode-btn.active {
    background: linear-gradient(135deg, #198754, #0d6efd);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 10px 20px rgba(13, 110, 253, 0.15);
}

.password-rules-card {
    background: #f8f9fa;
    border-right: 4px solid #198754;
    padding: 12px 15px;
    border-radius: 10px;
    font-size: .9rem;
}

.rule-ok {
    color: #0d6efd !important;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const registerForm = document.querySelector('form[asp-action="Index"], form');
    registerForm?.setAttribute("autocomplete", "off");
    registerForm?.querySelectorAll('input:not([type="hidden"]), select, textarea').forEach(field => {
        if (!field.hasAttribute('autocomplete')) {
            field.setAttribute('autocomplete', 'off');
        }
    });

    const password = document.getElementById("PasswordInput");
    const rulesBox = document.getElementById("passwordRulesBox");
    const registrationMethodInput = document.getElementById("RegistrationMethod");
    const emailPanel = document.getElementById("emailPanel");
    const whatsappPanel = document.getElementById("whatsappPanel");
    const modeButtons = document.querySelectorAll(".mode-btn");

    function setRegistrationMode(mode) {
        const normalizedMode = mode === "email" ? "email" : "whatsapp";
        if (registrationMethodInput) {
            registrationMethodInput.value = normalizedMode;
        }

        whatsappPanel?.classList.toggle("d-none", normalizedMode !== "whatsapp");
        emailPanel?.classList.toggle("d-none", normalizedMode !== "email");

        modeButtons.forEach(button => {
            button.classList.toggle("active", button.dataset.mode === normalizedMode);
        });
    }

    modeButtons.forEach(button => {
        button.addEventListener("click", function () {
            setRegistrationMode(button.dataset.mode || "whatsapp");
        });
    });

    setRegistrationMode((registrationMethodInput?.value || "whatsapp").toLowerCase());

    if (!password || !rulesBox) {
        return;
    }

    password.addEventListener("focus", function () {
        rulesBox.classList.remove("d-none");
    });

    password.addEventListener("input", function () {
        const value = password.value;
        updateRule("ruleLength", value.length >= 6);
        updateRule("ruleUpper", /[A-Z]/.test(value));
        updateRule("ruleLower", /[a-z]/.test(value));
        updateRule("ruleSymbol", /[!@@#$%^&*(),.?":{}|<>_\-+=~`[\]\\\/]/.test(value));
    });

    function updateRule(id, valid) {
        const item = document.getElementById(id);
        if (!item) {
            return;
        }

        const icon = item.querySelector("i");

        if (valid) {
            item.classList.remove("text-danger");
            item.classList.add("rule-ok");
            if (icon) {
                icon.className = "fas fa-check-circle me-1";
            }
        } else {
            item.classList.remove("rule-ok");
            item.classList.add("text-danger");
            if (icon) {
                icon.className = "fas fa-times-circle me-1";
            }
        }
    }
});
</script>
