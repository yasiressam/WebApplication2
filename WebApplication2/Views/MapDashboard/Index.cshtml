@model WebApplication2.Models.MapDashboardViewModel

@{
    Layout = "_Layout";
    // ✅ التحقق إذا كان المستخدم Admin (يظهر محافظة واحدة فقط)
    var isAdminOnly = Model.Governorates.Count == 1;
    var adminGovernorateName = isAdminOnly ? Model.Governorates.FirstOrDefault()?.Name : null;
    var isDistrictAdmin = User.IsInRole("DistrictAdmin");
    var adminDistrictName = Model.AdminDistrictName ?? "";
     var divisionsStats = ViewBag.DivisionsStats as List<dynamic> ?? new List<dynamic>();
    var sectionsStats = ViewBag.SectionsStats as List<dynamic> ?? new List<dynamic>();
    var groupsStats = ViewBag.GroupsStats as List<dynamic> ?? new List<dynamic>();
    var isManagerScopedView = Model.IsManagerScopedView;
    
    var totalDivisionsMembers = ViewBag.TotalDivisionsMembers ?? 0;
    var totalSectionsMembers = ViewBag.TotalSectionsMembers ?? 0;
    var totalGroupsMembers = ViewBag.TotalGroupsMembers ?? 0;
}

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
   :root {
    --primary-blue: #3498db;
    --primary-dark: #2c3e50;
    --primary-gradient: linear-gradient(135deg, #3498db, #2c3e50);
    --bg-light: #f8f9fa;
    --text-dark: #2c3e50;
    --text-muted: #6c757d;
    --border-color: rgba(52, 152, 219, 0.2);
    --card-bg: rgba(255, 255, 255, 0.95);
    --shadow-color: rgba(0, 0, 0, 0.15);
    --success: #2ecc71;
    --warning: #f39c12;
    --danger: #e74c3c;
    --info: #3498db;
    --purple: #9b59b6;
    --orange: #e67e22;
    --teal: #1abc9c;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: #f8f9fa;
    font-family: 'Tajawal', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    color: var(--text-dark);
    position: relative;
}

.dashboard-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
}

/* رأس الصفحة */
.dashboard-header {
    background: var(--primary-gradient) !important;
    color: white;
    padding: 1.5rem 2rem;
    border-radius: 15px;
    margin-bottom: 2rem;
    box-shadow: 0 0.5rem 1rem var(--shadow-color);
    border: none;
}

.dashboard-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
}

.dashboard-header p {
    font-size: 1rem;
    opacity: 0.9;
}

.last-update {
    background: rgba(255, 255, 255, 0.15);
    padding: 0.8rem 1.5rem;
    border-radius: 50px;
    backdrop-filter: blur(5px);
}

/* بطاقات الإحصائيات */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
}

.stat-card {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 0.5rem 0.6rem;
    transition: all 0.3s;
    box-shadow: 0 0.25rem 0.5rem var(--shadow-color);
    position: relative;
    overflow: hidden;
}

.stat-card.exportable-card {
    cursor: pointer;
}

.stat-card.exportable-card:hover::before {
    content: "\f1c3";
    font-family: "Font Awesome 6 Free";
    font-weight: 900;
    position: absolute;
    top: 8px;
    left: 10px;
    color: #198754;
    font-size: 0.95rem;
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 0.5rem 1rem rgba(52, 152, 219, 0.2);
    border-color: var(--primary-blue);
}

.stat-card::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--primary-gradient);
}

.stat-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: white;
    margin-bottom: 0.8rem;
    background: var(--primary-gradient) !important;
}

.stat-card h3 {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-dark);
    margin: 0;
    line-height: 1.2;
}

.stat-card p {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.35;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
}

.stat-card small {
    color: var(--text-muted);
    font-size: 0.7rem;
}

/* شريط الأدوات */
.toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 15px;
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 0.25rem 0.5rem var(--shadow-color);
}

.btn-excel {
    background: linear-gradient(135deg, var(--success), #27ae60);
    color: white;
    border: none;
    padding: 0.7rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.btn-excel:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(46, 204, 113, 0.3);
}

/* التخطيط الرئيسي */
.main-layout {
    display: grid;
    grid-template-columns: 600px 1fr;
    gap: 24px;
    margin-bottom: 2rem;
}

/* قسم الخريطة */
.map-panel {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 15px;
    padding: 20px;
    position: relative;
    box-shadow: 0 0.25rem 0.5rem var(--shadow-color);
    min-height: auto;
}

.map-title {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 12px;
    letter-spacing: 2px;
}

#map-container {
    overflow: auto !important;
    cursor: grab;
    border-radius: 10px;
    background: #f0f4f8;
    scroll-behavior: smooth;
    width: 100%;
    height: 550px !important;
    max-height: 550px;
    position: relative;
}

#map-container:active {
    cursor: grabbing;
}

#iraq-map {
    display: block;
    width: 100%;
    height: auto;
    pointer-events: auto;
}

.iraq-svg {
    width: 100%;
    height: auto;
    cursor: pointer;
}

.prov {
    fill: #a8d1ff;
    stroke: var(--primary-blue);
    stroke-width: 1.0;
    stroke-linejoin: round;
    cursor: pointer;
    transition: all 0.2s;
    pointer-events: auto;
}

.prov:hover {
    fill: #7bb9ff;
}

.prov-sel {
    fill: var(--primary-dark) !important;
    stroke: var(--primary-blue) !important;
    stroke-width: 2 !important;
    filter: drop-shadow(0 0 8px rgba(52, 152, 219, 0.5)) !important;
}

.lbl, .cnt {
    font-family: 'Tajawal', 'Segoe UI', sans-serif;
    text-anchor: middle;
    pointer-events: none;
}

.lbl {
    font-size: 14px;
    font-weight: 700;
    fill: var(--text-dark);
    text-shadow: 0 0 2px white;
}

.cnt {
    font-size: 16px;
    font-weight: 900;
    fill: #e74c3c;
    stroke: white;
    stroke-width: 1px;
    paint-order: stroke;
}

.map-legend {
    display: flex;
    gap: 18px;
    justify-content: center;
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid var(--border-color);
    flex-wrap: wrap;
}

.leg-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 0.75rem;
    color: var(--text-muted);
}

.leg-dot {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
}

.base-dot {
    background: #a8d1ff;
    border: 1.5px solid var(--primary-blue);
}

.sel-dot {
    background: var(--primary-dark);
    border: 2px solid var(--primary-blue);
}

/* الشريط الجانبي */
.sidebar-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

/* أزرار المحافظات */
.provinces-row {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 15px;
    padding: 16px;
    box-shadow: 0 0.25rem 0.5rem var(--shadow-color);
}

.row-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;
}

.label-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
}

.dot-blue {
    background: var(--primary-blue);
    box-shadow: 0 0 8px rgba(52, 152, 219, 0.3);
}

.row-label h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0;
}

.label-count {
    font-size: 0.7rem;
    color: var(--text-muted);
    background: #f8f9fa;
    padding: 2px 8px;
    border-radius: 20px;
}

.provinces-horizontal-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 4px;
    max-height: none;
    overflow-y: visible;
}

.province-horiz-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 30px;
    background: #f8f9fa;
    border: 1px solid var(--border-color);
    cursor: pointer;
    transition: all 0.2s;
    color: var(--text-dark);
    font-size: 0.75rem;
    white-space: nowrap;
    font-family: 'Tajawal', sans-serif;
}

.province-horiz-btn:hover {
    background: rgba(52, 152, 219, 0.1);
    border-color: var(--primary-blue);
    color: var(--primary-blue);
    transform: translateY(-2px);
}

.province-horiz-btn.active {
    background: var(--primary-gradient);
    border-color: var(--primary-blue);
    color: white;
}

.horiz-name {
    font-weight: 600;
}

.horiz-count {
    font-size: 0.65rem;
    font-weight: 800;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    padding: 2px 6px;
    color: inherit;
}

.province-horiz-btn.active .horiz-count {
    background: rgba(255, 255, 255, 0.3);
    color: white;
}

/* لوحة التقرير */
.report-panel {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 15px;
    padding: 20px;
    display: none;
    animation: slideIn 0.3s ease;
    box-shadow: 0 0.25rem 0.5rem var(--shadow-color);
}

@@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.rpt-hdr {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-color);
}

.rpt-title {
    flex: 1;
    min-width: 0;
}

.rpt-export-btn {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(39, 174, 96, 0.35);
    background: rgba(39, 174, 96, 0.1);
    color: #1e874b;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
}

.rpt-export-btn:hover {
    background: #27ae60;
    border-color: #27ae60;
    color: #fff;
    transform: translateY(-1px);
}

.back-btn {
    width: 32px;
    height: 32px;
    background: #f8f9fa;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
}

.back-btn:hover {
    background: rgba(52, 152, 219, 0.1);
    border-color: var(--primary-blue);
}

.back-btn svg {
    width: 22px;
    height: 22px;
    stroke: var(--text-dark);
}

.back-btn:hover svg {
    stroke: var(--primary-blue);
}

.rpt-hdr h2 {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-dark);
    margin: 0;
}

.rpt-sub {
    font-size: 0.7rem;
    color: var(--text-muted);
}

/* المكعبات الإحصائية */
.stats-cubes-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
}

.stat-cube {
    flex: 1;
    min-width: 75px;
    border-radius: 14px;
    padding: 12px 8px 10px;
    border: 1px solid;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s;
}

.stat-cube:hover {
    transform: translateY(-2px);
}

.cube-icon {
    font-size: 1.2rem;
    line-height: 1;
    margin-bottom: 4px;
}

.cube-num {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-dark);
    line-height: 1;
}

.cube-lbl {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 3px;
    margin-bottom: 8px;
}

.cube-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: #f8f9fa;
}

.cube-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.8s ease;
}

.cube-male {
    background: rgba(52, 152, 219, 0.05);
    border-color: rgba(52, 152, 219, 0.2);
}

.cube-fem {
    background: rgba(231, 76, 60, 0.05);
    border-color: rgba(231, 76, 60, 0.2);
}

.cube-male .cube-icon {
    color: var(--primary-blue);
}

.cube-fem .cube-icon {
    color: #e74c3c;
}

.fill-male {
    background: var(--primary-blue);
}

.fill-fem {
    background: #e74c3c;
}

/* تنسيق الجدول الهرمي */
.hierarchy-table-container {
    max-height: 500px;
    overflow-y: auto;
}

.hierarchy-table {
    width: 100%;
    border-collapse: collapse;
}

.hierarchy-table th {
    background: var(--primary-gradient);
    color: white;
    padding: 12px;
    text-align: center;
    font-weight: 600;
    position: sticky;
    top: 0;
}

.hierarchy-table td {
    padding: 10px;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
}

.hierarchy-table tr:hover {
    background: rgba(52, 152, 219, 0.05);
}

.level-entity {
    font-weight: 700;
    color: #27ae60;
}

.level-division {
    font-weight: 600;
    color: #3498db;
}

.level-section {
    font-weight: 500;
    color: #f39c12;
}

.level-group {
    font-weight: 500;
    color: #9b59b6;
}

.count-badge {
    background: #e9ecef;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--primary-dark);
}

.table-caption {
    background: #f8f9fa;
    padding: 10px;
    text-align: center;
    font-size: 0.85rem;
    color: #6c757d;
}

.hierarchy-breadcrumb {
    background: #f8fbff;
    border: 1px solid #e6eef8;
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 12px;
    color: #4b5563;
    font-weight: 700;
}

.hierarchy-level-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
}

.hierarchy-level-card {
    border: 1px solid #e5e7eb;
    background: #fff;
    border-radius: 8px;
    padding: 14px;
    cursor: pointer;
    text-align: right;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}

.hierarchy-level-card:hover {
    border-color: #27ae60;
    box-shadow: 0 6px 16px rgba(39, 174, 96, 0.14);
    transform: translateY(-1px);
}

.hierarchy-level-card.disabled {
    cursor: default;
    opacity: 0.85;
}

.hierarchy-level-card.disabled:hover {
    border-color: #e5e7eb;
    box-shadow: none;
    transform: none;
}

.hierarchy-level-title {
    color: #1f2937;
    font-weight: 800;
    margin-bottom: 8px;
    overflow-wrap: anywhere;
}

.hierarchy-level-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    color: #6b7280;
    font-size: 0.85rem;
}

/* ألوان إضافية للعضويات */
.bg-purple {
    background-color: #9b59b6 !important;
}

.text-purple {
    color: #9b59b6 !important;
}

.bg-orange {
    background-color: #e67e22 !important;
}

.bg-teal {
    background-color: #1abc9c !important;
}

/* تحسينات الموبايل */
@@media (max-width: 1200px) {
    .stats-grid {
        grid-template-columns: repeat(3, 1fr);
    }
    
    .main-layout {
        grid-template-columns: 1fr;
    }
    
    .map-panel {
        position: static;
    }
}

@@media (max-width: 768px) {
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .dashboard-header h1 {
        font-size: 1.5rem;
    }
    
    .provinces-horizontal-grid {
        max-height: none;
    }
}

.admin-welcome-alert {
    background: linear-gradient(135deg, #3498db, #2c3e50);
    color: white;
    border: none;
    border-radius: 15px;
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    margin-bottom: 1.5rem;
}

.admin-badge {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 50px;
    padding: 5px 12px;
    font-size: 0.8rem;
    font-weight: 600;
}
</style>

<div class="dashboard-container">
    <div class="dashboard-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <div>
                @if (isManagerScopedView)
                {
                    <h1 class="mb-2">
                        <i class="fas fa-user-tie me-3"></i> @Model.ManagerScopeTitle
                    </h1>
                    <p class="mb-0">
                        <i class="fas fa-chart-line me-2"></i> لوحة معلومات
                    </p>
                }
                else if (isAdminOnly)
                {
                    <h1 class="mb-2">
                        <i class="fas fa-map-marked-alt me-3"></i> خريطة محافظة @adminGovernorateName
                    </h1>
                    <p class="mb-0">
                        <i class="fas fa-chart-line me-2"></i> لوحة معلومات
                    </p>
                }
                else
                {
                    <h1 class="mb-2">
                        <i class="fas fa-map-marked-alt me-3"></i> الإحصائيات
                    </h1>
                    <p class="mb-0">
                        <i class="fas fa-chart-line me-2"></i> لوحة معلومات متكاملة لعرض إحصائيات المستخدمين
                    </p>
                }
            </div>
            <div class="last-update mt-3 mt-lg-0">
                <div class="d-flex align-items-center">
                    <i class="fas fa-clock me-2"></i>
                    <div>
                        <small>آخر تحديث</small>
                        <strong class="d-block">@Model.LastUpdated.ToString("yyyy/MM/dd HH:mm")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!isManagerScopedView)
    {
    <!-- ==================== القسم العلوي: الخريطة + قائمة المحافظات ==================== -->
    <div class="main-layout">
        <div class="map-panel">
            <div class="map-title">
                <i class="fas fa-map"></i> جمهورية العراق
            </div>
            <div id="map-container">
                <svg id="iraq-map" class="iraq-svg" viewBox="50 20 900 860" xmlns="http://www.w3.org/2000/svg">
                </svg>
            </div>
            <div class="map-legend">
                <div class="leg-item"><span class="leg-dot base-dot"></span><span>اضغط على المحافظة للتقرير</span></div>
                <div class="leg-item"><span class="leg-dot sel-dot"></span><span>المحافظة المختارة</span></div>
            </div>
        </div>

        <div class="sidebar-panel">
            <div class="provinces-row">
                <div class="row-label">
                    <span class="label-dot dot-blue"></span>
                    <h3>قائمة المحافظات</h3>
                    <span class="label-count">@Model.TotalGovernorates محافظة</span>
                </div>
                <div class="provinces-horizontal-grid" id="provincesGrid"></div>
            </div>
            <div class="report-panel" id="reportPanel"></div>
        </div>
    </div>

    <!-- ==================== شريط الأدوات ==================== -->
    <div class="toolbar">
        <div class="text-muted">
            <i class="fas fa-info-circle me-2"></i>
            إجمالي المحافظات: <strong class="text-dark">@Model.TotalGovernorates</strong>
            | المغطاة: <strong class="text-dark">@Model.CoveredGovernorates</strong>
        </div>
        <button class="btn-excel" onclick="exportToExcel()">
            <i class="fas fa-file-excel"></i> تصدير إلى Excel
        </button>
    </div>
    }
    else
    {
        <div class="toolbar">
            <div></div>
            <button class="btn-excel" onclick="exportToExcel()">
