        <!-- أزرار الحفظ والإلغاء -->
        <div class="text-center mt-3">
            <button type="submit" class="btn-save">
                <i class="bi bi-check-lg"></i> حفظ التعديلات
            </button>
            <a asp-action="Details" asp-route-id="@Model?.UserId" class="btn-cancel ms-3">
