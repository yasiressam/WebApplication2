        // دعم السحب بالماوس للخريطة
        function setupMapDrag() {
            var mapContainer = document.getElementById('map-container');
            if (!mapContainer) return;
            
            var isDragging = false;
            var startX, startY;
            var scrollLeft, scrollTop;
            
            mapContainer.addEventListener('mousedown', function(e) {
                if (e.target.closest('.prov')) {
                    return;
                }
                
                isDragging = true;
                mapContainer.style.cursor = 'grabbing';
                startX = e.pageX - mapContainer.offsetLeft;
                startY = e.pageY - mapContainer.offsetTop;
                scrollLeft = mapContainer.scrollLeft;
                scrollTop = mapContainer.scrollTop;
                e.preventDefault();
            });
            
            window.addEventListener('mousemove', function(e) {
                if (!isDragging) return;
                
                var x = e.pageX - mapContainer.offsetLeft;
                var y = e.pageY - mapContainer.offsetTop;
                var walkX = (x - startX);
                var walkY = (y - startY);
                
                mapContainer.scrollLeft = scrollLeft - walkX;
                mapContainer.scrollTop = scrollTop - walkY;
                
                e.preventDefault();
            });
            
            window.addEventListener('mouseup', function() {
                isDragging = false;
                mapContainer.style.cursor = 'grab';
            });
            
            mapContainer.addEventListener('touchstart', function(e) {
                if (e.target.closest('.prov')) {
                    return;
                }
                isDragging = true;
                startX = e.touches[0].pageX - mapContainer.offsetLeft;
                startY = e.touches[0].pageY - mapContainer.offsetTop;
                scrollLeft = mapContainer.scrollLeft;
                scrollTop = mapContainer.scrollTop;
            });
            
            mapContainer.addEventListener('touchmove', function(e) {
                if (!isDragging) return;
                var x = e.touches[0].pageX - mapContainer.offsetLeft;
                var y = e.touches[0].pageY - mapContainer.offsetTop;
                var walkX = (x - startX);
                var walkY = (y - startY);
                mapContainer.scrollLeft = scrollLeft - walkX;
                mapContainer.scrollTop = scrollTop - walkY;
            });
            
            mapContainer.addEventListener('touchend', function() {
                isDragging = false;
            });
        }

