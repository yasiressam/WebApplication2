@model WebApplication2.Models.RegisterViewModel

@{
    Layout = "_Layout";
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var isSystemManager = User.IsInRole("SystemManager");
    var canCreatePrivilegedUsers = isSuperAdmin || isSystemManager;
    var managedGovernorates = ((IEnumerable<string>)ViewBag.Governorates)
        .SelectMany(governorate => governorate == "بغداد"
            ? new[] { "بغداد عامة", "بغداد - الكرخ", "بغداد - الرصافة" }
            : new[] { governorate })
        .ToList();
}

<style>
    .create-user-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 12px 35px rgba(30, 60, 114, 0.14);
    }

    .create-user-card .card-header {
        background: linear-gradient(135deg, #1e3c72, #2a5a9c) !important;
        border-bottom: none;
        padding: 1rem 1.25rem;
    }

    .create-user-card .card-body {
        background: rgba(255, 255, 255, 0.98);
        padding: 1.5rem;
    }

    .create-user-card .form-control,
    .create-user-card .form-select {
        border-radius: 12px;
        border: 1px solid #d9e2f2;
        padding: 0.75rem 0.9rem;
    }

    .create-user-card .btn-primary {
        background: linear-gradient(135deg, #1e3c72, #2a5a9c);
        border: none;
        border-radius: 12px;
        padding: 0.8rem 1rem;
        font-weight: 700;
    }

    .create-user-card .btn-secondary {
        border-radius: 12px;
        padding: 0.8rem 1rem;
        font-weight: 600;
    }

    .create-user-card .alert-info {
        border: none;
        background: linear-gradient(135deg, rgba(30, 60, 114, 0.08), rgba(42, 90, 156, 0.12));
        color: #1e3c72;
        border-radius: 14px;
    }
</style>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow create-user-card">
                <div class="card-header text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user-plus"></i>
                        إنشاء مستخدم جديد
                    </h5>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="CreateUserByAdmin" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3" id="emailField">
                            <label asp-for="Email" class="form-label fw-bold">
                                <i class="fas fa-envelope"></i> البريد الإلكتروني
                            </label>
                            <input asp-for="Email" class="form-control" placeholder="example@domain.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-bold">
                                <i class="fas fa-lock"></i> كلمة المرور
                            </label>
                            <input asp-for="Password" class="form-control" type="password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold">
                                <i class="fas fa-lock"></i> تأكيد كلمة المرور
                            </label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Role" class="form-label fw-bold">
                                <i class="fas fa-user-tag"></i> الدور
                            </label>
                            @if (canCreatePrivilegedUsers)
                            {
                                <select asp-for="Role" class="form-select" id="roleSelect">
                                    <option value="User">مستخدم عادي</option>
                                    <option value="Admin">أدمن (مدير محافظة)</option>
                                    <option value="SuperAdmin">سوبر أدمن</option>
                                    @if (isSystemManager)
                                    {
                                        <option value="SystemManager">مدير النظام</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input asp-for="Role" type="hidden" value="User" />
                                <input class="form-control" value="مستخدم عادي" disabled />
                                <small class="form-text text-muted">
                                    تم تثبيت الدور على مستخدم عادي حسب صلاحيات الأدمن.
                                </small>
                            }
                        </div>

                        @if (canCreatePrivilegedUsers)
                        {
                            <div class="mb-3" id="governorateField" style="display: none;">
                                <label asp-for="ManagedGovernorate" class="form-label fw-bold">
                                    <i class="fas fa-map-marker-alt"></i> المحافظة المدارة
                                </label>
                                <select asp-for="ManagedGovernorate" class="form-select" id="ManagedGovernorate">
                                    <option value="">-- اختر المحافظة --</option>
                                    @foreach (var gov in managedGovernorates)
                                    {
                                        <option value="@gov">@gov</option>
                                    }
                                </select>
                                <span asp-validation-for="ManagedGovernorate" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    سيتمكن هذا الأدمن من رؤية وإدارة المستخدمين في هذه المحافظة فقط.
                                </small>
                            </div>
                            <div class="alert alert-info" id="adminInfo" style="display: none;">
                                <i class="fas fa-info-circle"></i>
                                <strong>تنبيه:</strong> عند إنشاء حساب أدمن، سيتمكن من رؤية المستخدمين في المحافظة المحددة فقط.
                            </div>
                        }

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> إنشاء المستخدم
                            </button>
                            <a href="@Url.Action("Users", canCreatePrivilegedUsers ? "SuperAdmin" : "Admin")" class="btn btn-secondary">
                                <i class="fas fa-arrow-right"></i> العودة للقائمة
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            const canCreatePrivilegedUsers = @canCreatePrivilegedUsers.ToString().ToLower();

            if (canCreatePrivilegedUsers) {
                $('#roleSelect').change(function() {
                    var selectedRole = $(this).val();

                    if (selectedRole === 'Admin') {
                        $('#governorateField').slideDown();
                        $('#adminInfo').slideDown();
                        $('#ManagedGovernorate').prop('required', true);
                    } else {
                        $('#governorateField').slideUp();
                        $('#adminInfo').slideUp();
                        $('#ManagedGovernorate').prop('required', false);
                    }
                });

                if ($('#roleSelect').val() === 'Admin') {
                    $('#governorateField').show();
                    $('#adminInfo').show();
                    $('#ManagedGovernorate').prop('required', true);
                }

                $('form').submit(function(e) {
                    var role = $('#roleSelect').val();
                    var governorate = $('#ManagedGovernorate').val();

                    if (role === 'Admin' && !governorate) {
                        e.preventDefault();
                        alert('❌ يجب اختيار المحافظة للأدمن');
                    }
                });
            }
        });
    </script>
}
