@model IEnumerable<WebApplication2.Models.Group>

@{
    ViewData["Title"] = "الوحدات";
    var currentSection = ViewBag.CurrentSection as WebApplication2.Models.Section;
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-8">
            <h2>
                <i class="bi bi-collection"></i> تجمعات الشعبة:
                <span class="text-warning">@(currentSection?.Name ?? "غير محدد")</span>
            </h2>
            @if (currentSection?.Division != null)
            {
                <small class="text-muted">
                    <i class="bi bi-diagram-3"></i> القسم: @currentSection.Division.Name
                    @if (currentSection.Division.AffiliationEntity != null)
                    {
                        <span> | <i class="bi bi-building"></i> جهة الانتساب: @currentSection.Division.AffiliationEntity.Name</span>
                    }
                </small>
            }
        </div>
        <div class="col-4 text-start">
            <a href="@Url.Action("CreateGroup", new { sectionId = ViewBag.SectionId })" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> إضافة تجمع جديد
            </a>
            <a href="@Url.Action("Sections", new { divisionId = currentSection?.DivisionId })" class="btn btn-secondary">
                <i class="bi bi-arrow-right"></i> عودة
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 5%">#</th>
                            <th style="width: 55%">الوحدة</th>
                            <th style="width: 20%">تاريخ الإضافة</th>
                            <th style="width: 20%">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int i = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">@(i++)</td>
                                    <td>
                                        <i class="bi bi-tag-fill text-secondary"></i> @item.Name
                                    </td>
                                    <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-danger"
                                                onclick="deleteGroup(@item.Id, '@item.Name')">
                                            <i class="bi bi-trash"></i> حذف
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    لا توجد وحدات
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteGroup(id, name) {
            if (confirm(`⚠️ هل أنت متأكد من حذف الوحدة "${name}"؟`)) {
                var token = $('input[name="__RequestVerificationToken"]').val();
                if (!token) token = $('form input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("DeleteGroup", "ManageableEntities")',
                    type: 'POST',
                    data: { id: id },
                    headers: { 'RequestVerificationToken': token },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert("❌ " + response.message);
                        }
                    },
                    error: function(xhr) {
                        alert("❌ حدث خطأ: " + (xhr.responseJSON?.message || xhr.statusText));
                    }
                });
            }
        }
    </script>
}
