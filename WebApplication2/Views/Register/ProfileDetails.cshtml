@model WebApplication2.Models.Profile.CompleteProfileViewModel
@{

    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .profile-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        margin-bottom: 25px;
        overflow: hidden;
    }

    .profile-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px;
        position: relative;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        border: 3px solid white;
        box-shadow: 0 3px 10px rgba(0,0,0,0.15);
        object-fit: cover;
    }

    .profile-header h2 {
        font-size: 1.5rem;
        margin-bottom: 0.25rem !important;
    }

    .profile-header p {
        font-size: 0.9rem;
        margin-bottom: 0.5rem !important;
    }

    .section-title {
        color: #495057;
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 3px solid #667eea;
        display: inline-block;
    }

    .info-label {
        font-weight: 600;
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 5px;
    }

    .info-value {
        font-weight: 500;
        color: #212529;
        font-size: 1.1rem;
        margin-bottom: 15px;
        padding: 8px 12px;
        background: #f8f9fa;
        border-radius: 8px;
    }

    .badge-status {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
    }

    .badge-active {
        background: #28a745;
        color: white;
    }

    .badge-pending {
        background: #ffc107;
        color: #212529;
    }

    .badge-review {
        background: #17a2b8;
        color: white;
    }

    .badge-rejected {
        background: #dc3545;
        color: white;
    }

    .badge-completed {
        background: #6f42c1;
        color: white;
    }

    .info-section {
        padding: 20px;
        border-bottom: 1px solid #e9ecef;
    }

        .info-section:last-child {
            border-bottom: none;
        }

    .membership-card {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 15px;
        border-right: 4px solid #667eea;
    }

    .promotion-alert {
        border-radius: 10px;
        padding: 15px 20px;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .alert-info-custom {
        background: #cce5ff;
        border-right: 5px solid #17a2b8;
    }

    .alert-warning-custom {
        background: #fff3cd;
        border-right: 5px solid #ffc107;
    }

    .alert-danger-custom {
        background: #f8d7da;
        border-right: 5px solid #dc3545;
    }

    .alert-success-custom {
        background: #d4edda;
        border-right: 5px solid #28a745;
    }

    .text-white-50 {
        color: rgba(255, 255, 255, 0.7) !important;
    }

    .whatsapp-link-card {
        background: #f0fff4;
        border-right: 5px solid #25d366;
        border-radius: 12px;
        box-shadow: 0 5px 18px rgba(0,0,0,0.08);
        padding: 18px;
        margin-bottom: 20px;
    }

    .whatsapp-link-card .form-control {
        background: white;
    }
    
    .federation-level {
        background: #e8f4f8;
        padding: 5px 10px;
        border-radius: 15px;
        font-size: 0.85rem;
        color: #0c5460;
        margin-right: 8px;
        display: inline-block;
    }
</style>

<div class="container mt-4" dir="rtl">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ========== قسم حالة الحساب ========== -->
    @if (!Model.IsPromoted)
    {
        @if (Model.AccountType == "مكتمل" && Model.RequestedPromotion)
        {
            <div class="alert alert-info-custom promotion-alert">
                <div>
                    <i class="bi bi-info-circle-fill fs-4 me-2"></i>
                    <strong>حسابك قيد المراجعة</strong>
                    <div class="mt-2">
                        <span class="badge bg-info text-white p-2">
                            <i class="bi bi-hourglass-split"></i> ⏳ طلبك قيد المراجعة من قبل الإدارة
                        </span>
                        <p class="small text-muted mt-2 mb-0">سيتم إعلامك عند الانتهاء من المراجعة</p>
                    </div>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(Model.RejectionReason))
        {
            <div class="alert alert-danger-custom promotion-alert">
                <div>
                    <i class="bi bi-x-octagon-fill fs-4 me-2"></i>
                    <strong>تم رفض طلب الترقية</strong>
                    <p class="small mt-2 mb-0"><span class="fw-bold">السبب:</span> @Model.RejectionReason</p>
                    <p class="small text-muted mt-2 mb-0">يمكنك تعديل بياناتك وإكمال الملف الشخصي ليتم إرسال الطلب تلقائياً مرة أخرى</p>
                </div>
            </div>
        }
        else if (Model.AccountType == "عادي")
        {
            <div class="alert alert-warning-custom promotion-alert">
                <div>
                    <i class="bi bi-exclamation-triangle-fill fs-4 me-2"></i>
                    <strong>حسابك غير مكتمل بعد</strong>
                    <p class="small text-muted mt-2 mb-0">بعد إكمال جميع البيانات المطلوبة، سيتم إرسال طلبك تلقائياً للإدارة للمراجعة</p>
                </div>
            </div>
        }
    }

    @if (!Model.IsWhatsAppVerified)
    {
        var pendingWhatsAppPhone = TempData["LinkWhatsAppPhone"]?.ToString();
        var pendingWhatsAppPhoneDisplay = TempData["LinkWhatsAppPhoneDisplay"]?.ToString();
        <div class="whatsapp-link-card">
            <div class="row align-items-center g-3">
                <div class="col-lg-5">
                    <h5 class="mb-2">
                        <i class="bi bi-whatsapp text-success"></i> ربط الحساب بالواتساب
                    </h5>
                    <p class="mb-2 text-muted">
                        بعد ربط الواتساب يمكنك تسجيل الدخول برقم الواتساب وكلمة المرور.
                    </p>
                    <div class="small">
                        رقم الهاتف المسجل لديك:
                        <strong>@(!string.IsNullOrWhiteSpace(Model.PersonalInfo.PhoneNumber) ? Model.PersonalInfo.PhoneNumber : "غير محدد")</strong>
                    </div>
                </div>

                <div class="col-lg-7">
                    @if (!string.IsNullOrWhiteSpace(pendingWhatsAppPhone))
                    {
                        <form asp-action="ConfirmProfileWhatsAppCode" method="post" class="row g-2 align-items-end">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="phoneNumber" value="@pendingWhatsAppPhone" />
                            <div class="col-md-7">
                                <label class="form-label fw-bold">كود التحقق المرسل إلى @pendingWhatsAppPhoneDisplay</label>
                                <input name="code" class="form-control" placeholder="000000" inputmode="numeric" autocomplete="off" />
                            </div>
                            <div class="col-md-5">
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="bi bi-check-circle"></i> تأكيد الواتساب
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="row g-2">
                            @if (!string.IsNullOrWhiteSpace(Model.PersonalInfo.PhoneNumber))
                            {
                                <div class="col-md-5">
                                    <form asp-action="SendProfileWhatsAppCode" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="phoneNumber" value="@Model.PersonalInfo.PhoneNumber" />
                                        <button type="submit" class="btn btn-success w-100">
                                            <i class="bi bi-send"></i> إرسال كود لهذا الرقم
                                        </button>
                                    </form>
                                </div>
                            }
                            <div class="col-md-7">
                                <form asp-action="SendProfileWhatsAppCode" method="post" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input name="phoneNumber" class="form-control" placeholder="رقم واتساب آخر 07XXXXXXXXX" autocomplete="off" />
                                    <button type="submit" class="btn btn-outline-success text-nowrap">
                                        استخدام رقم آخر
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    <!-- الهيدر الرئيسي -->
    <div class="profile-card">
        <div class="profile-header text-center">
            <div class="position-relative">
                @if (!string.IsNullOrEmpty(Model.PersonalInfo.CoverImage))
                {
                    <img src="@Model.PersonalInfo.CoverImage" class="profile-avatar mb-2" alt="الصورة الشخصية">
                }
                else
                {
                    <div class="profile-avatar mb-2 bg-light d-flex align-items-center justify-content-center mx-auto">
                        <i class="bi bi-person" style="font-size: 2rem; color: #667eea;"></i>
                    </div>
                }

                <h2 class="mb-1">@Model.PersonalInfo.FullName @Model.PersonalInfo.LastName</h2>
                <p class="mb-2"><i class="bi bi-envelope"></i> @Model.Email</p>

                <div class="mt-2">
                    @if (Model.IsPromoted)
                    {
                        <!-- تم إزالة "حساب مصعد (فرد)" -->
                    }
                    else if (Model.RequestedPromotion && Model.AccountType == "مكتمل")
                    {
                        <span class="badge-status badge-review">
                            <i class="bi bi-hourglass-split"></i> قيد المراجعة
                        </span>
                    }
                    else if (!string.IsNullOrEmpty(Model.RejectionReason))
                    {
                        <span class="badge-status badge-rejected">
                            <i class="bi bi-x-circle"></i> مرفوض
                        </span>
                    }
                    else if (Model.AccountType == "مكتمل")
                    {
                        <span class="badge-status badge-completed">
                            <i class="bi bi-check-circle"></i> مكتمل
                        </span>
                    }
                    else
                    {
                        <span class="badge-status badge-pending">
                            <i class="bi bi-person"></i> حساب عادي
                        </span>
                    }
                    <span class="badge bg-light text-dark ms-2">
                        <i class="bi bi-calendar"></i> عضو منذ: @Model.CreatedAt.ToString("yyyy-MM-dd")
                    </span>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.WorkLocation.Governorate))
        {
            <div class="info-section">
                <h4 class="section-title">
                    <i class="bi bi-geo-alt-fill"></i> محافظة العمل التنظيمي
                </h4>
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-label">محافظة العمل التنظيمي</div>
                        <div class="info-value">@($"محافظة {Model.WorkLocation.Governorate}")</div>
                    </div>
                </div>
            </div>
        }

        <!-- المعلومات الشخصية -->
        <div class="info-section">
            <h4 class="section-title">
                <i class="bi bi-person"></i> المعلومات الشخصية
            </h4>
            <div class="row">
                <div class="col-md-4">
                    <div class="info-label">الاسم الرباعي</div>
                    <div class="info-value">@Model.PersonalInfo.FullName</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">اللقب</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.PersonalInfo.LastName) ? Model.PersonalInfo.LastName : "---")</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">اسم الأم</div>
                    <div class="info-value">@Model.PersonalInfo.MotherName</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">تاريخ الميلاد</div>
                    <div class="info-value">@Model.PersonalInfo.DateOfBirth.ToString("yyyy-MM-dd")</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">الجنس</div>
                    <div class="info-value">@Model.PersonalInfo.Gender</div>
                </div>
                
                <div class="col-md-4">
                    <div class="info-label">الحالة الاجتماعية</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.PersonalInfo.MaritalStatus) ? Model.PersonalInfo.MaritalStatus : "---")</div>
                </div>
                
                <div class="col-md-4">
                    <div class="info-label">التحصيل الدراسي</div>
                    <div class="info-value">@Model.PersonalInfo.Education</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">الاختصاص</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.PersonalInfo.Specialization) ? Model.PersonalInfo.Specialization : "---")</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">رقم الهاتف</div>
                    <div class="info-value">@Model.PersonalInfo.PhoneNumber</div>
                </div>
                
                @if (Model.PersonalInfo.Education == "طالب جامعي")
                {
                    <div class="col-md-4">
                        <div class="info-label">نوع الجامعة</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.PersonalInfo.UniversityType) ? Model.PersonalInfo.UniversityType : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">نوع المؤسسة</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.PersonalInfo.InstitutionType) ? Model.PersonalInfo.InstitutionType : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">اسم الجامعة/المعهد</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.PersonalInfo.InstitutionName) ? Model.PersonalInfo.InstitutionName : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">الكلية/القسم</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.PersonalInfo.FacultyDepartment) ? Model.PersonalInfo.FacultyDepartment : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">نوع الدراسة</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.PersonalInfo.StudyType) ? Model.PersonalInfo.StudyType : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">المرحلة</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.PersonalInfo.StudyStage) ? Model.PersonalInfo.StudyStage : "---")</div>
                    </div>
                }
            </div>
        </div>

        <!-- عنوان السكن -->
        <div class="info-section">
            <h4 class="section-title">
                <i class="bi bi-geo-alt"></i> عنوان السكن
            </h4>
            <div class="row">
                <div class="col-md-4">
                    <div class="info-label">المحافظة</div>
                    <div class="info-value">@Model.Address.Governorate</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">القضاء</div>
                    <div class="info-value">@Model.Address.District</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">المنطقة</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.Address.Area) ? Model.Address.Area : "---")</div>
                </div>
                <div class="col-md-3">
                    <div class="info-label">المحلة</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.Address.Alley) ? Model.Address.Alley : "---")</div>
                </div>
                <div class="col-md-3">
                    <div class="info-label">الزقاق</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.Address.Street) ? Model.Address.Street : "---")</div>
                </div>
                <div class="col-md-3">
                    <div class="info-label">الدار</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.Address.House) ? Model.Address.House : "---")</div>
                </div>
                <div class="col-md-3">
                    <div class="info-label">أقرب نقطة دالة</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.Address.NearestPoint) ? Model.Address.NearestPoint : "---")</div>
                </div>
            </div>
        </div>

        <!-- المستندات الرسمية -->
        <div class="info-section">
            <h4 class="section-title">
                <i class="bi bi-card-text"></i> المستندات الرسمية
            </h4>
            <div class="row">
                <div class="col-md-4">
                    <div class="info-label">رقم البطاقة الموحدة</div>
                    <div class="info-value">@Model.IdentityCardN</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">تاريخ الإصدار</div>
                    <div class="info-value">@Model.IdentityDate.ToString("yyyy-MM-dd")</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">رقم بطاقة الناخب</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.Documents.VoterCardNumber) ? Model.Documents.VoterCardNumber : "---")</div>
                </div>
                <div class="col-md-4">
                    <div class="info-label">رقم مركز الاقتراع</div>
                    <div class="info-value">@(!string.IsNullOrEmpty(Model.Documents.PollingCenterNumber) ? Model.Documents.PollingCenterNumber : "---")</div>
                </div>
            </div>
        </div>

        <!-- ✅ العمل والتوظيف (مع إضافة JobTitle و JobGrade) -->
        @if (!string.IsNullOrEmpty(Model.Employment.EmploymentStatus) || !string.IsNullOrEmpty(Model.Employment.Work))
        {
            <div class="info-section">
                <h4 class="section-title">
                    <i class="bi bi-briefcase"></i> العمل والتوظيف
                </h4>
                <div class="row">
                    <div class="col-md-4">
                        <div class="info-label">الحالة الوظيفية</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Employment.EmploymentStatus) ? Model.Employment.EmploymentStatus : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">المهنة</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Employment.Work) ? Model.Employment.Work : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">الوزارة</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Employment.Ministry) ? Model.Employment.Ministry : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">الدائرة</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Employment.Department) ? Model.Employment.Department : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">المنصب</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Employment.Position) ? Model.Employment.Position : "---")</div>
                    </div>
                    
                    <!-- ✅ حقول جديدة للموظفين -->
                    @if (Model.Employment.EmploymentStatus == "موظف")
                    {
                        <div class="col-md-4">
                            <div class="info-label">العنوان الوظيفي</div>
                            <div class="info-value">@(!string.IsNullOrEmpty(Model.Employment.JobTitle) ? Model.Employment.JobTitle : "---")</div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-label">الدرجة الوظيفية</div>
                            <div class="info-value">@(!string.IsNullOrEmpty(Model.Employment.JobGrade) ? Model.Employment.JobGrade : "---")</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- الانتساب -->
        @if (!string.IsNullOrEmpty(Model.Affiliation.AffiliationEntity))
        {
            <div class="info-section">
                <h4 class="section-title">
                    <i class="bi bi-diagram-3"></i> معلومات الانتساب
                </h4>
                <div class="row">
                    <div class="col-md-4">
                        <div class="info-label">جهة الانتساب</div>
                        <div class="info-value">@Model.Affiliation.AffiliationEntity</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">القسم</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Affiliation.Division) ? Model.Affiliation.Division : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">الشعبة</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Affiliation.Section) ? Model.Affiliation.Section : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">الوحدة</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Affiliation.Group) ? Model.Affiliation.Group : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">رقم الباج الخاص بك</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Affiliation.BadgeNumber) ? Model.Affiliation.BadgeNumber : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">اسم المزكي</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Affiliation.MozakeName) ? Model.Affiliation.MozakeName : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">رقم هاتف المزكي</div>
                        <div class="info-value">@(!string.IsNullOrEmpty(Model.Affiliation.MozakePhoneNumber) ? Model.Affiliation.MozakePhoneNumber : "---")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">تاريخ الانتماء</div>
                        <div class="info-value">@(Model.Affiliation.AffiliationDate?.ToString("yyyy-MM-dd") ?? "---")</div>
                    </div>
                </div>
            </div>
        }

        <!-- العضويات -->
        @if (!string.IsNullOrEmpty(Model.Memberships.UnionName) || !string.IsNullOrEmpty(Model.Memberships.FederationName) ||
             !string.IsNullOrEmpty(Model.Memberships.AssociationName) || !string.IsNullOrEmpty(Model.Memberships.NgoName))
        {
            <div class="info-section">
                <h4 class="section-title">
                    <i class="bi bi-people"></i> العضويات
                </h4>

                <!-- ========== النقابة (مثل الانتساب) ========== -->
                @if (!string.IsNullOrEmpty(Model.Memberships.UnionName))
                {
                    <div class="row">
                        <div class="col-md-3">
                            <div class="info-label">النقابة</div>
                            <div class="info-value">@Model.Memberships.UnionName</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">الصفة في النقابة</div>
                            <div class="info-value">@(!string.IsNullOrEmpty(Model.Memberships.UnionPosition) ? Model.Memberships.UnionPosition : "---")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">رقم هوية النقابة</div>
                            <div class="info-value">@(!string.IsNullOrEmpty(Model.Memberships.UnionIdNumber) ? Model.Memberships.UnionIdNumber : "---")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">تاريخ النفاذ للنقابة</div>
                            <div class="info-value">@(Model.Memberships.UnionAffiliationDate?.ToString("yyyy-MM-dd") ?? "---")</div>
                        </div>
                    </div>
                }

                <!-- ========== الاتحاد (مثل الانتساب - 4 مستويات) ========== -->
                @if (!string.IsNullOrEmpty(Model.Memberships.FederationName))
                {
                    var federationParts = Model.Memberships.FederationName.Split(new[] { " - " }, StringSplitOptions.None);
            
                    <div class="row">
                        <div class="col-md-3">
                            <div class="info-label">الاتحاد</div>
                            <div class="info-value">@(federationParts.Length >= 1 ? federationParts[0] : "---")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">قسم الاتحاد</div>
                            <div class="info-value">@(federationParts.Length >= 2 ? federationParts[1] : "---")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">شعبة الاتحاد</div>
                            <div class="info-value">@(federationParts.Length >= 3 ? federationParts[2] : "---")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">وحدة الاتحاد</div>
                            <div class="info-value">@(federationParts.Length >= 4 ? federationParts[3] : "---")</div>
                        </div>
                    </div>
            
                    @if (!string.IsNullOrEmpty(Model.Memberships.FederationPosition) ||
                                     !string.IsNullOrEmpty(Model.Memberships.FederationIdNumber) ||
                                     Model.Memberships.FederationAffiliationDate.HasValue)
                    {
                        <div class="row mt-2">
                            <div class="col-md-4">
                                <div class="info-label">الصفة في الاتحاد</div>
                                <div class="info-value">@(!string.IsNullOrEmpty(Model.Memberships.FederationPosition) ? Model.Memberships.FederationPosition : "---")</div>
                            </div>
                            <div class="col-md-4">
                                <div class="info-label">رقم هوية الاتحاد</div>
                                <div class="info-value">@(!string.IsNullOrEmpty(Model.Memberships.FederationIdNumber) ? Model.Memberships.FederationIdNumber : "---")</div>
                            </div>
                            <div class="col-md-4">
                                <div class="info-label">تاريخ النفاذ للاتحاد</div>
                                <div class="info-value">@(Model.Memberships.FederationAffiliationDate?.ToString("yyyy-MM-dd") ?? "---")</div>
                            </div>
                        </div>
                    }
                }

                <!-- ========== الجمعية (مثل الانتساب) ========== -->
                @if (!string.IsNullOrEmpty(Model.Memberships.AssociationName))
                {
                    <div class="row">
                        <div class="col-md-3">
                            <div class="info-label">الجمعية</div>
                            <div class="info-value">@Model.Memberships.AssociationName</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">الصفة في الجمعية</div>
                            <div class="info-value">@(!string.IsNullOrEmpty(Model.Memberships.AssociationPosition) ? Model.Memberships.AssociationPosition : "---")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">رقم هوية الجمعية</div>
                            <div class="info-value">@(!string.IsNullOrEmpty(Model.Memberships.AssociationIdNumber) ? Model.Memberships.AssociationIdNumber : "---")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">تاريخ النفاذ للجمعية</div>
                            <div class="info-value">@(Model.Memberships.AssociationAffiliationDate?.ToString("yyyy-MM-dd") ?? "---")</div>
                        </div>
                    </div>
                }

                <!-- ========== المنظمة غير الحكومية (مثل الانتساب) ========== -->
                @if (!string.IsNullOrEmpty(Model.Memberships.NgoName))
                {
                    <div class="row">
                        <div class="col-md-3">
                            <div class="info-label">المنظمة غير الحكومية</div>
                            <div class="info-value">@Model.Memberships.NgoName</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">الصفة في المنظمة</div>
                            <div class="info-value">@(!string.IsNullOrEmpty(Model.Memberships.NgoPosition) ? Model.Memberships.NgoPosition : "---")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">رقم هوية المنظمة</div>
                            <div class="info-value">@(!string.IsNullOrEmpty(Model.Memberships.NgoIdNumber) ? Model.Memberships.NgoIdNumber : "---")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">تاريخ النفاذ للمنظمة</div>
                            <div class="info-value">@(Model.Memberships.NgoAffiliationDate?.ToString("yyyy-MM-dd") ?? "---")</div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('✅ صفحة الملف الشخصي - النظام التلقائي للترقية مفعل');

            setTimeout(function () {
                $('.alert-success.alert-dismissible').alert('close');
            }, 5000);
        });
    </script>
}
