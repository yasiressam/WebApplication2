                <!-- المنظمة -->
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label small text-muted">اسم المنظمة</label>
                        <select class="form-select" asp-for="Memberships.NgoName">
                            <option value="">اختر المنظمة</option>
                            @if (Model.NgosList != null)
                            {
                                foreach (var ngo in Model.NgosList)
                                {
                                    <option value="@ngo">@ngo</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted">المنصب</label>
                        <input type="text" class="form-control" asp-for="Memberships.NgoPosition" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted">رقم العضوية</label>
                        <input type="text" class="form-control" asp-for="Memberships.NgoIdNumber" />
                    </div>
