        function exportToExcel() {
    try {
        Swal.fire({
            title: 'جاري التصدير...',
            text: 'يرجى الانتظار',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });
        
        // جلب بيانات التصدير مع المجاميع من الخادم
        $.ajax({
            url: '/MapDashboard/GetExportData',
            type: 'GET',
            success: function(response) {
                Swal.close();
                
                if (response && response.success) {
                    var data = response.data;

                    if (data.isManagerScopedView) {
                        var summary = data.summary || {};
                        var managerExcelData = [
                            ['النطاق', 'عدد المنتمين', 'ذكور', 'إناث', 'منتسبين', 'نقابيين', 'اتحاديين', 'جمعيات', 'منظمات غير حكومية'],
                            [
                                data.scopeName || 'نطاق المسؤول',
                                summary.individualCount || 0,
                                summary.maleCount || 0,
                                summary.femaleCount || 0,
                                summary.affiliatedCount || 0,
                                summary.unionCount || 0,
                                summary.federationCount || 0,
                                summary.associationCount || 0,
                                summary.ngoCount || 0
                            ]
                        ];

                        var managerWb = XLSX.utils.book_new();
                        var managerWs = XLSX.utils.aoa_to_sheet(managerExcelData);
                        managerWs['!cols'] = [
                            {wch: 35},
                            {wch: 15},
                            {wch: 10},
                            {wch: 10},
                            {wch: 12},
                            {wch: 12},
                            {wch: 12},
                            {wch: 12},
                            {wch: 18}
                        ];

                        XLSX.utils.book_append_sheet(managerWb, managerWs, "أعداد_نطاق_المسؤول");
                        XLSX.writeFile(managerWb, "اعداد_نطاق_المسؤول.xlsx");

                        Swal.fire({
                            icon: 'success',
                            title: 'تم التصدير بنجاح',
                            text: 'تم تصدير أعداد نطاق المسؤول فقط',
                            timer: 2000,
                            showConfirmButton: false
                        });
                        return;
                    }
                    
                    // ✅ إزالة عامود # من العناوين
                    var excelData = [
                        ['المحافظة', 'عدد المنتمين', 'ذكور', 'إناث', 'أدمن', 'سوبر أدمن', 
                         'منتسبين', 'نقابيين', 'اتحاديين', 'جمعيات', 'منظمات غير حكومية']
                    ];
                    
                    // إضافة بيانات المحافظات (بدون الرقم التسلسلي)
                    var totalIndividuals = 0;
                    var totalMale = 0;
                    var totalFemale = 0;
                    var totalAdmins = 0;
                    var totalSuperAdmins = 0;
                    var totalAffiliated = 0;
                    var totalUnion = 0;
                    var totalFederation = 0;
                    var totalAssociation = 0;
                    var totalNgo = 0;
                    
                    data.governorates.forEach(function(g) { 
                        excelData.push([
                            g.name, 
                            g.individualCount || 0, 
                            g.maleCount || 0, 
                            g.femaleCount || 0, 
                            g.adminCount || 0, 
                            g.superAdminCount || 0, 
                            g.affiliatedCount || 0, 
                            g.unionCount || 0,
                            g.federationCount || 0,
                            g.associationCount || 0,
                            g.ngoCount || 0
                        ]);
                        
                        // تجميع المجاميع
                        totalIndividuals += g.individualCount || 0;
                        totalMale += g.maleCount || 0;
                        totalFemale += g.femaleCount || 0;
                        totalAdmins += g.adminCount || 0;
                        totalSuperAdmins += g.superAdminCount || 0;
                        totalAffiliated += g.affiliatedCount || 0;
                        totalUnion += g.unionCount || 0;
                        totalFederation += g.federationCount || 0;
                        totalAssociation += g.associationCount || 0;
                        totalNgo += g.ngoCount || 0;
                    });
                    
                    // ✅ إضافة صف المجموع النهائي (بدون العمود الفارغ الأول)
                    excelData.push([
                        'المجموع الكلي',
                        totalIndividuals, totalMale, totalFemale, totalAdmins, totalSuperAdmins,
                        totalAffiliated, totalUnion, totalFederation, totalAssociation, totalNgo
                    ]);
                    
                    var wb = XLSX.utils.book_new();
                    var ws = XLSX.utils.aoa_to_sheet(excelData);
                    
                    // تنسيق الأعمدة (تم إزالة العمود الأول)
                    ws['!cols'] = [
                        {wch: 35},  // المحافظة
                        {wch: 15},  // عدد المصعدين
                        {wch: 10},  // ذكور
                        {wch: 10},  // إناث
                        {wch: 10},  // أدمن
                        {wch: 12},  // سوبر أدمن
                        {wch: 12},  // منتسبين
                        {wch: 12},  // نقابيين
                        {wch: 12},  // اتحاديين
                        {wch: 12},  // جمعيات
                        {wch: 12}   // منظمات
                    ];
                    
                    XLSX.utils.book_append_sheet(wb, ws, "المصعدين_حسب_المحافظات");
                    XLSX.writeFile(wb, "اعضاء_مصعدين_المحافظات.xlsx");
                    
                    Swal.fire({
                        icon: 'success',
                        title: 'تم التصدير بنجاح',
                        text: 'تم تصدير البيانات إلى ملف Excel',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire('خطأ', response?.message || 'حدث خطأ في تصدير البيانات', 'error');
                }
            },
            error: function(xhr, status, error) {
                Swal.close();
                console.error('خطأ في التصدير:', error);
                Swal.fire('خطأ', 'حدث خطأ في الاتصال بالخادم: ' + error, 'error');
            }
        });
    } catch(e) { 
        Swal.close();
        Swal.fire('خطأ', 'حدث خطأ في تصدير الملف: ' + e.message, 'error'); 
    }
}

        async function exportCardToExcel(cardType, value) {
