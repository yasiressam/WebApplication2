     // ========== حفظ واسترجاع رقم الصفحة (مؤقت فقط للرجوع من التفاصيل أو الحذف) ==========
function saveCurrentPage() {
    sessionStorage.setItem('currentUserManagementPage', currentPage);
}

function restoreCurrentPage() {
    const savedPage = sessionStorage.getItem('currentUserManagementPage');
    if (savedPage && !isNaN(parseInt(savedPage))) {
        currentPage = parseInt(savedPage);
    }
}

// ✅ التحقق من المصدر ومسح التخزين إذا كان المصدر من خارج صفحة المستخدمين
function checkAndClearStorage() {
    var referrer = document.referrer;
    
    // قائمة بالصفحات التي نريد الاحتفاظ بالصفحة عند العودة منها
    var allowedReferrers = [
        '/SuperAdmin/UserDetails',
        '/SuperAdmin/EditUser',
        '/SuperAdmin/Users'
    ];
    
    var isFromAllowedPage = false;
    for (var i = 0; i < allowedReferrers.length; i++) {
        if (referrer.includes(allowedReferrers[i])) {
            isFromAllowedPage = true;
            break;
        }
    }
    
    // إذا لم يكن المصدر من الصفحات المسموح بها، نمسح التخزين
    if (!isFromAllowedPage && referrer !== '') {
        console.log('🧹 مسح التخزين - المصدر:', referrer);
        sessionStorage.removeItem('currentUserManagementPage');
        currentPage = 1;
    }
}


