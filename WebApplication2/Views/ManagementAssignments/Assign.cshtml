@model WebApplication2.Models.Profile.AssignManagerViewModel

@{
    ViewData["Title"] = "تعيين مباشر لمسؤول أو معاون";
    Layout = "_Layout";

    var prefix = Model.AssignmentRole == "Assistant" ? "معاون" : "مسؤول";
}

<div class="container mt-4" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-person-badge-fill me-2"></i>
                        تعيين مباشر للمستخدم كمسؤول أو معاون
                    </h4>
                </div>

                <div class="card-body">
                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <form asp-action="Assign" method="post">
                        @Html.AntiForgeryToken()

                        <input asp-for="UserId" type="hidden" />
                        <input asp-for="IdentifyId" type="hidden" />
                        <input asp-for="AffiliationEntityId" type="hidden" />
                        <input asp-for="DivisionId" type="hidden" />
                        <input asp-for="SectionId" type="hidden" />
                        <input asp-for="GroupId" type="hidden" />

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label fw-bold">الاسم</label>
                                <input class="form-control" value="@Model.FullName" readonly />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">البريد الإلكتروني</label>
                                <input class="form-control" value="@Model.Email" readonly />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">المحافظة</label>
                                <input class="form-control" value="@Model.Governorate" readonly />
                            </div>

                            @if (Model.Governorate == "بغداد")
                            {
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">نطاق بغداد</label>
                                    <input class="form-control" value="@(string.IsNullOrWhiteSpace(Model.District) ? "مركزي - بغداد كاملة" : Model.District)" readonly />
                                </div>
                            }

                            <div class="col-md-6">
                                <label class="form-label fw-bold">جهة الانتساب</label>
                                <input class="form-control" value="@Model.AffiliationEntityName" readonly />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">القسم</label>
                                <input class="form-control" value="@Model.DivisionName" readonly />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">الشعبة</label>
                                <input class="form-control" value="@Model.SectionName" readonly />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">الوحدة</label>
                                <input class="form-control" value="@Model.GroupName" readonly />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="AssignmentRole" class="form-label fw-bold"></label>
                                <select asp-for="AssignmentRole" class="form-select" id="assignmentRoleSelect">
                                    <option value="">-- اختر نوع التكليف --</option>
                                    <option value="Manager">مسؤول</option>
                                    <option value="Assistant">معاون</option>
                                </select>
                                <span asp-validation-for="AssignmentRole" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="SelectedLevel" class="form-label fw-bold"></label>
                                <select asp-for="SelectedLevel" class="form-select" id="selectedLevelSelect">
                                    <option value="">-- اختر المستوى الإداري --</option>

                                    @foreach (var level in Model.AvailableLevels)
                                    {
                                        if (level == "Entity")
                                        {
                                            <option value="Entity">@($"{prefix} جهة")</option>
                                        }
                                        else if (level == "Division")
                                        {
                                            <option value="Division">@($"{prefix} قسم")</option>
                                        }
                                        else if (level == "Section")
                                        {
                                            <option value="Section">@($"{prefix} شعبة")</option>
                                        }
                                        else if (level == "Group")
                                        {
                                            <option value="Group">@($"{prefix} وحدة")</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="SelectedLevel" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="mt-4 d-flex gap-2 flex-wrap">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle me-1"></i>
                                تأكيد التعيين
                            </button>

                            @if (Model.IsSuperAdmin)
                            {
                                <a asp-controller="SuperAdmin"
                                       asp-action="Users"
                                       class="btn btn-secondary">
                                    <i class="bi bi-arrow-right-circle me-1"></i>
                                    رجوع
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Admin"
                                       asp-action="Users"
                                       class="btn btn-secondary">
                                    <i class="bi bi-arrow-right-circle me-1"></i>
                                    رجوع
                                </a>
                            }
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const roleSelect = document.getElementById('assignmentRoleSelect');
            const levelSelect = document.getElementById('selectedLevelSelect');

            function getPrefix() {
                return roleSelect.value === 'Assistant' ? 'معاون' : 'مسؤول';
            }

            function updateLevelTexts() {
                const prefix = getPrefix();

                Array.from(levelSelect.options).forEach(option => {
                    if (option.value === 'Entity') {
                        option.text = prefix + ' جهة';
                    } else if (option.value === 'Division') {
                        option.text = prefix + ' قسم';
                    } else if (option.value === 'Section') {
                        option.text = prefix + ' شعبة';
                    } else if (option.value === 'Group') {
                        option.text = prefix + ' وحدة';
                    }
                });
            }

            if (roleSelect && levelSelect) {
                roleSelect.addEventListener('change', updateLevelTexts);
                updateLevelTexts();
            }
        })();
    </script>
}
