@model WebApplication2.Models.Profile.CompleteProfileViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "تعديل بيانات المستخدم";

    var workGovernorateValue = Model.WorkLocation.Governorate == "بغداد" && !string.IsNullOrWhiteSpace(Model.WorkLocation.District)
        ? $"بغداد - {Model.WorkLocation.District}"
        : Model.WorkLocation.Governorate;

    var workGovernorates = Model.Governorates?
        .SelectMany(governorate => governorate == "بغداد"
            ? new[] { "بغداد - الكرخ", "بغداد - الرصافة" }
            : new[] { governorate })
        .ToList() ?? new List<string>();
}

<style>
    .form-section {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        margin-bottom: 25px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .form-section-header {
        background: linear-gradient(135deg, #1e3c72, #2a5a9c);
        color: white;
        padding: 12px 20px;
        cursor: pointer;
        transition: all 0.3s;
    }

        .form-section-header:hover {
            background: linear-gradient(135deg, #2a5a9c, #1e3c72);
        }

        .form-section-header h5 {
            margin: 0;
            font-weight: 600;
            display: inline-block;
            font-size: 1rem;
        }

        .form-section-header i {
            margin-left: 10px;
        }

    .toggle-icon {
        float: left;
        font-size: 1.1rem;
        transition: transform 0.3s;
    }

        .toggle-icon.collapsed {
            transform: rotate(-90deg);
        }

    .form-section-body {
        padding: 20px;
        display: block;
    }

        .form-section-body.collapsed {
            display: none;
        }

    .required-field::after {
        content: "*";
        color: #dc3545;
        margin-right: 4px;
    }

    .admin-alert {
        background: #fff3cd;
        border-right: 4px solid #ffc107;
        padding: 12px 20px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .profile-image-preview {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #1e3c72;
        margin-bottom: 15px;
    }

    .profile-image-container {
        cursor: pointer;
        position: relative;
        display: inline-block;
        transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .profile-image-container:hover {
        opacity: 0.92;
        transform: translateY(-2px);
    }

    .profile-image-container:hover::after {
        content: "قص وتعديل";
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(30, 60, 114, 0.55);
        color: #fff;
        font-weight: 700;
        border-radius: 50%;
    }

    .cropper-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(12, 20, 38, 0.78);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        visibility: hidden;
        opacity: 0;
        transition: opacity 0.25s ease, visibility 0.25s ease;
    }

    .cropper-modal-overlay.active {
        visibility: visible;
        opacity: 1;
    }

    .cropper-container-custom {
        width: min(92vw, 760px);
        max-height: 90vh;
        overflow: auto;
        background: #fff;
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.28);
    }

    .cropper-instruction {
        background: #eef4ff;
        color: #1e3c72;
        border-radius: 12px;
        padding: 10px 14px;
        margin-bottom: 16px;
        text-align: center;
        font-weight: 600;
    }

    .cropper-image-stage {
        text-align: center;
        overflow: auto;
    }

    .cropper-image-stage img {
        max-width: 100%;
        max-height: 60vh;
    }

    .cropper-buttons {
        margin-top: 18px;
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-crop-save,
    .btn-crop-cancel {
        border: none;
        border-radius: 999px;
        padding: 10px 24px;
        font-weight: 700;
        color: #fff;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .btn-crop-save {
        background: linear-gradient(135deg, #198754, #20c997);
    }

    .btn-crop-cancel {
        background: #6c757d;
    }

    .btn-crop-save:hover,
    .btn-crop-cancel:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.15);
    }

    .btn-save {
        background: linear-gradient(135deg, #28a745, #20c997);
        color: white;
        border: none;
        padding: 10px 30px;
        border-radius: 30px;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(40, 167, 69, 0.3);
            color: white;
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        border: none;
        padding: 10px 30px;
        border-radius: 30px;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
        }

    .form-control:focus, .form-select:focus {
        border-color: #1e3c72;
        box-shadow: 0 0 0 0.2rem rgba(30, 60, 114, 0.25);
    }

    hr {
        margin: 15px 0;
        background: linear-gradient(90deg, #1e3c72, transparent);
        height: 2px;
    }

    .info-badge {
        background: #e9ecef;
        padding: 8px 15px;
        border-radius: 20px;
        font-size: 0.8rem;
        color: #495057;
    }

    .federation-level-container {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 15px;
        border-right: 3px solid #1e3c72;
    }
</style>

<div class="container-fluid py-3" dir="rtl">
    <!-- رأس الصفحة -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
        <div>
            <h4 class="mb-1">
                <i class="bi bi-pencil-square text-warning"></i>
                تعديل بيانات المستخدم
            </h4>
            <p class="text-muted mb-0 small">تعديل جميع بيانات المستخدم</p>
        </div>
        <div class="info-badge">
            <i class="bi bi-person"></i>
            <strong>@Model?.Email</strong>
        </div>
    </div>

    <!-- تنبيه للمسؤول -->
    <div class="admin-alert">
        <i class="bi bi-shield-shaded text-warning"></i>
        <strong>تنبيه:</strong> أنت تقوم بتعديل بيانات مستخدم آخر. أي تغيير سيتم حفظه مباشرة وسيتم إشعار المستخدم.
    </div>

    <form asp-action="EditUser" method="post" enctype="multipart/form-data" id="editUserForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="AccountType" />
        <input type="hidden" asp-for="IsPromoted" />
        
        <!-- حقول مخفية للحفاظ على معرفات الانتساب -->
        <input type="hidden" asp-for="AffiliationEntityId" />
        <input type="hidden" asp-for="DivisionId" />
        <input type="hidden" asp-for="SectionId" />
        <input type="hidden" asp-for="GroupId" />

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <strong>يرجى تصحيح الأخطاء التالية:</strong>
                <div asp-validation-summary="All" class="mt-2"></div>
            </div>
        }

        <!-- ========== القسم 1: الصورة الشخصية والمعلومات الأساسية ========== -->
        <div class="form-section">
            <div class="form-section-header" onclick="toggleSection(this)">
                <h5>
                    <i class="bi bi-camera"></i>
                    الصورة الشخصية والمعلومات الأساسية
                </h5>
                <i class="bi bi-chevron-up toggle-icon"></i>
            </div>
            <div class="form-section-body">
                <div class="row">
                    <div class="col-md-12 text-center mb-3">
                        <div id="imagePreview" class="profile-image-container" onclick="openCropModal()">
                            @if (!string.IsNullOrEmpty(Model?.PersonalInfo?.CoverImage))
                            {
                                <img src="@Model.PersonalInfo.CoverImage" class="profile-image-preview" id="profileImage" alt="الصورة الشخصية">
                            }
                            else
                            {
                                <div class="profile-image-preview bg-light d-flex align-items-center justify-content-center mx-auto" style="display: flex;">
                                    <i class="bi bi-person" style="font-size: 2rem; color: #1e3c72;"></i>
                                </div>
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label d-block">تغيير الصورة الشخصية</label>
                            <input type="file" class="d-none" asp-for="CoverImageFile" accept="image/*" />
                            <button type="button" class="btn btn-outline-primary" onclick="openCropModal()">
                                <i class="bi bi-pencil-square"></i>
                                تغيير الصورة الشخصية
                            </button>
                            <small class="text-muted">يسمح بصيغ: jpg, png, gif (حد أقصى 5MB)</small>
                            <small class="text-muted d-block">اضغط على الصورة لتعديلها واقتصاصها</small>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label required-field">الاسم الرباعي</label>
                        <input type="text" class="form-control" asp-for="PersonalInfo.FullName" required />
                        <span asp-validation-for="PersonalInfo.FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">اللقب</label>
                        <input type="text" class="form-control" asp-for="PersonalInfo.LastName" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label required-field">اسم الأم</label>
                        <input type="text" class="form-control" asp-for="PersonalInfo.MotherName" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">تاريخ الميلاد</label>
                        <input type="date" class="form-control" asp-for="PersonalInfo.DateOfBirth" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label required-field">الجنس</label>
                        <select class="form-select" asp-for="PersonalInfo.Gender" required>
                            <option value="">اختر الجنس</option>
                            @if (Model.Genders != null)
                            {
                                foreach (var gender in Model.Genders)
                                {
                                    <option value="@gender">@gender</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">الحالة الاجتماعية</label>
                        <select class="form-select" asp-for="PersonalInfo.MaritalStatus">
                            <option value="">اختر الحالة الاجتماعية</option>
                            <option value="أعزب">أعزب</option>
                            <option value="متزوج">متزوج</option>
                            <option value="مطلق">مطلق</option>
                            <option value="أرمل">أرمل</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label required-field">رقم الهاتف</label>
                        <input type="tel" class="form-control" asp-for="PersonalInfo.PhoneNumber" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">المؤهل العلمي</label>
                        <select class="form-select" asp-for="PersonalInfo.Education" id="EducationLevel">
                            <option value="">اختر المؤهل العلمي</option>
                            @if (Model.Educations != null)
                            {
                                foreach (var edu in Model.Educations)
                                {
                                    <option value="@edu">@edu</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-12 mb-3 required-field" id="SpecializationDiv">
                        <label class="form-label">الاختصاص</label>
                        <input type="text" class="form-control" asp-for="PersonalInfo.Specialization" id="PersonalInfo_Specialization" />
                    </div>
                </div>

                <!-- حقول الطالب الجامعي -->
                <div id="UniversityFields" style="display: none;">
                    <hr />
                    <h6 class="text-primary mb-3"><i class="bi bi-building"></i> بيانات الطالب الجامعي</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">نوع الجامعة</label>
                            <select class="form-select" asp-for="PersonalInfo.UniversityType" id="PersonalInfo_UniversityType">
                                <option value="">اختر نوع الجامعة</option>
                                <option value="حكومي">حكومي</option>
                                <option value="أهلي">أهلي</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">نوع المؤسسة</label>
                            <select class="form-select" asp-for="PersonalInfo.InstitutionType" id="PersonalInfo_InstitutionType">
                                <option value="">اختر نوع المؤسسة</option>
                                <option value="جامعة">جامعة</option>
                                <option value="معهد">معهد</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">اسم المؤسسة</label>
                            <input type="text" class="form-control" asp-for="PersonalInfo.InstitutionName" id="PersonalInfo_InstitutionName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">الكلية/القسم</label>
                            <input type="text" class="form-control" asp-for="PersonalInfo.FacultyDepartment" id="PersonalInfo_FacultyDepartment" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">نوع الدراسة</label>
                            <select class="form-select" asp-for="PersonalInfo.StudyType" id="PersonalInfo_StudyType">
                                <option value="">اختر نوع الدراسة</option>
                                <option value="صباحي">صباحي</option>
                                <option value="مسائي">مسائي</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">المرحلة</label>
                            <select class="form-select" asp-for="PersonalInfo.StudyStage" id="PersonalInfo_StudyStage">
                                <option value="">-- اختر المرحلة --</option>
                                @if (Model.StudyStagesList != null)
                                {
                                    foreach (var stage in Model.StudyStagesList)
                                    {
                                        <option value="@stage">@stage</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ========== القسم 2: محافظة العمل التنظيمي ========== -->
        <div class="form-section">
            <div class="form-section-header" onclick="toggleSection(this)">
                <h5>
                    <i class="bi bi-geo-alt-fill"></i>
                    محافظة العمل التنظيمي
                </h5>
                <i class="bi bi-chevron-up toggle-icon"></i>
            </div>
            <div class="form-section-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">محافظة العمل التنظيمي</label>
                        <select class="form-select" name="WorkLocation.Governorate" id="WorkGovernorateSelect">
                            <option value="">اختر محافظة العمل التنظيمي</option>
                            @foreach (var gov in workGovernorates)
                            {
                                <option value="@gov" selected="@(workGovernorateValue == gov ? "selected" : null)">@gov</option>
                            }
                        </select>
                        <input type="hidden" name="WorkLocation.District" value="" />
                    </div>
                </div>
            </div>
        </div>

        <!-- ========== القسم 3: محافظة السكن (مع دعم بغداد) ========== -->
        <div class="form-section">
            <div class="form-section-header" onclick="toggleSection(this)">
                <h5>
                    <i class="bi bi-geo-alt"></i>
                    محافظة السكن
                </h5>
                <i class="bi bi-chevron-up toggle-icon"></i>
            </div>
            <div class="form-section-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label required-field">المحافظة</label>
                        <select class="form-select" asp-for="Address.Governorate" id="GovernorateSelect" required>
                            <option value="">اختر المحافظة</option>
                            @if (Model.Governorates != null)
                            {
                                foreach (var gov in Model.Governorates)
                                {
                                    <option value="@gov">@gov</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- حقل القضاء - قائمة منسدلة خاصة ببغداد -->
                    <div id="districtSelectDiv" class="col-md-4 mb-3" style="display: none;">
                        <label class="form-label">القضاء</label>
                        <select id="districtSelect" class="form-select">
                            <option value="">-- اختر القضاء --</option>
                            @{
                                var baghdadDistrictsList = new List<string> { "الكرخ", "الرصافة" };
                            }
                            @foreach (var district in baghdadDistrictsList)
                            {
                                var isSelected = !string.IsNullOrEmpty(Model.Address.District) && Model.Address.District == district;
                                <option value="@district" selected="@(isSelected ? "selected" : null)">
                                    @district
                                </option>
                            }
                        </select>
                    </div>

                    <!-- حقل القضاء - حقل نص عادي لباقي المحافظات -->
                    <div id="districtInputDiv" class="col-md-4 mb-3">
                        <label class="form-label">القضاء</label>
                        <input type="text" class="form-control" id="Address_District" asp-for="Address.District" />
                    </div>

                    <!-- حقل مخفي لتوحيد القيمة -->
                    <input type="hidden" id="hiddenDistrict" name="Address.District" value="@Model.Address.District" />

                    <div class="col-md-4 mb-3">
                        <label class="form-label">المنطقة</label>
                        <input type="text" class="form-control" asp-for="Address.Area" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">المحلة</label>
                        <input type="text" class="form-control" asp-for="Address.Alley" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">الزقاق</label>
                        <input type="text" class="form-control" asp-for="Address.Street" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">الدار</label>
                        <input type="text" class="form-control" asp-for="Address.House" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">أقرب نقطة دالة</label>
                        <input type="text" class="form-control" asp-for="Address.NearestPoint" />
                    </div>
                </div>
            </div>
        </div>

        <!-- ========== القسم 3: المستندات الرسمية ========== -->
        <div class="form-section">
            <div class="form-section-header" onclick="toggleSection(this)">
                <h5>
                    <i class="bi bi-card-text"></i>
                    المستندات الرسمية
                </h5>
                <i class="bi bi-chevron-up toggle-icon"></i>
            </div>
            <div class="form-section-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label required-field">رقم البطاقة الموحدة</label>
                        <input type="text" class="form-control" asp-for="IdentityCardN" required maxlength="12" pattern="[0-9]*" inputmode="numeric" />
                        <span asp-validation-for="IdentityCardN" class="text-danger"></span>
                        <small class="text-muted">أدخل 12 رقماً</small>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">تاريخ الإصدار</label>
                        <input type="date" class="form-control" asp-for="IdentityDate" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">رقم بطاقة الناخب</label>
                        <input type="text" class="form-control" asp-for="Documents.VoterCardNumber" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">رقم مركز الاقتراع</label>
                        <input type="text" class="form-control" asp-for="Documents.PollingCenterNumber" />
                    </div>
                </div>
            </div>
        </div>

        <!-- ========== القسم 4: العمل التنظيمي ========== -->
        <!-- ========== القسم 5: العمل والتوظيف ========== -->
        <div class="form-section">
            <div class="form-section-header" onclick="toggleSection(this)">
                <h5>
                    <i class="bi bi-briefcase"></i>
                    العمل والتوظيف
                </h5>
                <i class="bi bi-chevron-up toggle-icon"></i>
            </div>
            <div class="form-section-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">الحالة الوظيفية</label>
                        <select class="form-select" asp-for="Employment.EmploymentStatus" id="EmploymentStatus">
                            <option value="">اختر الحالة الوظيفية</option>
                            @if (Model.EmploymentStatuses != null)
                            {
                                foreach (var status in Model.EmploymentStatuses)
                                {
                                    <option value="@status">@status</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">جهة العمل</label>
                        <input type="text" class="form-control" asp-for="Employment.Work" id="Employment_Work" />
                    </div>
                    <div class="col-md-4 mb-3" id="MinistryDiv" style="display: none;">
                        <label class="form-label">الوزارة</label>
                        <select class="form-select" asp-for="Employment.Ministry" id="Employment_Ministry">
                            <option value="">اختر الوزارة</option>
                            @if (Model.Ministries != null)
                            {
                                foreach (var ministry in Model.Ministries)
                                {
                                    <option value="@ministry">@ministry</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3" id="DepartmentDiv" style="display: none;">
                        <label class="form-label">الدائرة</label>
                        <input type="text" class="form-control" asp-for="Employment.Department" id="Employment_Department" />
                    </div>
                    <div class="col-md-4 mb-3" id="PositionDiv" style="display: none;">
                        <label class="form-label">المنصب</label>
                        <input type="text" class="form-control" asp-for="Employment.Position" id="Employment_Position" />
                    </div>
                    <div class="col-md-6 mb-3" id="JobTitleDiv" style="display: none;">
