@model WebApplication2.Models.News

@{
    ViewData["Title"] = "تفاصيل الخبر";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="bi bi-eye me-2"></i> تفاصيل الخبر
            </h4>
        </div>

        <div class="card-body">
            <div class="row">
                <!-- الصورة -->
                <div class="col-md-4 mb-3">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="img-fluid rounded shadow" />
                    }
                    else
                    {
                        <div class="alert alert-secondary text-center py-5">
                            <i class="bi bi-image display-4"></i>
                            <p class="mt-3">لا توجد صورة مرفقة</p>
                        </div>
                    }
                </div>

                <!-- التفاصيل -->
                <div class="col-md-8">
                    <h3 class="text-primary mb-3">@Model.Title</h3>

                    <div class="mb-4 border-start border-primary ps-3">
                        @Html.Raw(Model.Content.Replace("\n", "<br>"))
                    </div>

                    <!-- معلومات الخبر -->
                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <p>
                                        <strong><i class="bi bi-calendar text-primary"></i> تاريخ الإنشاء:</strong><br />
                                        <span class="text-muted">@Model.CreatedAt.ToString("dddd, dd MMMM yyyy - HH:mm")</span>
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    @if (!string.IsNullOrEmpty(Model.AuthorId))
                                    {
                                        <p>
                                            <strong><i class="bi bi-person text-primary"></i> معرف الكاتب:</strong><br />
                                            <span class="text-muted">@Model.AuthorId</span>
                                        </p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- أزرار الإجراءات -->
            <div class="mt-4 pt-3 border-top">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i> تعديل
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i> حذف
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> رجوع للقائمة
                </a>
            </div>
        </div>
    </div>
</div>