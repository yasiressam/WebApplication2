@model WebApplication2.Models.WhatsAppVerificationViewModel

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">
        <div class="custom-card">
            <div class="custom-card-header">
                <h4 class="mb-0">تأكيد رقم الواتساب</h4>
                <p class="mb-0 small">أدخل الكود الذي وصل إلى رقمك</p>
            </div>
            <div class="custom-card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <div class="alert alert-info">
                    تم إرسال كود التحقق إلى: <strong>@Model.PhoneNumber</strong>
                </div>

                <form asp-action="VerifyWhatsApp" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <input asp-for="UserId" type="hidden" />
                    <input asp-for="PhoneNumber" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Code" class="form-label"></label>
                        <input asp-for="Code" class="form-control" placeholder="000000" inputmode="numeric" autocomplete="off" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="custom-btn-primary">تأكيد الواتساب</button>
                    </div>
                </form>

                <form asp-action="ResendWhatsAppCode" method="post" class="mt-3 text-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@Model.UserId" />
                    <input type="hidden" name="phoneNumber" value="@Model.PhoneNumber" />
                    <button type="submit" class="btn btn-link">إعادة إرسال الكود</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
